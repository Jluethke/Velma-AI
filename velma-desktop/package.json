{
  "name": "velma-desktop",
  "version": "1.0.0",
  "description": "Velma — your AI companion. Always watching. Always there.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.wayfindertrust.velma",
    "productName": "Velma",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "assets/velma.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/velma.icns"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "keywords": [],
  "author": "The Wayfinder Trust",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "viem": "^2.0.0"
  }
}
