{
    "name": "sales-deal-autopsy",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["sales", "deal", "loss", "win", "debrief", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Sales Rep",
        "guest": "Buyer"
    },
    "inputs": [
        "shared_company_name",
        "shared_deal_description",
        "shared_outcome",
        "rep_deal_narrative",
        "rep_loss_hypothesis",
        "rep_what_would_have_changed_it",
        "rep_relationship_read",
        "buyer_real_reason",
        "buyer_decision_process",
        "buyer_what_was_missing",
        "buyer_what_almost_changed_their_mind"
    ],
    "outputs": [
        "real_loss_reason",
        "rep_perception_gap",
        "decision_process_map",
        "what_actually_mattered",
        "what_could_have_changed_it",
        "sales_process_diagnosis",
        "next_opportunity_strategy"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Sales rep and buyer each submit their honest account of a deal — won or lost. AI reveals the real reason the deal went the way it did, the gap between what the rep thought was happening and what was actually happening, and what could have changed the outcome."
}
