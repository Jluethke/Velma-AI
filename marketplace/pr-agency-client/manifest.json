{
  "name": "PR Agency Client Engagement",
  "slug": "pr-agency-client",
  "description": "A PR agency and a client each submit their real communications goals, approval tolerance, and news agenda before the engagement — Claude aligns on a PR strategy and working relationship that generates earned media without the approval bottlenecks that kill every news cycle.",
  "domain": "media",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "PR Agency"
  },
  "inputs": [
    { "name": "shared_client_and_agency", "type": "string", "required": true, "shared": true },
    { "name": "shared_pr_objective", "type": "string", "required": true, "shared": true },
    { "name": "agency_pr_strategy", "type": "object", "required": true, "role": "guest" },
    { "name": "agency_scope_and_fees", "type": "object", "required": true, "role": "guest" },
    { "name": "agency_media_relationships_and_access", "type": "object", "required": true, "role": "guest" },
    { "name": "agency_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
    { "name": "agency_what_kills_pr_programs", "type": "array", "required": true, "role": "guest" },
    { "name": "client_communications_goals", "type": "object", "required": true, "role": "host" },
    { "name": "client_story_and_proof_points", "type": "object", "required": true, "role": "host" },
    { "name": "client_sensitive_topics_and_restrictions", "type": "object", "required": true, "role": "host" },
    { "name": "client_approval_and_spokesperson_reality", "type": "object", "required": true, "role": "host" },
    { "name": "client_past_pr_experience", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "pr_strategy_alignment", "type": "object" },
    { "name": "story_and_opportunity_assessment", "type": "object" },
    { "name": "scope_and_fee_structure", "type": "object" },
    { "name": "approval_and_spokesperson_plan", "type": "object" },
    { "name": "sensitive_topic_and_crisis_protocol", "type": "object" },
    { "name": "engagement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
