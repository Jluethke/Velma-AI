{
  "name": "Pharma CMO Agreement",
  "slug": "pharma-cmo-agreement",
  "description": "A pharmaceutical sponsor and a contract manufacturing organization each submit their technical requirements, capacity constraints, and quality expectations before formalizing a manufacturing agreement — AI aligns on a supply arrangement that delivers compliant product at scale without surprises.",
  "domain": "pharma",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Sponsor",
    "guest": "CMO"
  },
  "inputs": [
    { "name": "shared_product_and_program", "type": "string", "required": true, "shared": true },
    { "name": "shared_sponsor_and_cmo", "type": "string", "required": true, "shared": true },
    { "name": "sponsor_technical_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "sponsor_supply_volume_and_timeline", "type": "object", "required": true, "role": "host" },
    { "name": "sponsor_quality_and_regulatory_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "sponsor_ip_and_confidentiality_concerns", "type": "array", "required": true, "role": "host" },
    { "name": "sponsor_concerns_about_this_cmo", "type": "array", "required": true, "role": "host" },
    { "name": "cmo_technical_capabilities", "type": "object", "required": true, "role": "guest" },
    { "name": "cmo_pricing_and_economics", "type": "object", "required": true, "role": "guest" },
    { "name": "cmo_quality_and_compliance_posture", "type": "object", "required": true, "role": "guest" },
    { "name": "cmo_capacity_and_scheduling_constraints", "type": "object", "required": true, "role": "guest" },
    { "name": "cmo_concerns_about_this_sponsor", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "technical_and_quality_alignment", "type": "object" },
    { "name": "commercial_terms", "type": "object" },
    { "name": "supply_and_scheduling_plan", "type": "object" },
    { "name": "quality_agreement_framework", "type": "object" },
    { "name": "ip_and_confidentiality_provisions", "type": "object" },
    { "name": "manufacturing_services_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
