{
    "name": "org-design",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["org", "design", "structure", "leadership", "team", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Executive A",
        "guest": "Executive B"
    },
    "inputs": [
        "shared_company_name",
        "shared_context",
        "exec_a_view_on_structure",
        "exec_a_concerns_about_current_org",
        "exec_a_non_negotiables",
        "exec_a_concerns_about_other_exec",
        "exec_b_view_on_structure",
        "exec_b_concerns_about_current_org",
        "exec_b_non_negotiables",
        "exec_b_concerns_about_other_exec"
    ],
    "outputs": [
        "structural_alignment",
        "tension_zones",
        "design_options",
        "decision_rights_implications",
        "change_management_risks",
        "recommended_structure"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Two executives each submit their real views on org structure, concerns about each other's approach, and non-negotiables. AI finds the structural consensus, names the real tensions, and recommends a design both sides can commit to."
}
