{
    "name": "construction-lender-draw",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["construction", "lender", "draw", "financing", "developer", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Borrower / Developer",
        "guest": "Construction Lender"
    },
    "inputs": [
        "shared_project_name",
        "shared_draw_number",
        "borrower_draw_request",
        "borrower_work_completed",
        "borrower_inspector_concerns_to_address",
        "borrower_project_status",
        "borrower_concerns_about_lender_conditions",
        "lender_draw_review_findings",
        "lender_conditions_to_funding",
        "lender_project_concerns",
        "lender_loan_covenant_status",
        "lender_what_they_need_to_release_funds"
    ],
    "outputs": [
        "draw_readiness_assessment",
        "conditions_checklist",
        "project_health_summary",
        "inspector_finding_resolution",
        "funding_timeline",
        "open_items_to_resolve"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Developer and construction lender each submit their real draw position and project concerns. AI aligns on conditions, surfaces open items, and produces a funding path that does not let administrative gaps delay construction."
}
