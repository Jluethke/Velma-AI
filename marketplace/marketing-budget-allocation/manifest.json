{
    "name": "marketing-budget-allocation",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["marketing", "finance", "budget", "pipeline", "ROI", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Marketing Lead",
        "guest": "Finance Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_fiscal_period",
        "marketing_channel_performance",
        "marketing_proposed_allocation",
        "marketing_pipeline_targets",
        "marketing_what_gets_cut_if_reduced",
        "marketing_concerns_about_roi_framing",
        "finance_total_budget_available",
        "finance_roi_expectations",
        "finance_concerns_about_efficiency",
        "finance_what_needs_justification",
        "finance_flexibility_areas"
    ],
    "outputs": [
        "channel_roi_assessment",
        "allocation_recommendation",
        "pipeline_impact_model",
        "cut_scenario_analysis",
        "justification_package",
        "performance_tracking_framework"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Marketing and finance each submit their real channel data and budget constraints before allocation. AI models ROI by channel, names the pipeline impact of cuts, and produces an allocation plan both sides can defend."
}
