{
    "name": "it-system-migration",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["IT", "migration", "systems", "operations", "business-unit", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "IT / Engineering Lead",
        "guest": "Business Unit Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_system_being_migrated",
        "it_migration_plan",
        "it_timeline",
        "it_cutover_approach",
        "it_rollback_plan",
        "it_concerns_about_business_readiness",
        "bu_operational_dependencies",
        "bu_blackout_periods",
        "bu_cutover_concerns",
        "bu_what_cannot_be_disrupted",
        "bu_training_and_readiness_status"
    ],
    "outputs": [
        "operational_risk_assessment",
        "cutover_timing_recommendation",
        "business_readiness_checklist",
        "contingency_and_rollback_plan",
        "communication_plan",
        "go_live_criteria"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "IT and the business unit each submit their real migration plan and operational constraints. AI surfaces the conflict between technical timeline and business readiness, and produces a go-live plan that does not bring down the business on launch day."
}
