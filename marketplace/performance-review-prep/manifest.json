{
    "name": "performance-review-prep",
    "version": "1.0.0",
    "domain": "career",
    "tags": ["performance", "review", "manager", "employee", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Manager",
        "guest": "Employee"
    },
    "inputs": [
        "shared_employee_name",
        "shared_role",
        "shared_review_period",
        "performance_assessment",
        "rating_rationale",
        "compensation_plans",
        "concerns",
        "growth_plans",
        "relationship_health",
        "self_assessment",
        "accomplishments",
        "compensation_expectations",
        "blockers",
        "growth_goals"
    ],
    "outputs": [
        "alignment_map",
        "gap_analysis",
        "talking_points",
        "compensation_bridge",
        "growth_plan_draft",
        "risk_flags"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Manager and employee each submit their real perspective before the review. Claude finds the gaps in ratings, compensation expectations, and growth plans so the meeting is a real conversation, not a monologue. Prevents the two most common review failures: surprises and empty promises."
}
