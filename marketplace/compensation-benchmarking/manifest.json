{
    "name": "compensation-benchmarking",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["HR", "compensation", "finance", "people", "benchmarking", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "HR / People Lead",
        "guest": "Finance Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_roles_in_scope",
        "hr_current_comp_data",
        "hr_market_benchmarks",
        "hr_equity_gaps",
        "hr_recommended_adjustments",
        "hr_retention_risks",
        "finance_payroll_budget",
        "finance_available_adjustment_budget",
        "finance_concerns_about_request",
        "finance_what_needs_justification",
        "finance_flexibility_areas"
    ],
    "outputs": [
        "comp_gap_analysis",
        "retention_risk_assessment",
        "adjustment_recommendations",
        "budget_impact_model",
        "implementation_plan",
        "equity_remediation_priorities"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "HR and finance each submit their real comp data, budget constraints, and concerns before compensation review. AI models the gap, prioritizes equity adjustments, and produces a plan both sides can defend to leadership."
}
