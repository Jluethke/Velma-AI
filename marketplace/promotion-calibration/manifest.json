{
    "name": "promotion-calibration",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["HR", "management", "promotion", "calibration", "people", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Manager",
        "guest": "HR / People Partner"
    },
    "inputs": [
        "shared_company_name",
        "shared_employee_role_and_level",
        "manager_promotion_case",
        "manager_accomplishments_and_evidence",
        "manager_timing_rationale",
        "manager_concerns_about_process",
        "hr_calibration_data",
        "hr_leveling_criteria",
        "hr_peer_comparison",
        "hr_comp_implications",
        "hr_concerns_about_case"
    ],
    "outputs": [
        "promotion_readiness_assessment",
        "leveling_evaluation",
        "evidence_gap_analysis",
        "comp_adjustment_recommendation",
        "calibration_talking_points",
        "promotion_decision_recommendation"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Manager and HR each submit their real case and calibration data before a promotion decision. Claude assesses readiness against the leveling bar, surfaces evidence gaps, and produces a calibration package both sides can take into the review."
}
