{
    "name": "cre-acquisition-underwriting",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["CRE", "real-estate", "acquisition", "underwriting", "due-diligence", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Buyer / Acquisition Lead",
        "guest": "Broker / Sell-Side Advisor"
    },
    "inputs": [
        "shared_property_address",
        "shared_asset_type",
        "buyer_investment_thesis",
        "buyer_underwriting_assumptions",
        "buyer_due_diligence_findings",
        "buyer_pricing_view",
        "buyer_concerns_about_deal",
        "broker_market_comps",
        "broker_seller_expectations",
        "broker_what_will_kill_the_deal",
        "broker_other_interest_in_asset",
        "broker_deal_timeline_reality"
    ],
    "outputs": [
        "pricing_gap_analysis",
        "underwriting_assumption_review",
        "risk_flag_summary",
        "deal_viability_assessment",
        "offer_strategy",
        "due_diligence_checklist"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Buyer and broker each submit their real underwriting views and market read before pursuing an acquisition. Claude stress-tests the assumptions, names the pricing gap, and produces an offer strategy grounded in what will actually close."
}
