{
    "name": "medical-second-opinion",
    "version": "1.0.0",
    "domain": "health",
    "tags": ["medical", "second-opinion", "doctor", "patient", "treatment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Patient",
        "guest": "Second-Opinion Doctor"
    },
    "inputs": [
        "shared_primary_diagnosis",
        "shared_proposed_treatment",
        "patient_symptoms_and_history",
        "patient_concerns_about_proposed_treatment",
        "patient_quality_of_life_priorities",
        "patient_questions_never_asked",
        "patient_what_they_fear_most",
        "doctor_clinical_assessment",
        "doctor_agreement_or_difference",
        "doctor_recommended_additional_workup",
        "doctor_treatment_alternatives",
        "doctor_prognosis_view"
    ],
    "outputs": [
        "diagnosis_alignment",
        "treatment_comparison",
        "patient_questions_answered",
        "recommended_next_steps",
        "decision_framework",
        "questions_for_primary_doctor"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Patient submits their symptoms, concerns, and the questions they were too afraid to ask. Second-opinion doctor submits their clinical assessment and any disagreements with the proposed treatment. Claude synthesizes a clear decision framework and the questions the patient needs to bring back to their primary doctor."
}
