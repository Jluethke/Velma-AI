{
  "name": "Residential Buyer Agent Engagement",
  "slug": "residential-buyer-agent",
  "description": "A buyer's agent and a homebuyer each submit their real priorities, financial constraints, and market expectations before the search begins — AI aligns on a search strategy that finds the right home without wasting months on misaligned showings.",
  "domain": "real-estate",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Buyer",
    "guest": "Agent"
  },
  "inputs": [
    { "name": "shared_agent_and_buyer", "type": "string", "required": true, "shared": true },
    { "name": "shared_market_and_price_range", "type": "string", "required": true, "shared": true },
    { "name": "agent_market_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_buyer_qualification_read", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_search_strategy", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_compensation", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_concerns_about_this_buyer", "type": "array", "required": true, "role": "guest" },
    { "name": "buyer_real_priorities", "type": "object", "required": true, "role": "host" },
    { "name": "buyer_financial_reality", "type": "object", "required": true, "role": "host" },
    { "name": "buyer_flexibility_and_constraints", "type": "object", "required": true, "role": "host" },
    { "name": "buyer_timeline_and_pressure", "type": "object", "required": true, "role": "host" },
    { "name": "buyer_concerns_about_agents", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "search_criteria_alignment", "type": "object" },
    { "name": "market_reality_briefing", "type": "object" },
    { "name": "financial_and_offer_strategy", "type": "object" },
    { "name": "agent_compensation_disclosure", "type": "object" },
    { "name": "search_process_plan", "type": "object" },
    { "name": "buyer_representation_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
