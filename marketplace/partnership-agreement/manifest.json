{
    "name": "partnership-agreement",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["partnership", "business", "joint-venture", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Partner A",
        "guest": "Partner B"
    },
    "inputs": [
        "shared_partnership_name",
        "shared_business_type",
        "shared_structure",
        "contribution",
        "expected_returns",
        "role_definition",
        "decision_rights",
        "exit_expectations",
        "dealbreakers"
    ],
    "outputs": [
        "alignment_map",
        "contribution_gap",
        "decision_rights_draft",
        "profit_structure_recommendation",
        "exit_clause_draft",
        "partnership_agreement_draft"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Two business partners each submit their real expectations about contributions, returns, decision rights, and exit terms. Claude produces an alignment map and draft partnership agreement — before the handshake becomes a dispute."
}
