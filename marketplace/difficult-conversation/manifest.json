{
    "name": "difficult-conversation",
    "version": "1.0.0",
    "domain": "career",
    "tags": ["communication", "conflict", "difficult", "conversation", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Person A",
        "guest": "Person B"
    },
    "inputs": [
        "shared_relationship_type",
        "shared_conversation_topic",
        "your_perspective",
        "what_you_need",
        "what_you_fear",
        "what_you_wish_they_understood",
        "your_ideal_outcome",
        "what_you_are_willing_to_do_differently"
    ],
    "outputs": [
        "shared_ground",
        "core_tension",
        "each_sides_fear",
        "bridge_statement",
        "conversation_agenda",
        "opening_lines",
        "guardrails"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Both people submit what they actually think and feel before a difficult conversation. Claude finds the shared ground, names the real tension, and writes the opening lines so neither person has to figure out how to start. The hardest part of a hard conversation is starting it."
}
