{
    "name": "vc-term-sheet",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["VC", "venture", "term-sheet", "founder", "investor", "fundraising", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Investor / VC",
        "guest": "Founder / CEO"
    },
    "inputs": [
        "shared_company_name",
        "shared_round_size",
        "investor_valuation_view",
        "investor_terms_required",
        "investor_governance_requirements",
        "investor_concerns_about_deal",
        "investor_what_they_will_not_move_on",
        "founder_valuation_expectations",
        "founder_terms_they_can_accept",
        "founder_dilution_concerns",
        "founder_governance_concerns",
        "founder_what_they_will_not_give_up"
    ],
    "outputs": [
        "valuation_gap_analysis",
        "term_by_term_alignment_map",
        "economic_dilution_model",
        "governance_structure_options",
        "term_sheet_draft",
        "negotiation_path_to_close"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Investor and founder each submit their real valuation views and non-negotiable terms before term sheet negotiation. AI models the economics, maps each term, and produces a term sheet draft both sides can actually close on."
}
