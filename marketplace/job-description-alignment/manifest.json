{
    "name": "job-description-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["hiring", "job-description", "HR", "manager", "recruiting", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Hiring Manager",
        "guest": "HR / Recruiter"
    },
    "inputs": [
        "shared_role_title",
        "shared_team",
        "manager_what_they_actually_need",
        "manager_must_haves",
        "manager_nice_to_haves",
        "manager_culture_requirements",
        "manager_what_failed_in_past_hires",
        "hr_market_reality",
        "hr_compensation_constraints",
        "hr_sourcing_approach",
        "hr_concerns_about_requirements",
        "hr_what_will_widen_or_narrow_pool"
    ],
    "outputs": [
        "requirements_reality_check",
        "compensation_alignment",
        "job_description_draft",
        "sourcing_strategy",
        "screening_criteria",
        "hiring_timeline"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Hiring manager and recruiter each submit their real requirements and market constraints before writing a job description. Claude calibrates the requirements to the market, drafts the JD, and produces a sourcing strategy — so the role fills instead of sitting open for six months."
}
