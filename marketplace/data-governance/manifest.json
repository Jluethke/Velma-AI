{
    "name": "data-governance",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["legal", "data", "privacy", "compliance", "engineering", "governance", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Legal / Privacy Lead",
        "guest": "Data Engineering Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_data_types_in_scope",
        "legal_compliance_requirements",
        "legal_retention_policies",
        "legal_privacy_obligations",
        "legal_what_must_be_enforced",
        "legal_concerns_about_technical_gaps",
        "data_current_architecture",
        "data_technical_feasibility",
        "data_implementation_costs",
        "data_timeline_reality",
        "data_concerns_about_compliance_requirements"
    ],
    "outputs": [
        "compliance_gap_assessment",
        "feasibility_analysis",
        "data_governance_policy_draft",
        "implementation_roadmap",
        "residual_risk_register",
        "ownership_and_accountability_model"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Legal and data engineering each submit their real compliance requirements and technical constraints. AI produces a data governance policy that is actually implementable — not one that gets agreed to and ignored."
}
