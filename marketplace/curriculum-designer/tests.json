{
  "skill_name": "curriculum-designer",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "tc_001",
      "name": "happy_path_standard_curriculum",
      "category": "happy_path",
      "scenario": "Design a complete curriculum for a technical topic with standard inputs, validating all phases execute and all outputs are produced.",
      "input": {
        "topic": "Python Web Development",
        "target_audience": "software engineers transitioning to web development",
        "domain_context": "technology",
        "time_constraints": "12 weeks",
        "resource_preferences": [
          "video",
          "hands-on labs",
          "interactive"
        ]
      },
      "expected_keywords": [
        "curriculum_overview",
        "prerequisites",
        "skill_levels",
        "learning_path",
        "resources",
        "practice_exercises",
        "assessment_criteria",
        "Beginner",
        "Intermediate",
        "Advanced",
        "Expert",
        "capstone_project",
        "learning_objectives"
      ],
      "expected_behavior": "Skill executes all 9 phases successfully, producing a complete curriculum structure with all 7 outputs populated, including learner personas, prerequisite self-assessment, and capstone project.",
      "phase_coverage": [
        "Phase 1: Topic Analysis",
        "Phase 1.5: Learner Persona Mapping",
        "Phase 2: Prerequisites Mapping",
        "Phase 2.5: Self-Assessment & Remediation",
        "Phase 3: Skill Level Framework",
        "Phase 4: Learning Path Sequencing",
        "Phase 5: Resource Curation",
        "Phase 6: Exercise Design",
        "Phase 7: Assessment & Validation",
        "Phase 7.5: Capstone Project Design",
        "Phase 8: Curriculum Synthesis"
      ]
    },
    {
