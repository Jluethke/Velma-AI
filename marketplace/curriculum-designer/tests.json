    {
      "id": "tc_003",
      "name": "edge_case_minimal_inputs",
      "category": "edge_case",
      "scenario": "Design curriculum with only required input (topic), using all defaults for optional inputs, validating graceful handling of minimal specification.",
      "input": {
        "topic": "Project Management Basics"
      },
      "expected_keywords": [
        "curriculum_overview",
        "prerequisites",
        "skill_levels",
        "learning_path",
        "resources",
        "practice_exercises",
        "assessment_criteria",
        "general adult learners",
        "flexible",
        "mixed",
        "learning_objectives"
      ],
      "expected_behavior": "Skill uses default values for optional inputs (target_audience='general adult learners', time_constraints='flexible', resource_preferences=['mixed']) and produces complete curriculum.",
      "phase_coverage": [
        "Phase 1: Topic Analysis",
        "Phase 2: Prerequisites Mapping",
        "Phase 3: Skill Level Framework",
        "Phase 4: Learning Path Sequencing"
      ]
    },
    {
      "id": "tc_004",
      "name": "edge_case_narrow_topic",
      "category": "edge_case",
      "scenario": "Design curriculum for a very narrow/niche topic (e.g., 'Kubernetes StatefulSets') with fewer than 5 core concepts, validating error handling for scope.",
      "input": {
        "topic": "Kubernetes StatefulSets",
        "target_audience": "DevOps engineers",
        "domain_context": "technology",
        "time_constraints": "2 weeks",
        "resource_preferences": [
          "documentation",
          "hands-on labs"
        ]
      },
      "expected_keywords": [
        "curriculum_overview",
        "learning_path",
        "resources",
        "practice_exercises",
        "assessment_criteria",
        "Adjust",
        "combining with related topics",
        "learning_objectives"
      ],
      "expected_behavior": "Skill detects narrow scope, adjusts by suggesting combination with related Kubernetes topics (Deployments, DaemonSets) or treats as single module within broader curriculum.",
      "phase_coverage": [
        "Phase 1: Topic Analysis",
        "Error Handling: Phase 1 narrow topic"
      ]
    },
    {
      "id": "tc_005",
      "name": "edge_case_broad_topic",
      "category": "edge_case",
      "scenario": "Design curriculum for an extremely broad topic (e.g., 'Computer Science') that cannot be meaningfully decomposed into 5-12 concepts, validating scope narrowing.",
      "input": {
        "topic": "Computer Science",
        "target_audience": "high school students",
        "domain_context": "academic",
        "time_constraints": "1 year",
        "resource_preferences": [
          "mixed"
        ]
      },
      "expected_keywords": [
        "Adjust",
        "scope narrowing",
        "split into multiple curricula",
        "too broad",
        "Computer Science Fundamentals",
        "Data Structures",
        "Algorithms"
      ],
      "expected_behavior": "Skill detects overly broad scope and requests narrowing (e.g., 'Computer Science Fundamentals', 'Data Structures & Algorithms', 'Web Development') or suggests splitting into multiple curricula.",
      "phase_coverage": [
        "Phase 1: Topic Analysis",
        "Error Handling: Phase 1 broad topic"
      ]
    },
    {
      "id": "tc_006",
      "name": "error_handling_circular_prerequisites",
      "category": "error_handling",
      "scenario": "Detect and handle circular dependency in prerequisites (e.g., Concept A requires B, B requires C, C requires A), validating error recovery.",
      "input": {
        "topic": "Advanced Database Design",
        "target_audience": "database administrators",
        "domain_context": "technology",
        "time_constraints": "16 weeks",
        "resource_preferences": [
          "documentation",
          "hands-on labs"
        ]
      },
      "expected_keywords": [
        "circular dependency",
        "Adjust",
        "bootstrap concepts",
        "parallel learning",
        "orientation phase",
        "prerequisites",
        "resolved"
      ],
      "expected_behavior": "Skill identifies circular prerequisite dependency, adjusts by identifying bootstrap concepts that can be learned in parallel, adds orientation phase, and produces valid prerequisite ordering.",
      "phase_coverage": [
        "Phase 2: Prerequisites Mapping",
        "Error Handling: Phase 2 circular dependency"
      ]
    },
    {
      "id": "tc_007",
      "name": "error_handling_insufficient_resources",
      "category": "error_handling",
      "scenario": "Handle case where insufficient quality resources exist for a module (e.g., very niche or emerging topic), validating graceful degradation.",
      "input": {
        "topic": "Quantum Machine Learning",
        "target_audience": "machine learning researchers",
        "domain_context": "technology",
        "time_constraints": "20 weeks",
        "resource_preferences": [
          "research papers",
          "courses",
          "hands-on labs"
        ]
      },
      "expected_keywords": [
        "resources",
        "Adjust",
        "community resources",
        "original content",
        "gap noted",
        "learning_path",
        "practice_exercises"
      ],
      "expected_behavior": "Skill identifies modules with insufficient quality resources, recommends community resources or original content creation, documents gaps, and produces curriculum with noted limitations.",
      "phase_coverage": [
        "Phase 5: Resource Curation",
        "Error Handling: Phase 5 insufficient resources"
      ]
    },
    {
      "id": "tc_008",
      "name": "quality_gate_skill_level_differentiation",
      "category": "quality_gate",
      "scenario": "Validate that skill levels are meaningfully differentiated with distinct learning objectives at each level (Beginner, Intermediate, Advanced, Expert).",
      "input": {
        "topic": "Data Analysis with Python",
        "target_audience": "business analysts",
        "domain_context": "technology",
        "time_constraints": "12 weeks",
        "resource_preferences": [
          "video",
          "interactive"
        ]
      },
      "expected_keywords": [
        "skill_levels",
        "Beginner",
        "Intermediate",
        "Advanced",
        "Expert",
        "learning_objectives",
        "distinct",
        "no overlap",
        "SMART format",
        "measurable"
      ],
      "expected_behavior": "Skill produces 4 skill levels with distinct, non-overlapping learning objectives in SMART format. Each level represents clear progression (e.g., Beginner: write basic queries; Intermediate: build dashboards; Advanced: design analytics pipelines; Expert: mentor others).",
      "phase_coverage": [
        "Phase 3: Skill Level Framework",
        "Quality Gate: Phase 3 differentiation"
      ]
    },
    {
      "id": "tc_009",
      "name": "quality_gate_module_sizing",
      "category": "quality_gate",
      "scenario": "Validate that learning path modules are appropriately sized (1-3 core concepts, 4-8 hours each) and sequenced with explicit dependencies.",
      "input": {
        "topic": "React.js Frontend Development",
        "target_audience": "junior web developers",
        "domain_context": "technology",
        "time_constraints": "10 weeks",
        "resource_preferences": [
          "video",
          "hands-on labs",
          "interactive"
        ]
      },
      "expected_keywords": [
        "learning_path",
        "module_number",
        "concepts",
        "duration",
        "prerequisites_within_path",
        "1-3 core concepts",
        "4-8 hours",
        "explicit dependencies",
        "real_world_applications"
      ],
      "expected_behavior": "Skill produces 6-12 modules, each covering 1-3 distinct concepts, completable in 4-8 hours, with explicit prerequisite dependencies and 2+ real-world applications per module.",
      "phase_coverage": [
        "Phase 4: Learning Path Sequencing",
        "Quality Gate: Phase 4 module sizing"
      ]
    },
    {
      "id": "tc_010",
      "name": "quality_gate_assessment_alignment",
      "category": "quality_gate",
      "scenario": "Validate that assessment criteria (knowledge checks + practical tasks) are aligned with learning objectives and use measurable passing thresholds (70% knowledge + 80% exercises).",
      "input": {
        "topic": "Cloud Architecture with AWS",
        "target_audience": "solutions architects",
        "domain_context": "technology",
        "time_constraints": "16 weeks",
        "resource_preferences": [
          "courses",
          "hands-on labs",
          "documentation"
        ]
      },
      "expected_keywords": [
        "assessment_criteria",
        "knowledge_checks",
        "practical_tasks",
        "passing_threshold",
        "70%",
        "80%",
        "aligned",
        "learning_objectives",
        "Beginner",
        "Intermediate",
        "Advanced",
        "Expert"
      ],
      "expected_behavior": "Skill produces assessment criteria for each level with knowledge checks and practical tasks aligned to learning objectives, with explicit passing thresholds (70%+ knowledge + 80%+ exercises).",
      "phase_coverage": [
        "Phase 7: Assessment & Validation",
        "Quality Gate: Phase 7 assessment alignment"
      ]
    }
  ],
