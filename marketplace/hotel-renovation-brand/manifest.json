{
  "name": "Hotel Renovation Brand Standards Alignment",
  "slug": "hotel-renovation-brand",
  "description": "A hotel owner and a brand/franchisor each submit their real capital constraints, brand standard requirements, and renovation timeline before the PIP is finalized — Claude aligns on a renovation scope that satisfies brand standards without the capital overspend that causes owners to exit flags.",
  "domain": "hospitality",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Hotel Owner",
    "guest": "Brand/Franchisor"
  },
  "inputs": [
    { "name": "shared_property_and_brand", "type": "string", "required": true, "shared": true },
    { "name": "shared_property_context", "type": "string", "required": true, "shared": true },
    { "name": "brand_pip_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "brand_timeline_and_milestones", "type": "object", "required": true, "role": "guest" },
    { "name": "brand_priority_ranking", "type": "object", "required": true, "role": "guest" },
    { "name": "brand_concerns_about_this_owner", "type": "array", "required": true, "role": "guest" },
    { "name": "brand_what_they_will_not_waive", "type": "array", "required": true, "role": "guest" },
    { "name": "owner_capital_budget", "type": "object", "required": true, "role": "host" },
    { "name": "owner_renovation_priorities", "type": "object", "required": true, "role": "host" },
    { "name": "owner_operational_constraints", "type": "object", "required": true, "role": "host" },
    { "name": "owner_concerns_about_the_pip", "type": "array", "required": true, "role": "host" },
    { "name": "owner_exit_risk_assessment", "type": "object", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "pip_scope_and_prioritization", "type": "object" },
    { "name": "capital_plan", "type": "object" },
    { "name": "renovation_timeline", "type": "object" },
    { "name": "brand_standard_compliance_framework", "type": "object" },
    { "name": "operational_impact_mitigation_plan", "type": "object" },
    { "name": "pip_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
