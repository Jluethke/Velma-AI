{
  "skill_name": "data-dictionary-builder",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "tc_001",
      "name": "happy_path_postgresql_standard_schema",
      "category": "happy_path",
      "scenario": "Generate complete data dictionary from a standard PostgreSQL database with multiple tables, foreign keys, and schema comments.",
      "input": {
        "database_connection": {
          "host": "localhost",
          "port": 5432,
          "database_name": "ecommerce_db",
          "username": "analyst",
          "password": "${DB_PASSWORD}",
          "connection_type": "postgresql"
        },
        "schema_filter": "public",
        "table_filter": [
          "users",
          "orders",
          "products"
        ],
        "sampling_config": {
          "enabled": true,
          "sample_size": 5,
          "max_table_rows": 1000000,
          "mask_pii": true
        },
        "business_context_source": null,
        "output_format": "json"
      },
      "expected_keywords": [
        "data_dictionary",
        "metadata",
        "tables",
        "columns",
        "relationships",
        "sample_values",
        "data_type",
        "nullable",
        "foreign_key",
        "validation_report",
        "pii_detected",
        "cardinality"
      ],
      "expected_behavior": "Successfully connects to PostgreSQL, retrieves schema for three tables, extracts column metadata with types and constraints, identifies foreign key relationships, retrieves sample data with PII masking, and returns complete structured data dictionary with validation report.",
      "phase_coverage": [
        "Phase 1: Connect and Retrieve Schema",
        "Phase 2: Extract and Structure Column Metadata",
        "Phase 3: Identify Table Relationships",
        "Phase 4: Query Sample Data",
        "Phase 5: Gather Business Context",
        "Phase 6: Compile Data Dictionary",
        "Phase 7: Validate and Report"
      ]
    },
    {
      "id": "tc_002",
      "name": "happy_path_mysql_with_external_documentation",
      "category": "happy_path",
      "scenario": "Generate data dictionary from MySQL database with external business context file providing column descriptions and valid values.",
      "input": {
        "database_connection": {
          "host": "db.example.com",
          "port": 3306,
          "database_name": "customer_analytics",
          "username": "readonly_user",
          "password": "${DB_PASSWORD}",
          "connection_type": "mysql"
        },
        "schema_filter": null,
        "table_filter": null,
        "sampling_config": {
          "enabled": true,
          "sample_size": 10,
          "max_table_rows": 500000,
          "mask_pii": true
        },
        "business_context_source": "/docs/business_context.json",
        "output_format": "markdown"
      },
      "expected_keywords": [
        "data_dictionary",
        "business_purpose",
        "valid_values",
        "enumerated",
        "relationships",
        "cardinality",
        "sample_values",
        "data_quality_notes",
        "markdown",
        "validation_report",
        "missing_descriptions"
      ],
      "expected_behavior": "Connects to MySQL, retrieves all accessible schemas and tables, parses external JSON documentation file, matches descriptions to columns using exact and fuzzy matching, compiles markdown-formatted data dictionary with business context integrated.",
      "phase_coverage": [
        "Phase 1: Connect and Retrieve Schema",
        "Phase 2: Extract and Structure Column Metadata",
        "Phase 3: Identify Table Relationships",
        "Phase 4: Query Sample Data",
        "Phase 5: Gather Business Context",
        "Phase 6: Compile Data Dictionary"
      ]
    },
    {
      "id": "tc_003",
      "name": "edge_case_empty_schema_no_tables",
      "category": "edge_case",
      "scenario": "Attempt to generate data dictionary from a database schema that contains no accessible tables.",
      "input": {
        "database_connection": {
          "host": "localhost",
          "port": 5432,
          "database_name": "empty_db",
          "username": "analyst",
          "password": "${DB_PASSWORD}",
          "connection_type": "postgresql"
        },
        "schema_filter": "empty_schema",
        "table_filter": null,
        "sampling_config": {
          "enabled": true,
          "sample_size": 5,
          "max_table_rows": 1000000,
          "mask_pii": true
        },
        "business_context_source": null,
        "output_format": "json"
      },
      "expected_keywords": [
        "error",
        "empty",
        "inaccessible",
        "schema",
        "no tables found",
        "schema_filter",
        "SELECT permissions",
        "Abort"
      ],
      "expected_behavior": "Connection succeeds but Phase 1 quality gate fails because no tables are found in the schema. Skill aborts with error message indicating empty or inaccessible schema and suggests checking schema_filter parameter and user permissions.",
      "phase_coverage": [
        "Phase 1: Connect and Retrieve Schema"
      ]
    },
