    {
      "id": "tc_005",
      "name": "edge_case_large_table_sampling_skipped",
      "category": "edge_case",
      "scenario": "Generate data dictionary for a table exceeding max_table_rows threshold, testing sampling skip behavior.",
      "input": {
        "database_connection": {
          "host": "localhost",
          "port": 5432,
          "database_name": "analytics_db",
          "username": "analyst",
          "password": "${DB_PASSWORD}",
          "connection_type": "postgresql"
        },
        "schema_filter": "public",
        "table_filter": [
          "events"
        ],
        "sampling_config": {
          "enabled": true,
          "sample_size": 5,
          "max_table_rows": 100000,
          "mask_pii": true
        },
        "business_context_source": null,
        "output_format": "json"
      },
      "expected_keywords": [
        "data_dictionary",
        "sampling skipped",
        "table too large",
        "row_count",
        "columns",
        "sample_values",
        "empty",
        "data_quality_notes",
        "validation_report"
      ],
      "expected_behavior": "Phase 4 detects table row count exceeds max_table_rows threshold, skips sampling for that table, marks as 'sampling skipped - table too large' in data_quality_notes, continues processing remaining metadata, and includes table in final dictionary.",
      "phase_coverage": [
        "Phase 1: Connect and Retrieve Schema",
        "Phase 2: Extract and Structure Column Metadata",
        "Phase 3: Identify Table Relationships",
        "Phase 4: Query Sample Data",
        "Phase 6: Compile Data Dictionary"
      ]
    },
