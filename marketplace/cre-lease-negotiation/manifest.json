{
    "name": "cre-lease-negotiation",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["CRE", "real-estate", "lease", "negotiation", "landlord", "tenant", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Landlord / Listing Broker",
        "guest": "Tenant / Tenant Rep Broker"
    },
    "inputs": [
        "shared_property_address",
        "shared_space_description",
        "landlord_asking_rent",
        "landlord_ti_budget",
        "landlord_lease_terms_required",
        "landlord_tenant_quality_requirements",
        "landlord_non_negotiables",
        "landlord_concerns_about_tenant",
        "tenant_target_rent",
        "tenant_ti_requirements",
        "tenant_space_and_term_needs",
        "tenant_flexibility_on_terms",
        "tenant_concerns_about_building_or_landlord"
    ],
    "outputs": [
        "deal_gap_analysis",
        "term_by_term_negotiation_map",
        "ti_alignment_assessment",
        "negotiated_loi_draft",
        "risk_flags_for_each_side",
        "path_to_execution"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Landlord and tenant each submit their real requirements and constraints before LOI negotiation. Claude maps the gap term-by-term, identifies where trade-offs are possible, and produces a negotiated LOI draft both sides can move forward with."
}
