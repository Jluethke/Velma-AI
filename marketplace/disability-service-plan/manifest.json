{
    "name": "disability-service-plan",
    "version": "1.0.0",
    "domain": "social-services",
    "tags": ["disability services", "case management", "social services", "person-centered", "family", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Case Manager",
        "guest": "Individual / Family"
    },
    "inputs": [
        "shared_individual_name_or_id",
        "shared_service_type_and_program",
        "case_manager_assessment",
        "case_manager_available_services_and_funding",
        "case_manager_recommendations",
        "case_manager_concerns",
        "case_manager_regulatory_requirements",
        "individual_life_goals",
        "individual_current_priorities",
        "family_concerns_and_priorities",
        "individual_what_is_not_working",
        "individual_what_they_will_not_accept"
    ],
    "outputs": [
        "person_centered_goals",
        "service_plan",
        "gap_analysis",
        "natural_supports_plan",
        "risk_and_safety_plan",
        "plan_review_schedule"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The case manager and the individual or family each submit their real goals, available services, and priorities. Claude produces a service plan that reflects what the person actually needs to live, work, and participate in their community."
}
