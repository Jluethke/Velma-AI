{
  "name": "Medical Device Hospital Contract",
  "slug": "medical-device-hospital-contract",
  "description": "A medical device company and a hospital or GPO each submit their clinical requirements, pricing constraints, and contract terms before negotiation — Claude aligns on a supply agreement that gets the right devices to patients at terms both sides can live with.",
  "domain": "healthcare",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Hospital/GPO",
    "guest": "Device Company"
  },
  "inputs": [
    { "name": "shared_device_category", "type": "string", "required": true, "shared": true },
    { "name": "shared_facility_and_company", "type": "string", "required": true, "shared": true },
    { "name": "company_pricing_and_margin", "type": "object", "required": true, "role": "guest" },
    { "name": "company_clinical_support_offer", "type": "object", "required": true, "role": "guest" },
    { "name": "company_contract_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "company_concerns_about_this_account", "type": "array", "required": true, "role": "guest" },
    { "name": "company_what_they_will_not_do", "type": "array", "required": true, "role": "guest" },
    { "name": "hospital_clinical_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "hospital_budget_and_pricing_target", "type": "object", "required": true, "role": "host" },
    { "name": "hospital_current_vendor_situation", "type": "object", "required": true, "role": "host" },
    { "name": "hospital_contract_terms_required", "type": "array", "required": true, "role": "host" },
    { "name": "hospital_concerns_about_this_vendor", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "pricing_and_contract_structure", "type": "object" },
    { "name": "clinical_support_plan", "type": "object" },
    { "name": "volume_and_commitment_terms", "type": "object" },
    { "name": "performance_and_outcomes_framework", "type": "object" },
    { "name": "supply_reliability_provisions", "type": "object" },
    { "name": "contract_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
