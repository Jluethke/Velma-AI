{
    "name": "build-vs-buy",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["engineering", "finance", "strategy", "build", "buy", "make-vs-buy", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Engineering Lead",
        "guest": "Finance / Business Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_capability_in_question",
        "eng_build_complexity",
        "eng_maintenance_burden",
        "eng_team_capacity",
        "eng_integration_concerns",
        "eng_technical_risks",
        "eng_build_preference_and_rationale",
        "finance_budget_available",
        "finance_strategic_value_assessment",
        "finance_vendor_options",
        "finance_timeline_constraints",
        "finance_concerns_about_build_estimates"
    ],
    "outputs": [
        "capability_requirements_definition",
        "build_cost_model",
        "buy_cost_model",
        "strategic_fit_assessment",
        "risk_comparison",
        "recommendation_with_rationale"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Engineering and finance each submit their real constraints and preferences before a build-vs-buy decision. AI models the true cost of each path, names the strategic trade-offs, and produces a recommendation both sides can defend."
}
