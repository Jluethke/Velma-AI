{
    "name": "healthcare-family-care-plan",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["healthcare", "family", "care-plan", "treatment", "patient", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Care Team / Physician",
        "guest": "Patient / Family Decision-Maker"
    },
    "inputs": [
        "shared_patient_situation",
        "shared_diagnosis_or_condition",
        "care_team_diagnosis",
        "care_team_treatment_options",
        "care_team_clinical_recommendation",
        "care_team_risks_of_inaction",
        "care_team_what_they_need_from_family",
        "family_patient_wishes",
        "family_concerns_about_treatment",
        "family_practical_constraints",
        "family_values_and_priorities",
        "family_questions_not_yet_asked"
    ],
    "outputs": [
        "aligned_care_plan",
        "treatment_option_summary",
        "risk_and_benefit_breakdown",
        "decision_framework",
        "care_coordination_plan",
        "questions_to_address_before_proceeding"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Care team and patient family each submit their real clinical perspective and values before making a treatment decision. AI surfaces the questions not yet asked, aligns on the care plan, and ensures no decision gets made in a vacuum of fear or incomplete information."
}
