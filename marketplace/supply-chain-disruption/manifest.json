{
  "name": "Supply Chain Disruption Response",
  "slug": "supply-chain-disruption",
  "description": "An operations leader and a key supplier each submit their real disruption impact, recovery capacity, and business continuity needs when a supply chain problem emerges — AI aligns on a recovery plan that keeps the business running while both sides manage the fallout honestly.",
  "domain": "manufacturing",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Operations Leader",
    "guest": "Supplier"
  },
  "inputs": [
    { "name": "shared_buyer_and_supplier", "type": "string", "required": true, "shared": true },
    { "name": "shared_disruption_description", "type": "string", "required": true, "shared": true },
    { "name": "ops_business_impact", "type": "object", "required": true, "role": "host" },
    { "name": "ops_inventory_position", "type": "object", "required": true, "role": "host" },
    { "name": "ops_alternative_sourcing_assessment", "type": "object", "required": true, "role": "host" },
    { "name": "ops_customer_commitments_at_risk", "type": "object", "required": true, "role": "host" },
    { "name": "ops_what_they_need_from_supplier", "type": "array", "required": true, "role": "host" },
    { "name": "supplier_disruption_root_cause", "type": "object", "required": true, "role": "guest" },
    { "name": "supplier_recovery_timeline", "type": "object", "required": true, "role": "guest" },
    { "name": "supplier_allocation_capacity", "type": "object", "required": true, "role": "guest" },
    { "name": "supplier_financial_and_contractual_exposure", "type": "object", "required": true, "role": "guest" },
    { "name": "supplier_concerns_about_this_buyer", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "disruption_reality_assessment", "type": "object" },
    { "name": "business_continuity_plan", "type": "object" },
    { "name": "recovery_milestone_plan", "type": "object" },
    { "name": "allocation_and_priority_framework", "type": "object" },
    { "name": "financial_and_contractual_resolution", "type": "object" },
    { "name": "relationship_and_future_sourcing_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
