{
  "name": "Therapy Intake Alignment",
  "slug": "therapy-intake-alignment",
  "description": "A therapist and a prospective client each submit their real therapeutic goals, concerns, and fit requirements before the first session — Claude aligns on a therapeutic approach, expectations, and boundaries that give this relationship the best chance of producing meaningful progress.",
  "domain": "health",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Therapist"
  },
  "inputs": [
    { "name": "shared_therapist_and_client", "type": "string", "required": true, "shared": true },
    { "name": "shared_therapy_modality", "type": "string", "required": true, "shared": true },
    { "name": "therapist_clinical_approach", "type": "object", "required": true, "role": "guest" },
    { "name": "therapist_initial_clinical_impression", "type": "object", "required": true, "role": "guest" },
    { "name": "therapist_scope_and_limitations", "type": "object", "required": true, "role": "guest" },
    { "name": "therapist_fee_and_logistics", "type": "object", "required": true, "role": "guest" },
    { "name": "therapist_clinical_concerns", "type": "array", "required": true, "role": "guest" },
    { "name": "client_real_reason_for_therapy", "type": "object", "required": true, "role": "host" },
    { "name": "client_therapy_history", "type": "object", "required": true, "role": "host" },
    { "name": "client_goals_and_fears", "type": "object", "required": true, "role": "host" },
    { "name": "client_practical_constraints", "type": "object", "required": true, "role": "host" },
    { "name": "client_concerns_about_this_therapist", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "therapeutic_fit_assessment", "type": "object" },
    { "name": "treatment_approach_alignment", "type": "object" },
    { "name": "goals_and_expectations_framework", "type": "object" },
    { "name": "scope_and_referral_assessment", "type": "object" },
    { "name": "logistics_and_boundaries", "type": "object" },
    { "name": "engagement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
