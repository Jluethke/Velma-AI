{
    "name": "forecast-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["finance", "business-unit", "forecast", "planning", "revenue", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Business Unit Lead",
        "guest": "Finance / FP&A Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_forecast_period",
        "bu_revenue_forecast",
        "bu_assumptions",
        "bu_pipeline_and_backlog",
        "bu_risks_to_forecast",
        "bu_upside_scenarios",
        "finance_corporate_target",
        "finance_concerns_about_bu_forecast",
        "finance_historical_forecast_accuracy",
        "finance_what_needs_to_be_true",
        "finance_sensitivity_analysis_requests"
    ],
    "outputs": [
        "forecast_gap_analysis",
        "assumption_stress_test",
        "risk_adjusted_forecast",
        "upside_and_downside_scenarios",
        "confidence_assessment",
        "agreed_forecast_submission"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Business unit and finance each submit their real forecast and the assumptions underneath it. Claude stress-tests the assumptions, models risk scenarios, and produces an agreed forecast submission with the confidence level explicitly stated."
}
