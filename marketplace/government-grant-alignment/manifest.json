{
  "name": "Government Grant Alignment",
  "slug": "government-grant-alignment",
  "description": "A government program officer and a grant applicant each submit their real program requirements, compliance expectations, and project design before the award — AI aligns on a funded project that delivers against the program's objectives without the compliance failures that end government grants early.",
  "domain": "government",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Grantee",
    "guest": "Program Officer"
  },
  "inputs": [
    { "name": "shared_agency_and_grantee", "type": "string", "required": true, "shared": true },
    { "name": "shared_program_area", "type": "string", "required": true, "shared": true },
    { "name": "program_objectives_and_priorities", "type": "object", "required": true, "role": "guest" },
    { "name": "compliance_and_reporting_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "program_concerns_about_this_applicant", "type": "object", "required": true, "role": "guest" },
    { "name": "program_what_will_cause_problems", "type": "array", "required": true, "role": "guest" },
    { "name": "program_award_parameters", "type": "object", "required": true, "role": "guest" },
    { "name": "project_design_and_approach", "type": "object", "required": true, "role": "host" },
    { "name": "organizational_capacity", "type": "object", "required": true, "role": "host" },
    { "name": "budget_and_match_reality", "type": "object", "required": true, "role": "host" },
    { "name": "compliance_concerns", "type": "object", "required": true, "role": "host" },
    { "name": "project_risks", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "project_and_program_alignment", "type": "object" },
    { "name": "compliance_readiness_assessment", "type": "object" },
    { "name": "budget_and_match_review", "type": "object" },
    { "name": "reporting_and_monitoring_plan", "type": "object" },
    { "name": "risk_mitigation_framework", "type": "object" },
    { "name": "grant_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
