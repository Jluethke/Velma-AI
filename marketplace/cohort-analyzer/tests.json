              "transaction_date": "2023-01-15T10:30:00Z",
              "revenue_amount": 99.99,
              "product_tier": "pro"
            },
            {
              "customer_id": "C001",
              "transaction_date": "2023-02-15T10:30:00Z",
              "revenue_amount": 99.99,
              "product_tier": "pro"
            },
            {
              "customer_id": "C002",
              "transaction_date": "2023-01-20T14:22:00Z",
              "revenue_amount": 49.99,
              "product_tier": "basic"
            }
          ],
          "row_count": 1200
        },
        "churn_metrics": {
          "records": [
            {
              "customer_id": "C001",
              "churn_date": null,
              "churn_reason": null,
              "last_activity_date": "2024-01-10T08:00:00Z"
