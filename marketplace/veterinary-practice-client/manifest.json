{
  "name": "Veterinary Practice Client Engagement",
  "slug": "veterinary-practice-client",
  "description": "A veterinary practice and a pet owner each submit their real concerns about their pet's health, care preferences, and financial constraints before a significant treatment decision — AI aligns on a care plan that serves the animal's wellbeing within the owner's real circumstances.",
  "domain": "health",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Pet Owner",
    "guest": "Veterinarian"
  },
  "inputs": [
    { "name": "shared_practice_and_client", "type": "string", "required": true, "shared": true },
    { "name": "shared_patient", "type": "string", "required": true, "shared": true },
    { "name": "vet_clinical_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "vet_treatment_options", "type": "object", "required": true, "role": "guest" },
    { "name": "vet_quality_of_life_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "vet_concerns_about_this_case", "type": "array", "required": true, "role": "guest" },
    { "name": "vet_what_they_will_recommend_against", "type": "array", "required": true, "role": "guest" },
    { "name": "owner_goals_for_the_pet", "type": "object", "required": true, "role": "host" },
    { "name": "owner_financial_reality", "type": "object", "required": true, "role": "host" },
    { "name": "owner_concerns_about_treatment", "type": "object", "required": true, "role": "host" },
    { "name": "owner_prior_veterinary_experiences", "type": "array", "required": true, "role": "host" },
    { "name": "owner_what_they_cannot_accept", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "treatment_plan_recommendation", "type": "object" },
    { "name": "options_and_tradeoffs", "type": "object" },
    { "name": "financial_plan", "type": "object" },
    { "name": "quality_of_life_framework", "type": "object" },
    { "name": "owner_commitment_plan", "type": "object" },
    { "name": "communication_and_follow_up_plan", "type": "object" }
  ],
  "version": "1.0.0"
}
