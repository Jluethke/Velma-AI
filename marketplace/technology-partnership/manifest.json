{
  "name": "Technology Partnership",
  "slug": "technology-partnership",
  "description": "Two technology companies each submit their real integration goals, IP boundaries, and commercial expectations before formalizing a partnership — Claude aligns on a structure that delivers customer value, protects each party's core IP, and defines who owns what when the partnership produces something new.",
  "domain": "technology",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Company A",
    "guest": "Company B"
  },
  "inputs": [
    { "name": "shared_company_a_and_b", "type": "string", "required": true, "shared": true },
    { "name": "shared_partnership_purpose", "type": "string", "required": true, "shared": true },
    { "name": "company_a_strategic_objective", "type": "object", "required": true, "role": "host" },
    { "name": "company_a_contribution", "type": "object", "required": true, "role": "host" },
    { "name": "company_a_ip_boundaries", "type": "array", "required": true, "role": "host" },
    { "name": "company_a_commercial_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "company_a_concerns_about_the_partner", "type": "array", "required": true, "role": "host" },
    { "name": "company_b_strategic_objective", "type": "object", "required": true, "role": "guest" },
    { "name": "company_b_contribution", "type": "object", "required": true, "role": "guest" },
    { "name": "company_b_ip_boundaries", "type": "array", "required": true, "role": "guest" },
    { "name": "company_b_commercial_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "company_b_concerns_about_the_partner", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "strategic_alignment_assessment", "type": "object" },
    { "name": "contribution_and_ip_framework", "type": "object" },
    { "name": "commercial_structure", "type": "object" },
    { "name": "joint_development_framework", "type": "object" },
    { "name": "governance_and_termination", "type": "object" },
    { "name": "partnership_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
