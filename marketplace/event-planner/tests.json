        "known_edge_cases": [
          "venue has limited parking",
          "client prefers local vendors"
        ]
      },
      "expected_keywords": [
        "event_brief",
        "guest_list",
        "venue_shortlist",
        "vendor_list",
        "event_timeline",
        "budget_tracker",
        "day_of_runsheet",
