        "debrief_report",
        "SMART",
        "accessibility",
        "contingency"
      ],
      "expected_behavior": "All 9 phases execute successfully, producing complete event planning artifacts with stakeholder alignment, venue selection, vendor coordination, timeline, budget tracking, runsheet, team briefing, and post-event debrief.",
      "phase_coverage": [
        "PHASE 0: PRE-PLANNING ALIGNMENT",
        "PHASE 1: DEFINE EVENT SCOPE",
        "PHASE 2: BUILD GUEST LIST AND MANAGE INVITATIONS",
        "PHASE 3: SELECT AND SECURE VENUE",
        "PHASE 4: COORDINATE VENDORS",
        "PHASE 5: CREATE TIMELINE AND CRITICAL PATH",
        "PHASE 6: TRACK BUDGET AND MANAGE COSTS",
        "PHASE 7: CREATE DAY-OF RUNSHEET",
        "PHASE 8: BRIEF TEAM AND EXECUTE EVENT",
        "PHASE 9: POST-EVENT DEBRIEF AND CLOSEOUT"
