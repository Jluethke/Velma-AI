{
  "name": "Portfolio Add-On Acquisition",
  "slug": "portfolio-addon-acquisition",
  "description": "A private equity platform company and an add-on acquisition target each submit their real strategic fit assessment, valuation expectations, and integration concerns before the deal closes — AI aligns on an acquisition structure where the target understands what they are joining and the platform understands what they are buying.",
  "domain": "financial-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Platform Company",
    "guest": "Acquisition Target"
  },
  "inputs": [
    { "name": "shared_platform_and_target", "type": "string", "required": true, "shared": true },
    { "name": "shared_deal_context", "type": "string", "required": true, "shared": true },
    { "name": "platform_strategic_rationale", "type": "object", "required": true, "role": "host" },
    { "name": "platform_valuation_and_deal_structure", "type": "object", "required": true, "role": "host" },
    { "name": "platform_integration_plan", "type": "object", "required": true, "role": "host" },
    { "name": "platform_concerns_about_the_target", "type": "array", "required": true, "role": "host" },
    { "name": "platform_what_will_kill_the_deal", "type": "array", "required": true, "role": "host" },
    { "name": "target_seller_objectives", "type": "object", "required": true, "role": "guest" },
    { "name": "target_business_reality", "type": "object", "required": true, "role": "guest" },
    { "name": "target_valuation_expectations", "type": "object", "required": true, "role": "guest" },
    { "name": "target_concerns_about_joining_a_platform", "type": "array", "required": true, "role": "guest" },
    { "name": "target_what_they_will_not_accept", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "strategic_fit_and_synergy_assessment", "type": "object" },
    { "name": "valuation_and_structure_alignment", "type": "object" },
    { "name": "due_diligence_risk_map", "type": "object" },
    { "name": "integration_plan_framework", "type": "object" },
    { "name": "earnout_and_retention_structure", "type": "object" },
    { "name": "loi_and_purchase_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
