{
    "name": "insurance-reinsurance-treaty",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["insurance", "reinsurance", "treaty", "cedent", "capacity", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Cedent (Primary Insurer)",
        "guest": "Reinsurer"
    },
    "inputs": [
        "shared_treaty_name",
        "shared_treaty_type",
        "cedent_portfolio_exposure",
        "cedent_desired_cession_terms",
        "cedent_pricing_expectations",
        "cedent_loss_history",
        "cedent_concerns_about_reinsurer",
        "reinsurer_portfolio_analysis",
        "reinsurer_treaty_terms_required",
        "reinsurer_pricing_requirements",
        "reinsurer_capacity_available",
        "reinsurer_concerns_about_cedent_portfolio"
    ],
    "outputs": [
        "exposure_and_pricing_gap",
        "terms_alignment_map",
        "cession_structure_options",
        "pricing_negotiation_range",
        "treaty_draft_terms",
        "capacity_commitment"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Cedent and reinsurer each submit their real portfolio exposure and pricing requirements before treaty negotiations. AI models the economics, surfaces terms misalignment, and produces a treaty structure both sides can execute."
}
