{
  "name": "Mortgage Origination",
  "slug": "mortgage-origination",
  "description": "A mortgage loan officer and a borrower each submit their real financial picture, loan goals, and concerns before the application — AI aligns on the right loan structure, surfaces the full cost of borrowing, and identifies what needs to be resolved before underwriting.",
  "domain": "financial-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Borrower",
    "guest": "Loan Officer"
  },
  "inputs": [
    { "name": "shared_property_and_transaction", "type": "string", "required": true, "shared": true },
    { "name": "shared_borrower_and_lender", "type": "string", "required": true, "shared": true },
    { "name": "lo_credit_and_risk_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "lo_loan_product_recommendation", "type": "object", "required": true, "role": "guest" },
    { "name": "lo_pricing_and_compensation", "type": "object", "required": true, "role": "guest" },
    { "name": "lo_underwriting_concerns", "type": "array", "required": true, "role": "guest" },
    { "name": "lo_what_could_kill_this_deal", "type": "array", "required": true, "role": "guest" },
    { "name": "borrower_financial_reality", "type": "object", "required": true, "role": "host" },
    { "name": "borrower_loan_goals", "type": "object", "required": true, "role": "host" },
    { "name": "borrower_concerns", "type": "array", "required": true, "role": "host" },
    { "name": "borrower_what_they_have_not_disclosed", "type": "array", "required": true, "role": "host" },
    { "name": "borrower_deal_breakers", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "loan_structure_recommendation", "type": "object" },
    { "name": "full_cost_of_borrowing", "type": "object" },
    { "name": "underwriting_risk_assessment", "type": "object" },
    { "name": "rate_lock_and_timeline_plan", "type": "object" },
    { "name": "disclosure_and_compliance_checklist", "type": "object" },
    { "name": "alternative_scenarios", "type": "object" }
  ],
  "version": "1.0.0"
}
