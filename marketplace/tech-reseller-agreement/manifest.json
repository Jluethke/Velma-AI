    { "name": "reseller_what_they_will_not_do", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "channel_value_and_fit_assessment", "type": "object" },
    { "name": "margin_and_economics_structure", "type": "object" },
    { "name": "reseller_requirements_and_commitments", "type": "object" },
    { "name": "channel_conflict_framework", "type": "object" },
    { "name": "enablement_and_support_plan", "type": "object" },
    { "name": "reseller_agreement_framework", "type": "object" }
