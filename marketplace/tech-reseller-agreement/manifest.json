    "host": "ISV",
    "guest": "Reseller"
  },
  "inputs": [
    { "name": "shared_isv_and_reseller", "type": "string", "required": true, "shared": true },
    { "name": "shared_product_and_market", "type": "string", "required": true, "shared": true },
    { "name": "isv_channel_strategy", "type": "object", "required": true, "role": "host" },
    { "name": "isv_margin_and_economics", "type": "object", "required": true, "role": "host" },
    { "name": "isv_requirements_from_reseller", "type": "object", "required": true, "role": "host" },
    { "name": "isv_channel_conflict_policy", "type": "object", "required": true, "role": "host" },
    { "name": "isv_concerns_about_this_reseller", "type": "array", "required": true, "role": "host" },
    { "name": "reseller_market_and_customer_access", "type": "object", "required": true, "role": "guest" },
    { "name": "reseller_margin_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "reseller_support_and_enablement_needs", "type": "object", "required": true, "role": "guest" },
