{
    "name": "healthcare-care-transition",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["healthcare", "care-transition", "discharge", "patient-safety", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Discharging Care Team",
        "guest": "Receiving Facility / Care Team"
    },
    "inputs": [
        "shared_patient_id",
        "shared_diagnosis",
        "discharging_patient_clinical_status",
        "discharging_reason_for_transition",
        "discharging_care_plan",
        "discharging_safety_concerns",
        "discharging_timeline_pressure",
        "receiving_capacity",
        "receiving_what_they_need_to_accept",
        "receiving_clinical_concerns",
        "receiving_resource_constraints",
        "receiving_what_would_prevent_acceptance"
    ],
    "outputs": [
        "transition_readiness_assessment",
        "clinical_handoff_summary",
        "safety_concern_resolution_plan",
        "care_plan_alignment",
        "transition_timeline",
        "escalation_criteria"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Discharging and receiving care teams each submit their real clinical status and capacity constraints before patient transition. AI surfaces safety gaps, aligns on care plan, and produces a handoff protocol that protects the patient."
}
