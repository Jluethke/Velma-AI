{
  "name": "Nonprofit Grant Alignment",
  "slug": "nonprofit-grant-alignment",
  "description": "A program director and a funder each submit their real priorities, funding criteria, and impact expectations before the grant is submitted — Claude aligns on a proposal that reflects what the funder actually funds and what the organization can actually deliver.",
  "domain": "nonprofit",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Program Director",
    "guest": "Funder"
  },
  "inputs": [
    { "name": "shared_organization_and_funder", "type": "string", "required": true, "shared": true },
    { "name": "shared_grant_program_area", "type": "string", "required": true, "shared": true },
    { "name": "funder_strategic_priorities", "type": "object", "required": true, "role": "guest" },
    { "name": "funder_funding_criteria", "type": "object", "required": true, "role": "guest" },
    { "name": "funder_grant_economics", "type": "object", "required": true, "role": "guest" },
    { "name": "funder_concerns_about_this_applicant", "type": "object", "required": true, "role": "guest" },
    { "name": "funder_what_they_will_not_fund", "type": "array", "required": true, "role": "guest" },
    { "name": "program_design_and_theory_of_change", "type": "object", "required": true, "role": "host" },
    { "name": "program_capacity_and_track_record", "type": "object", "required": true, "role": "host" },
    { "name": "funding_need_and_use_of_funds", "type": "object", "required": true, "role": "host" },
    { "name": "program_risks_and_mitigation", "type": "array", "required": true, "role": "host" },
    { "name": "concerns_about_funder_fit", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "strategic_alignment_assessment", "type": "object" },
    { "name": "fundability_assessment", "type": "object" },
    { "name": "proposal_design_recommendations", "type": "object" },
    { "name": "budget_and_economics_alignment", "type": "object" },
    { "name": "capacity_and_risk_assessment", "type": "object" },
    { "name": "grant_relationship_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
