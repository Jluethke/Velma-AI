{
  "name": "Financial Planner Client Engagement",
  "slug": "financial-planner-client",
  "description": "A financial planner and a client each submit their real financial situation, goals, and fears before the engagement begins — Claude aligns on a financial plan that addresses what the client actually needs, not a generic portfolio allocation delivered to someone who hasn't told the advisor the whole story.",
  "domain": "financial-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Financial Planner"
  },
  "inputs": [
    { "name": "shared_planner_and_client", "type": "string", "required": true, "shared": true },
    { "name": "shared_planning_scope", "type": "string", "required": true, "shared": true },
    { "name": "planner_initial_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "planner_service_and_fee_structure", "type": "object", "required": true, "role": "guest" },
    { "name": "planner_fiduciary_and_product_position", "type": "object", "required": true, "role": "guest" },
    { "name": "planner_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
    { "name": "planner_what_they_cannot_help_with", "type": "array", "required": true, "role": "guest" },
    { "name": "client_real_financial_picture", "type": "object", "required": true, "role": "host" },
    { "name": "client_financial_goals", "type": "object", "required": true, "role": "host" },
    { "name": "client_financial_fears", "type": "object", "required": true, "role": "host" },
    { "name": "client_past_advisor_experiences", "type": "array", "required": true, "role": "host" },
    { "name": "client_financial_behaviors", "type": "object", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "financial_situation_assessment", "type": "object" },
    { "name": "planning_priorities", "type": "object" },
    { "name": "fee_and_compensation_disclosure", "type": "object" },
    { "name": "planning_engagement_structure", "type": "object" },
    { "name": "behavioral_and_implementation_plan", "type": "object" },
    { "name": "engagement_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
