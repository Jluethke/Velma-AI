{
  "name": "Creative Agency Client Engagement",
  "slug": "creative-agency-client",
  "description": "A creative agency and a client each submit their real creative vision, budget, approval process, and timeline before the engagement begins — AI aligns on a scope of work that produces great creative without the revision spiral that kills every deadline.",
  "domain": "media",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Agency"
  },
  "inputs": [
    { "name": "shared_client_and_agency", "type": "string", "required": true, "shared": true },
    { "name": "shared_project_brief", "type": "string", "required": true, "shared": true },
    { "name": "agency_creative_approach", "type": "object", "required": true, "role": "guest" },
    { "name": "agency_scope_and_pricing", "type": "object", "required": true, "role": "guest" },
    { "name": "agency_resource_plan", "type": "object", "required": true, "role": "guest" },
    { "name": "agency_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
    { "name": "agency_what_kills_good_work", "type": "array", "required": true, "role": "guest" },
    { "name": "client_creative_vision", "type": "object", "required": true, "role": "host" },
    { "name": "client_business_objective", "type": "object", "required": true, "role": "host" },
    { "name": "client_budget_and_timeline", "type": "object", "required": true, "role": "host" },
    { "name": "client_approval_and_decision_process", "type": "object", "required": true, "role": "host" },
    { "name": "client_past_agency_problems", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "scope_of_work", "type": "object" },
    { "name": "creative_brief_alignment", "type": "object" },
    { "name": "timeline_and_milestone_plan", "type": "object" },
    { "name": "budget_and_fee_structure", "type": "object" },
    { "name": "approval_process_agreement", "type": "object" },
    { "name": "engagement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
