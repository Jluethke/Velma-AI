        "founder_financial_expectations",
        "successor_vision",
        "successor_what_they_would_change",
        "successor_concerns_about_transition",
        "successor_financial_expectations",
        "successor_relationship_with_founder_post_transition"
    ],
    "outputs": [
        "alignment_map",
        "vision_gap",
        "financial_alignment",
        "transition_risks",
        "succession_plan_draft",
        "relationship_structure_post_transition"
