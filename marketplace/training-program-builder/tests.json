      "id": "tc_001",
      "name": "happy_path_intermediate_strength_goal",
      "category": "happy_path",
      "scenario": "Intermediate lifter with 2 years training age, strength goal, full gym access, 4 days/week frequency, no injuries\u2014should generate complete 12-week linear periodization program with all phases, microcycles, and nutrition protocol.",
      "input": {
        "fitness_goals": "increase squat 1RM by 10%",
        "current_fitness_level": {
          "training_age_years": 2,
          "baseline_metrics": {
            "max_squat_lbs": 275,
            "max_deadlift_lbs": 365,
            "body_weight_lbs": 185
          },
          "movement_competency": "intermediate",
          "injury_history": "none"
        },
        "training_frequency": 4,
        "equipment_access": "full_gym",
        "program_duration_weeks": 12,
        "lifestyle_factors": {
          "sleep_quality": "good",
          "stress_level": "moderate",
          "job_demands": "sedentary",
          "recovery_priority": "moderate"
        }
      },
      "expected_keywords": [
        "linear periodization",
        "strength development",
        "3-5 rep range",
        "85-95% 1RM",
        "deload weeks 4 8 12",
        "squat deadlift bench rows",
        "progression rule add 5 lbs",
        "nutrition maintenance surplus",
        "0.8-1.0 g protein per lb",
        "adjustment rules stalled progress",
        "12-week program document",
        "microcycle template"
      ],
      "expected_behavior": "Skill executes all 7 phases successfully, producing a complete periodized training program with 3-4 phases, weekly microcycles, deload protocols, nutrition targets, and adjustment rules. Program document is 15-25 pages, markdown format, self-contained.",
      "phase_coverage": [
        "Phase 1: Assess Fitness Profile",
        "Phase 2: Select Periodization Model",
        "Phase 3: Design Phase-Specific Objectives",
        "Phase 4: Build Weekly Microcycles",
        "Phase 5: Define Progress Markers and Nutrition",
        "Phase 6: Generate Adjustment Rules",
        "Phase 7: Generate Complete Program Document"
      ]
    },
