{
    "name": "renewal-negotiation-prep",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["customer-success", "sales", "renewal", "retention", "negotiation", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Customer Success Manager",
        "guest": "Account Executive"
    },
    "inputs": [
        "shared_company_name",
        "shared_customer_name",
        "shared_renewal_date",
        "cs_account_health",
        "cs_customer_sentiment",
        "cs_what_customer_values",
        "cs_risks_to_renewal",
        "cs_what_customer_has_complained_about",
        "sales_target_contract_value",
        "sales_expansion_opportunity",
        "sales_pricing_flexibility",
        "sales_what_they_need_from_cs",
        "sales_concerns_about_account"
    ],
    "outputs": [
        "account_health_summary",
        "negotiation_strategy",
        "concession_framework",
        "expansion_opportunity_assessment",
        "renewal_proposal_draft",
        "risk_mitigation_plan"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "CS and sales each submit their real read on account health and commercial goals before the renewal conversation. Claude produces a negotiation strategy that protects the relationship and hits the number."
}
