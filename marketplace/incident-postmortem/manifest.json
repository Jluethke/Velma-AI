{
    "name": "incident-postmortem",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["engineering", "product", "postmortem", "incident", "reliability", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Engineering Lead",
        "guest": "Product / Business Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_incident_summary",
        "shared_incident_date",
        "eng_technical_root_cause",
        "eng_timeline_of_events",
        "eng_what_broke_and_why",
        "eng_proposed_remediations",
        "eng_what_they_are_not_responsible_for",
        "product_customer_impact",
        "product_business_impact",
        "product_what_they_need_to_prevent_recurrence",
        "product_concerns_about_eng_root_cause",
        "product_what_customers_are_asking_for"
    ],
    "outputs": [
        "root_cause_summary",
        "impact_assessment",
        "contributing_factors",
        "action_items_with_owners",
        "customer_communication_draft",
        "prevention_commitments"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Engineering and product each submit their real account of an incident — technical cause and business impact — before the postmortem. AI produces a root cause analysis, assigns action items, and drafts the customer communication so the postmortem actually changes something."
}
