{
    "name": "small-biz-loan-prep",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["small business", "loan", "SBA", "financing", "lender", "bank", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Business Owner",
        "guest": "Lender / Banker"
    },
    "inputs": [
        "shared_business_name",
        "shared_loan_amount_requested",
        "owner_business_financials",
        "owner_use_of_funds",
        "owner_collateral_available",
        "owner_credit_and_history",
        "owner_concerns_about_qualification",
        "lender_qualification_criteria",
        "lender_red_flags_in_application",
        "lender_what_would_strengthen_the_application",
        "lender_alternative_structures",
        "lender_timeline_and_process"
    ],
    "outputs": [
        "qualification_gap_analysis",
        "application_strengthening_plan",
        "loan_package_outline",
        "lender_q_and_a_prep",
        "alternative_structures",
        "timeline_and_next_steps"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The business owner and their lender each submit their real financial picture and lending criteria. Claude surfaces the gaps between what the owner thinks qualifies and what the bank actually needs, and produces a loan application package that walks in ready."
}
