{
    "name": "farm-land-lease",
    "version": "1.0.0",
    "domain": "agriculture",
    "tags": ["agriculture", "farm", "land lease", "landowner", "farmer", "crop", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Landowner",
        "guest": "Farmer / Operator"
    },
    "inputs": [
        "shared_farm_description",
        "shared_lease_term_requested",
        "landowner_financial_requirements",
        "landowner_land_stewardship_requirements",
        "landowner_concerns_about_the_farmer",
        "landowner_long_term_goals",
        "landowner_what_they_will_not_accept",
        "farmer_operation_plan",
        "farmer_economic_model",
        "farmer_investment_requirements",
        "farmer_concerns_about_the_lease",
        "farmer_long_term_intentions"
    ],
    "outputs": [
        "lease_economics_assessment",
        "lease_structure_recommendation",
        "stewardship_and_practices_agreement",
        "improvement_and_investment_framework",
        "lease_term_and_renewal_structure",
        "lease_agreement_framework"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The landowner and the farmer each submit their real financial requirements, land use expectations, and long-term goals. Claude designs the lease terms that give the farmer a viable operation and the landowner fair returns and a partner who takes care of the land."
