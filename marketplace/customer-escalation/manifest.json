{
    "name": "customer-escalation",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["customer-success", "product", "escalation", "retention", "CX", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Customer Success",
        "guest": "Product / Engineering Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_customer_name",
        "cs_customer_complaint",
        "cs_relationship_risk",
        "cs_what_customer_needs_to_stay",
        "cs_timeline_pressure",
        "cs_what_they_have_already_committed",
        "product_root_cause",
        "product_what_is_fixable_and_when",
        "product_workarounds_available",
        "product_what_is_not_possible",
        "product_concerns_about_cs_commitments"
    ],
    "outputs": [
        "root_cause_summary",
        "retention_risk_assessment",
        "escalation_response_plan",
        "customer_communication_draft",
        "fix_timeline",
        "commitment_alignment"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Customer success and product each submit the real situation and constraints before responding to a customer escalation. Claude aligns on what is and is not possible, drafts the response plan, and prevents CS from over-committing to what engineering cannot deliver."
}
