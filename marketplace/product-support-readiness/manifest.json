{
    "name": "product-support-readiness",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["product", "support", "customer-success", "launch", "readiness", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Product Manager",
        "guest": "Support / CS Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_feature_or_release",
        "shared_launch_date",
        "product_what_is_launching",
        "product_known_edge_cases",
        "product_what_support_should_know",
        "product_timeline_constraints",
        "product_concerns_about_support_readiness",
        "support_what_they_need_before_launch",
        "support_volume_projections",
        "support_training_status",
        "support_documentation_gaps",
        "support_what_will_cause_escalations"
    ],
    "outputs": [
        "support_readiness_assessment",
        "documentation_gap_list",
        "training_plan",
        "escalation_path_definition",
        "launch_support_coverage_plan",
        "go_live_support_criteria"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Product and support each submit their real launch status and readiness gaps. Claude surfaces what support needs that product has not provided, produces a training and documentation plan, and ensures support is not learning the product from confused customers on launch day."
}
