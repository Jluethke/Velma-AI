{
    "name": "quota-setting",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["sales", "finance", "quota", "revenue", "planning", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Sales Leadership",
        "guest": "Finance Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_fiscal_period",
        "sales_territory_capacity",
        "sales_pipeline_reality",
        "sales_market_conditions",
        "sales_team_morale_risks",
        "sales_what_is_achievable",
        "finance_revenue_targets",
        "finance_board_commitments",
        "finance_comp_budget",
        "finance_margin_requirements",
        "finance_concerns_about_sales_estimates"
    ],
    "outputs": [
        "quota_model",
        "attainment_probability_assessment",
        "territory_allocation",
        "comp_plan_alignment",
        "risk_scenarios",
        "negotiated_quota_recommendation"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Sales leadership and finance each submit their real pipeline read and revenue targets before quota-setting. Claude models what is actually achievable, names the gap, and produces a quota plan both sides can commit to."
}
