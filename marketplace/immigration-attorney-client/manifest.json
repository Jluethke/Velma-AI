{
  "name": "Immigration Attorney Client Engagement",
  "slug": "immigration-attorney-client",
  "description": "An immigration attorney and a client each submit their real immigration goals, timeline pressures, and case facts before the engagement begins — AI aligns on a legal strategy and engagement structure that navigates the actual pathway to the client's immigration objective without false hope or missed deadlines.",
  "domain": "professional-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Immigration Attorney"
  },
  "inputs": [
    { "name": "shared_attorney_and_client", "type": "string", "required": true, "shared": true },
    { "name": "shared_immigration_objective", "type": "string", "required": true, "shared": true },
    { "name": "attorney_case_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "attorney_recommended_strategy", "type": "object", "required": true, "role": "guest" },
    { "name": "attorney_fees_and_timeline", "type": "object", "required": true, "role": "guest" },
    { "name": "attorney_concerns_about_this_case", "type": "array", "required": true, "role": "guest" },
    { "name": "attorney_what_they_will_not_do", "type": "array", "required": true, "role": "guest" },
    { "name": "client_immigration_history", "type": "object", "required": true, "role": "host" },
    { "name": "client_timeline_and_pressure", "type": "object", "required": true, "role": "host" },
    { "name": "client_employer_and_sponsor_situation", "type": "object", "required": true, "role": "host" },
    { "name": "client_concerns_about_the_process", "type": "array", "required": true, "role": "host" },
    { "name": "client_what_they_have_not_disclosed", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "legal_pathway_analysis", "type": "object" },
    { "name": "case_risk_assessment", "type": "object" },
    { "name": "timeline_and_milestone_plan", "type": "object" },
    { "name": "fee_and_government_cost_disclosure", "type": "object" },
    { "name": "client_obligations", "type": "object" },
    { "name": "engagement_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
