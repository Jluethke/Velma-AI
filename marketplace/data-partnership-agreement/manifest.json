{
  "name": "Data Partnership Agreement",
  "slug": "data-partnership-agreement",
  "description": "A data provider and a data licensee each submit their real data specifications, use case requirements, and privacy constraints before formalizing a data agreement — Claude aligns on a licensing structure that gives the licensee what they actually need while protecting the provider's data asset and compliance posture.",
  "domain": "technology",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Data Provider",
    "guest": "Licensee"
  },
  "inputs": [
    { "name": "shared_provider_and_licensee", "type": "string", "required": true, "shared": true },
    { "name": "shared_data_category", "type": "string", "required": true, "shared": true },
    { "name": "provider_data_asset", "type": "object", "required": true, "role": "host" },
    { "name": "provider_licensing_economics", "type": "object", "required": true, "role": "host" },
    { "name": "provider_use_case_restrictions", "type": "object", "required": true, "role": "host" },
    { "name": "provider_privacy_and_compliance_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "provider_concerns_about_this_licensee", "type": "array", "required": true, "role": "host" },
    { "name": "licensee_use_case", "type": "object", "required": true, "role": "guest" },
    { "name": "licensee_data_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "licensee_budget_and_pricing_tolerance", "type": "object", "required": true, "role": "guest" },
    { "name": "licensee_compliance_and_security_posture", "type": "object", "required": true, "role": "guest" },
    { "name": "licensee_concerns_about_this_provider", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "data_specification_alignment", "type": "object" },
    { "name": "licensing_economics", "type": "object" },
    { "name": "use_case_and_restriction_framework", "type": "object" },
    { "name": "privacy_and_compliance_framework", "type": "object" },
    { "name": "data_quality_and_sla", "type": "object" },
    { "name": "data_license_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
