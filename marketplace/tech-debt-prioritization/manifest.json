{
    "name": "tech-debt-prioritization",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["engineering", "product", "tech-debt", "prioritization", "roadmap", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Engineering Lead",
        "guest": "Product Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_planning_horizon",
        "eng_debt_inventory",
        "eng_risk_ratings",
        "eng_effort_estimates",
        "eng_what_is_causing_most_pain",
        "eng_what_creates_risk_if_ignored",
        "product_roadmap_priorities",
        "product_capacity_needed",
        "product_what_they_will_trade",
        "product_reliability_concerns",
        "product_concerns_about_eng_estimates"
    ],
    "outputs": [
        "debt_risk_matrix",
        "capacity_trade_off_model",
        "prioritized_debt_backlog",
        "roadmap_impact_assessment",
        "investment_recommendation",
        "agreed_allocation_plan"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Engineering and product each submit their real debt inventory, risk ratings, and roadmap constraints before planning. AI models the trade-offs and produces a prioritized debt plan both sides have actually agreed to fund."
}
