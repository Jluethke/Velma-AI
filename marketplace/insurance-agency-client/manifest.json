{
  "name": "Insurance Agency Client Engagement",
  "slug": "insurance-agency-client",
  "description": "An insurance agent and a client each submit their real coverage needs, risk profile, and budget before the placement — AI aligns on a coverage program that addresses the client's actual exposures without paying for coverage they don't need.",
  "domain": "financial-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Insurance Agent"
  },
  "inputs": [
    { "name": "shared_client_and_agency", "type": "string", "required": true, "shared": true },
    { "name": "shared_coverage_lines_needed", "type": "string", "required": true, "shared": true },
    { "name": "agent_risk_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_coverage_recommendations", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_market_options", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_compensation_and_fees", "type": "object", "required": true, "role": "guest" },
    { "name": "agent_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
    { "name": "client_operations_and_exposures", "type": "object", "required": true, "role": "host" },
    { "name": "client_coverage_priorities", "type": "object", "required": true, "role": "host" },
    { "name": "client_budget_and_constraints", "type": "object", "required": true, "role": "host" },
    { "name": "client_claims_and_loss_history", "type": "array", "required": true, "role": "host" },
    { "name": "client_concerns_about_coverage", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "coverage_program_design", "type": "object" },
    { "name": "premium_and_cost_summary", "type": "object" },
    { "name": "coverage_gaps_and_exclusions", "type": "object" },
    { "name": "risk_management_recommendations", "type": "object" },
    { "name": "agent_compensation_disclosure", "type": "object" },
    { "name": "renewal_and_service_plan", "type": "object" }
  ],
  "version": "1.0.0"
}
