{
    "name": "contract-scope-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["contract", "scope", "freelance", "agency", "client", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Client",
        "guest": "Contractor"
    },
    "inputs": [
        "shared_project_name",
        "shared_project_type",
        "project_description",
        "budget_ceiling",
        "timeline",
        "success_definition",
        "flexibility_areas",
        "scope_interpretation",
        "realistic_timeline",
        "pricing_rationale",
        "constraints",
        "concerns"
    ],
    "outputs": [
        "scope_alignment_map",
        "budget_bridge",
        "timeline_reconciliation",
        "risk_register",
        "sow_draft",
        "negotiation_priorities"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Client and contractor each submit what they actually expect before a contract is signed. AI surfaces where the scope, budget, and timeline assumptions diverge — before those divergences become disputes. Produces a draft Statement of Work both sides can edit."
}
