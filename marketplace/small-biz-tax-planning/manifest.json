{
    "name": "small-biz-tax-planning",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["small business", "tax", "accounting", "CPA", "year-end", "planning", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Business Owner",
        "guest": "Accountant / CPA"
    },
    "inputs": [
        "shared_business_name",
        "shared_tax_year_or_planning_period",
        "owner_current_year_financials",
        "owner_major_transactions_planned",
        "owner_personal_financial_situation",
        "owner_what_they_are_worried_about",
        "owner_goals_for_the_plan",
        "accountant_current_year_tax_estimate",
        "accountant_strategies_available",
        "accountant_issues_flagged",
        "accountant_what_owner_has_not_considered",
        "accountant_year_end_deadlines"
    ],
    "outputs": [
        "tax_liability_projection",
        "action_list_with_deadlines",
        "retirement_and_savings_plan",
        "forward_planning_recommendations",
        "issues_to_resolve",
        "advisor_coordination_list"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The business owner and their accountant each submit the real financial picture and what they know is coming. Claude produces a year-end tax plan that reduces the bill, eliminates surprises, and puts the owner in control of their numbers before it is too late to act."
}
