{
  "name": "Wedding Vendor Couple Engagement",
  "slug": "wedding-vendor-couple",
  "description": "A wedding vendor and a couple each submit their real vision, budget, and expectations before signing — AI aligns on a services arrangement that delivers the wedding the couple actually wants within the budget they actually have.",
  "domain": "hospitality",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Couple",
    "guest": "Vendor"
  },
  "inputs": [
    { "name": "shared_couple_and_vendor", "type": "string", "required": true, "shared": true },
    { "name": "shared_event_details", "type": "string", "required": true, "shared": true },
    { "name": "vendor_service_offering", "type": "object", "required": true, "role": "guest" },
    { "name": "vendor_pricing_and_packages", "type": "object", "required": true, "role": "guest" },
    { "name": "vendor_availability_and_capacity", "type": "object", "required": true, "role": "guest" },
    { "name": "vendor_concerns_about_this_booking", "type": "array", "required": true, "role": "guest" },
    { "name": "vendor_what_they_will_not_do", "type": "array", "required": true, "role": "guest" },
    { "name": "couple_real_vision", "type": "object", "required": true, "role": "host" },
    { "name": "couple_true_budget", "type": "object", "required": true, "role": "host" },
    { "name": "couple_priorities_and_tradeoffs", "type": "object", "required": true, "role": "host" },
    { "name": "couple_concerns_about_vendors", "type": "array", "required": true, "role": "host" },
    { "name": "couple_what_they_will_not_compromise", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "service_scope_alignment", "type": "object" },
    { "name": "budget_and_pricing_transparency", "type": "object" },
    { "name": "vision_and_execution_alignment", "type": "object" },
    { "name": "timeline_and_logistics_plan", "type": "object" },
    { "name": "communication_and_revision_process", "type": "object" },
    { "name": "contract_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
