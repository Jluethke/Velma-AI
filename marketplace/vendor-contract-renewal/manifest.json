{
    "name": "vendor-contract-renewal",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["procurement", "vendor", "contract", "negotiation", "finance", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Business Owner (Vendor User)",
        "guest": "Procurement / Finance Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_vendor_name",
        "shared_renewal_date",
        "owner_vendor_satisfaction",
        "owner_what_they_need_from_vendor",
        "owner_must_haves_in_renewal",
        "owner_concerns_about_switching",
        "procurement_current_contract_terms",
        "procurement_leverage_points",
        "procurement_alternative_vendors",
        "procurement_cost_target",
        "procurement_terms_to_improve"
    ],
    "outputs": [
        "negotiation_leverage_assessment",
        "batna_analysis",
        "negotiation_strategy",
        "contract_redline_priorities",
        "cost_reduction_opportunity",
        "renewal_recommendation"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The business owner who uses the vendor and procurement each submit their real requirements and leverage before renewal. AI builds the negotiation strategy, identifies the BATNA, and produces a redline priority list both sides agree on."
}
