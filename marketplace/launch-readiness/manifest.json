{
    "name": "launch-readiness",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["product", "marketing", "launch", "operations", "readiness", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Product / Launch Owner",
        "guest": "Marketing / GTM Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_launch_name",
        "shared_target_launch_date",
        "product_feature_readiness",
        "product_known_gaps_at_launch",
        "product_what_is_not_ready",
        "product_launch_risks",
        "product_support_readiness",
        "marketing_campaign_readiness",
        "marketing_what_they_need_from_product",
        "marketing_assets_and_messaging_status",
        "marketing_concerns_about_product_readiness",
        "marketing_consequences_of_delay"
    ],
    "outputs": [
        "launch_readiness_assessment",
        "go_no_go_recommendation",
        "risk_acceptance_register",
        "launch_checklist",
        "contingency_plan",
        "post_launch_monitoring_plan"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Product and marketing each submit their real readiness status and risks before a launch decision. Claude produces a go/no-go assessment, names what is being accepted as a known risk, and builds the contingency plan before it is needed."
}
