    { "name": "manager_career_strategy", "type": "object", "required": true, "role": "guest" },
    { "name": "manager_commission_and_fees", "type": "object", "required": true, "role": "guest" },
    { "name": "manager_services_provided", "type": "object", "required": true, "role": "guest" },
    { "name": "manager_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
