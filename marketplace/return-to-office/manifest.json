{
    "name": "return-to-office",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["HR", "leadership", "policy", "remote", "workplace", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "HR Lead",
        "guest": "Executive / Business Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_current_policy",
        "hr_employee_sentiment_data",
        "hr_retention_risks",
        "hr_what_employees_want",
        "hr_benchmark_data",
        "hr_concerns_about_leadership_direction",
        "exec_what_business_needs",
        "exec_culture_concerns",
        "exec_non_negotiables",
        "exec_what_they_will_compromise_on",
        "exec_concerns_about_hr_read"
    ],
    "outputs": [
        "retention_risk_assessment",
        "business_need_analysis",
        "policy_options",
        "exception_framework",
        "implementation_plan",
        "communication_strategy"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "HR and leadership each submit their real employee data and business needs before designing RTO policy. AI models retention risk, designs policy options, and produces a plan that does not lose the people the company cannot afford to lose."
}
