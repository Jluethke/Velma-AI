{
    "name": "hiring-debrief",
    "version": "1.0.0",
    "domain": "career",
    "tags": ["hiring", "interview", "candidate", "recruiting", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Hiring Manager",
        "guest": "Candidate"
    },
    "inputs": [
        "shared_role",
        "shared_company",
        "shared_interview_stage",
        "manager_assessment",
        "manager_concerns",
        "manager_lean",
        "manager_what_would_close_it",
        "candidate_impression",
        "candidate_concerns",
        "candidate_interest_level",
        "candidate_what_they_need_to_say_yes"
    ],
    "outputs": [
        "mutual_interest_map",
        "manager_concern_vs_candidate_reality",
        "candidate_concerns_vs_role_reality",
        "close_gap",
        "next_step_recommendation",
        "offer_strategy"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Hiring manager and candidate each submit their honest read after an interview. AI maps the real mutual interest, surfaces the concerns neither side voiced in the room, and tells both sides what it would actually take to close."
}
