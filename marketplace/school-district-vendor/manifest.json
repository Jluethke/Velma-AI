{
  "name": "School District Vendor Agreement",
  "slug": "school-district-vendor",
  "description": "A school district and an educational vendor each submit their real requirements, budget constraints, and implementation expectations before signing — Claude aligns on an agreement that actually improves student outcomes rather than just purchasing software that sits unused in classrooms.",
  "domain": "education",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "School District",
    "guest": "Vendor"
  },
  "inputs": [
    { "name": "shared_district_and_vendor", "type": "string", "required": true, "shared": true },
    { "name": "shared_product_and_scope", "type": "string", "required": true, "shared": true },
    { "name": "vendor_product_and_evidence_base", "type": "object", "required": true, "role": "guest" },
    { "name": "vendor_pricing_and_contract_terms", "type": "object", "required": true, "role": "guest" },
    { "name": "vendor_implementation_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "vendor_concerns_about_this_district", "type": "array", "required": true, "role": "guest" },
    { "name": "vendor_what_makes_implementations_fail", "type": "array", "required": true, "role": "guest" },
    { "name": "district_educational_need", "type": "object", "required": true, "role": "host" },
    { "name": "district_budget_reality", "type": "object", "required": true, "role": "host" },
    { "name": "district_technical_and_capacity_constraints", "type": "object", "required": true, "role": "host" },
    { "name": "district_procurement_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "district_prior_vendor_problems", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "educational_fit_assessment", "type": "object" },
    { "name": "total_cost_of_ownership", "type": "object" },
    { "name": "implementation_readiness_assessment", "type": "object" },
    { "name": "contract_and_procurement_framework", "type": "object" },
    { "name": "pilot_and_evaluation_plan", "type": "object" },
    { "name": "implementation_and_training_plan", "type": "object" }
  ],
  "version": "1.0.0"
}
