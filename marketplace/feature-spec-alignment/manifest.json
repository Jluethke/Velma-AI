{
    "name": "feature-spec-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["product", "engineering", "spec", "feature", "requirements", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Product Manager",
        "guest": "Engineering Lead"
    },
    "inputs": [
        "shared_company_name",
        "shared_feature_name",
        "product_desired_outcome",
        "product_user_problem",
        "product_proposed_solution",
        "product_success_metrics",
        "product_timeline_requirements",
        "eng_technical_constraints",
        "eng_complexity_and_effort_estimate",
        "eng_architectural_concerns",
        "eng_what_is_not_possible_in_timeline",
        "eng_alternative_approaches"
    ],
    "outputs": [
        "requirements_feasibility_assessment",
        "scope_and_timeline_alignment",
        "technical_constraint_summary",
        "alternative_approaches",
        "agreed_spec_draft",
        "acceptance_criteria"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Product and engineering each submit their real requirements and technical constraints before a feature is specced. Claude aligns on what is buildable in the timeline, surfaces architectural concerns early, and produces a spec both sides have actually agreed to build."
}
