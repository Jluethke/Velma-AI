{
  "name": "Nonprofit Merger Alignment",
  "slug": "nonprofit-merger",
  "description": "Two nonprofit CEOs each submit their real concerns about organizational culture, mission alignment, and post-merger leadership before the integration begins — AI surfaces the tensions that kill nonprofit mergers and builds a structure where the combined organization serves the mission better than either could alone.",
  "domain": "nonprofit",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "CEO A",
    "guest": "CEO B"
  },
  "inputs": [
    { "name": "shared_organizations", "type": "string", "required": true, "shared": true },
    { "name": "shared_merger_rationale", "type": "string", "required": true, "shared": true },
    { "name": "org_a_mission_and_identity", "type": "object", "required": true, "role": "host" },
    { "name": "org_a_financial_and_operational_reality", "type": "object", "required": true, "role": "host" },
    { "name": "org_a_leadership_expectations", "type": "object", "required": true, "role": "host" },
    { "name": "org_a_cultural_concerns", "type": "array", "required": true, "role": "host" },
    { "name": "org_a_deal_breakers", "type": "array", "required": true, "role": "host" },
    { "name": "org_b_mission_and_identity", "type": "object", "required": true, "role": "guest" },
    { "name": "org_b_financial_and_operational_reality", "type": "object", "required": true, "role": "guest" },
    { "name": "org_b_leadership_expectations", "type": "object", "required": true, "role": "guest" },
    { "name": "org_b_cultural_concerns", "type": "array", "required": true, "role": "guest" },
    { "name": "org_b_deal_breakers", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "mission_alignment_assessment", "type": "object" },
    { "name": "financial_and_operational_picture", "type": "object" },
    { "name": "leadership_structure_framework", "type": "object" },
    { "name": "program_and_culture_integration_plan", "type": "object" },
    { "name": "stakeholder_and_donor_transition_plan", "type": "object" },
    { "name": "merger_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
