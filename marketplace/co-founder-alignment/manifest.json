{
    "name": "co-founder-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["co-founder", "startup", "equity", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Co-founder A",
        "guest": "Co-founder B"
    },
    "inputs": [
        "shared_company_name",
        "shared_stage",
        "shared_idea_description",
        "vision",
        "equity_expectations",
        "role_definition",
        "working_style",
        "dealbreakers",
        "commitment_level"
    ],
    "outputs": [
        "alignment_map",
        "gap_analysis",
        "equity_recommendation",
        "role_boundaries",
        "working_agreement_draft",
        "red_flags"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Two co-founders each answer privately about vision, equity, roles, and working style. AI finds where you're aligned, where you'll clash, and drafts a working agreement. Most startup breakups are preventable. This is how you prevent them."
}
