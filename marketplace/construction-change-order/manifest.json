{
    "name": "construction-change-order",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["construction", "change-order", "GC", "owner", "contract", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "General Contractor",
        "guest": "Owner / Owner's Rep"
    },
    "inputs": [
        "shared_project_name",
        "shared_change_description",
        "gc_scope_change_justification",
        "gc_cost_breakdown",
        "gc_time_impact",
        "gc_why_it_is_a_legitimate_change",
        "gc_documentation",
        "owner_whether_they_agree_it_is_a_change",
        "owner_budget_position",
        "owner_schedule_tolerance",
        "owner_what_they_will_approve",
        "owner_concerns_about_gc_pricing"
    ],
    "outputs": [
        "change_legitimacy_assessment",
        "cost_reasonableness_review",
        "schedule_impact_analysis",
        "negotiated_change_order_terms",
        "documentation_requirements",
        "dispute_risk_assessment"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "GC and owner each submit their real position on a change order before negotiation. AI assesses legitimacy, reviews pricing, and produces negotiated change order terms that resolve the dispute before it becomes a claim."
}
