{
  "name": "Interior Designer Client Engagement",
  "slug": "interior-designer-client",
  "description": "An interior designer and a client each submit their real aesthetic vision, budget, and lifestyle requirements before the design begins — Claude aligns on a design engagement that produces a space the client loves without the scope creep and budget overruns that define most interior design projects.",
  "domain": "professional-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Designer"
  },
  "inputs": [
    { "name": "shared_designer_and_client", "type": "string", "required": true, "shared": true },
    { "name": "shared_project_scope", "type": "string", "required": true, "shared": true },
    { "name": "designer_creative_approach", "type": "object", "required": true, "role": "guest" },
    { "name": "designer_fees_and_scope", "type": "object", "required": true, "role": "guest" },
    { "name": "designer_project_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "designer_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
    { "name": "designer_what_they_will_not_do", "type": "array", "required": true, "role": "guest" },
    { "name": "client_aesthetic_vision", "type": "object", "required": true, "role": "host" },
    { "name": "client_true_budget", "type": "object", "required": true, "role": "host" },
    { "name": "client_lifestyle_and_functional_needs", "type": "object", "required": true, "role": "host" },
    { "name": "client_decision_process", "type": "object", "required": true, "role": "host" },
    { "name": "client_past_design_experiences", "type": "array", "required": true, "role": "host" }
