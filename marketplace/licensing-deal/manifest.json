{
    "name": "licensing-deal",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["licensing", "IP", "royalties", "deal", "creative", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "IP Owner / Licensor",
        "guest": "Licensee"
    },
    "inputs": [
        "shared_ip_description",
        "shared_intended_use",
        "licensor_valuation",
        "licensor_usage_restrictions",
        "licensor_royalty_expectations",
        "licensor_concerns_about_licensee",
        "licensor_non_negotiables",
        "licensee_use_case",
        "licensee_revenue_projections",
        "licensee_royalty_capacity",
        "licensee_exclusivity_needs",
        "licensee_concerns_about_deal"
    ],
    "outputs": [
        "deal_feasibility",
        "royalty_structure_options",
        "usage_alignment",
        "exclusivity_assessment",
        "license_agreement_draft",
        "negotiation_agenda"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "IP owner and licensee each submit their real expectations about royalties, usage, and exclusivity. Claude assesses deal feasibility, produces royalty structure options, and drafts opening license agreement language."
}
