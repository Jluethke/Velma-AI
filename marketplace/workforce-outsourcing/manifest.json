{
  "name": "Workforce Outsourcing Engagement",
  "slug": "workforce-outsourcing",
  "description": "An HR leader and a workforce solutions provider each submit their real staffing requirements, service expectations, and cost constraints before signing — AI aligns on an outsourcing arrangement that fills critical workforce needs without creating misclassification risk or service quality failures.",
  "domain": "professional-services",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "HR Leader",
    "guest": "Workforce Provider"
  },
  "inputs": [
    { "name": "shared_company_and_provider", "type": "string", "required": true, "shared": true },
    { "name": "shared_workforce_scope", "type": "string", "required": true, "shared": true },
    { "name": "hr_workforce_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "hr_cost_and_budget_constraints", "type": "object", "required": true, "role": "host" },
    { "name": "hr_quality_and_compliance_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "hr_current_workforce_problems", "type": "array", "required": true, "role": "host" },
    { "name": "hr_concerns_about_this_provider", "type": "array", "required": true, "role": "host" },
    { "name": "provider_capabilities_and_capacity", "type": "object", "required": true, "role": "guest" },
    { "name": "provider_pricing_and_margin", "type": "object", "required": true, "role": "guest" },
    { "name": "provider_compliance_posture", "type": "object", "required": true, "role": "guest" },
    { "name": "provider_concerns_about_this_client", "type": "object", "required": true, "role": "guest" },
    { "name": "provider_what_they_will_not_do", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "workforce_program_design", "type": "object" },
    { "name": "pricing_and_economics", "type": "object" },
    { "name": "compliance_and_classification_framework", "type": "object" },
    { "name": "service_level_standards", "type": "object" },
    { "name": "governance_and_transition_plan", "type": "object" },
    { "name": "services_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
