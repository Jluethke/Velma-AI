{
    "name": "public-private-partnership",
    "version": "1.0.0",
    "domain": "government",
    "tags": ["government", "P3", "public-private", "infrastructure", "concession", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Government Entity",
        "guest": "Private Partner"
    },
    "inputs": [
        "shared_project_name",
        "shared_asset_or_service",
        "government_public_objectives",
        "government_fiscal_constraints",
        "government_risk_tolerance",
        "government_regulatory_and_political_constraints",
        "government_concerns_about_the_partner",
        "partner_return_requirements",
        "partner_risk_appetite",
        "partner_financing_plan",
        "partner_concerns_about_government_partner",
        "partner_what_they_need_to_commit"
    ],
    "outputs": [
        "public_value_and_commercial_viability_alignment",
        "risk_allocation_framework",
        "financial_structure",
        "performance_and_service_standards",
        "governance_framework",
        "partnership_agreement_framework"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The government entity and the private partner each submit their real objectives, risk tolerances, and financial expectations before the partnership is structured. Claude designs the P3 framework that delivers public value, gives the private partner a viable return, and allocates risk to the party best able to manage it."
}
