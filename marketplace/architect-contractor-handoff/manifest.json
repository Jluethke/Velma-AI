{
  "name": "Architect Contractor Handoff",
  "slug": "architect-contractor-handoff",
  "description": "An architect and a general contractor each submit their real concerns about the construction documents, scope interpretation, and schedule before the project breaks ground — AI aligns on a shared understanding of the drawings that prevents the RFIs, change orders, and disputes that inflate every project budget.",
  "domain": "construction",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Architect",
    "guest": "General Contractor"
  },
  "inputs": [
    { "name": "shared_project_and_team", "type": "string", "required": true, "shared": true },
    { "name": "shared_project_scope", "type": "string", "required": true, "shared": true },
    { "name": "architect_design_intent", "type": "object", "required": true, "role": "host" },
    { "name": "architect_known_drawing_issues", "type": "object", "required": true, "role": "host" },
    { "name": "architect_scope_interpretation_concerns", "type": "object", "required": true, "role": "host" },
    { "name": "architect_concerns_about_this_contractor", "type": "array", "required": true, "role": "host" },
    { "name": "architect_what_they_will_not_approve", "type": "array", "required": true, "role": "host" },
    { "name": "contractor_constructability_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "contractor_scope_clarifications_needed", "type": "object", "required": true, "role": "guest" },
    { "name": "contractor_schedule_and_sequencing_concerns", "type": "object", "required": true, "role": "guest" },
    { "name": "contractor_concerns_about_this_design_team", "type": "array", "required": true, "role": "guest" },
    { "name": "contractor_what_they_will_flag_as_change_orders", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "drawing_interpretation_alignment", "type": "object" },
    { "name": "constructability_resolution_plan", "type": "object" },
    { "name": "scope_boundary_definition", "type": "object" },
    { "name": "afi_and_rfi_process", "type": "object" },
    { "name": "schedule_and_submittal_plan", "type": "object" },
    { "name": "coordination_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
