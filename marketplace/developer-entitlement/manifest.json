{
  "name": "Developer Entitlement Alignment",
  "slug": "developer-entitlement",
  "description": "A real estate developer and a planning department each submit their real project requirements, community concerns, and approval standards before the entitlement process begins — Claude identifies what needs to be resolved for approval and what the project must commit to for the community to support it.",
  "domain": "real-estate",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Developer",
    "guest": "Planning Department"
  },
  "inputs": [
    { "name": "shared_project_and_jurisdiction", "type": "string", "required": true, "shared": true },
    { "name": "shared_project_description", "type": "string", "required": true, "shared": true },
    { "name": "developer_project_design", "type": "object", "required": true, "role": "host" },
    { "name": "developer_financial_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "developer_entitlement_strategy", "type": "object", "required": true, "role": "host" },
    { "name": "developer_community_concerns_assessment", "type": "object", "required": true, "role": "host" },
    { "name": "developer_deal_breakers", "type": "array", "required": true, "role": "host" },
    { "name": "planning_approval_standards", "type": "object", "required": true, "role": "guest" },
    { "name": "community_concerns_and_priorities", "type": "object", "required": true, "role": "guest" },
    { "name": "planning_department_position", "type": "object", "required": true, "role": "guest" },
    { "name": "political_and_policy_context", "type": "object", "required": true, "role": "guest" },
    { "name": "planning_what_they_need_from_developer", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "approval_path_assessment", "type": "object" },
    { "name": "project_modification_framework", "type": "object" },
    { "name": "community_benefit_structure", "type": "object" },
    { "name": "environmental_and_infrastructure_requirements", "type": "object" },
    { "name": "entitlement_timeline", "type": "object" },
    { "name": "development_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
