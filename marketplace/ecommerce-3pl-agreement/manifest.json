{
  "name": "E-Commerce 3PL Agreement",
  "slug": "ecommerce-3pl-agreement",
  "description": "An e-commerce brand and a third-party logistics provider each submit their real volume projections, service requirements, and cost expectations before signing — Claude aligns on a fulfillment partnership that ships orders on time without the hidden fees that destroy unit economics.",
  "domain": "logistics",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Brand",
    "guest": "3PL"
  },
  "inputs": [
    { "name": "shared_brand_and_3pl", "type": "string", "required": true, "shared": true },
    { "name": "shared_product_category", "type": "string", "required": true, "shared": true },
    { "name": "brand_volume_and_growth", "type": "object", "required": true, "role": "host" },
    { "name": "brand_service_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "brand_cost_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "brand_current_fulfillment_problems", "type": "array", "required": true, "role": "host" },
    { "name": "brand_concerns_about_this_3pl", "type": "array", "required": true, "role": "host" },
    { "name": "3pl_capabilities_and_capacity", "type": "object", "required": true, "role": "guest" },
    { "name": "3pl_pricing_structure", "type": "object", "required": true, "role": "guest" },
    { "name": "3pl_onboarding_and_integration", "type": "object", "required": true, "role": "guest" },
    { "name": "3pl_concerns_about_this_brand", "type": "object", "required": true, "role": "guest" },
    { "name": "3pl_what_they_will_not_do", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "fulfillment_service_agreement", "type": "object" },
    { "name": "pricing_and_cost_model", "type": "object" },
    { "name": "unit_economics_analysis", "type": "object" },
    { "name": "onboarding_and_integration_plan", "type": "object" },
    { "name": "performance_standards", "type": "object" },
    { "name": "agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
