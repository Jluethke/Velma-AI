{
    "name": "process-design",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["process", "operations", "cross-functional", "workflow", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Team Lead A",
        "guest": "Team Lead B"
    },
    "inputs": [
        "shared_process_name",
        "shared_current_problem",
        "team_a_current_workflow",
        "team_a_pain_points",
        "team_a_non_negotiables",
        "team_a_concerns_about_team_b",
        "team_a_what_they_need_to_change",
        "team_b_current_workflow",
        "team_b_pain_points",
        "team_b_non_negotiables",
        "team_b_concerns_about_team_a",
        "team_b_what_they_need_to_change"
    ],
    "outputs": [
        "pain_point_alignment",
        "workflow_conflicts",
        "redesigned_process_draft",
        "handoff_definition",
        "success_metrics",
        "change_management_plan"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Two team leads each submit their real workflow pain points, non-negotiables, and concerns about the other team before redesigning a shared process. Claude maps the conflicts, drafts the redesigned process, and defines the handoffs — so the new process doesn't just recreate the old problems."
}
