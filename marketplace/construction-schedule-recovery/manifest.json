{
    "name": "construction-schedule-recovery",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["construction", "schedule", "recovery", "GC", "owner", "delay", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "General Contractor",
        "guest": "Owner / Owner's Rep"
    },
    "inputs": [
        "shared_project_name",
        "shared_delay_amount",
        "gc_why_schedule_slipped",
        "gc_recovery_plan",
        "gc_cost_to_accelerate",
        "gc_what_owner_must_decide",
        "gc_what_is_not_recoverable",
        "owner_timeline_requirements",
        "owner_budget_for_recovery",
        "owner_risk_tolerance",
        "owner_what_they_need_from_gc",
        "owner_concerns_about_gc_recovery_plan"
    ],
    "outputs": [
        "delay_cause_analysis",
        "recovery_plan_feasibility",
        "cost_to_complete_scenarios",
        "owner_decision_requirements",
        "revised_schedule",
        "risk_and_contingency_plan"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "GC and owner each submit their real account of the delay and recovery options before deciding how to proceed. Claude assesses root cause, models recovery scenarios, and produces a revised schedule with the decisions each side needs to make."
}
