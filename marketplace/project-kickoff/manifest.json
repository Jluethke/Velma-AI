{
    "name": "project-kickoff",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["project", "kickoff", "PM", "stakeholder", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Project Manager",
        "guest": "Key Stakeholder"
    },
    "inputs": [
        "shared_project_name",
        "shared_start_date",
        "pm_scope_understanding",
        "pm_capacity_and_constraints",
        "pm_risks",
        "pm_what_they_need_from_stakeholder",
        "pm_concerns_about_the_engagement",
        "stakeholder_success_definition",
        "stakeholder_priorities",
        "stakeholder_concerns",
        "stakeholder_availability_reality",
        "stakeholder_what_will_cause_them_to_escalate"
    ],
    "outputs": [
        "scope_alignment",
        "success_criteria",
        "risk_register",
        "stakeholder_engagement_plan",
        "project_charter_draft",
        "escalation_triggers"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Project manager and key stakeholder each submit their real scope understanding, priorities, and concerns before kickoff. AI produces a project charter both sides have actually agreed to — not a document the PM wrote and the stakeholder signed without reading."
}
