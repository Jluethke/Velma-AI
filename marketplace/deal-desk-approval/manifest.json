{
    "name": "deal-desk-approval",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["sales", "finance", "deal-desk", "discount", "approval", "revenue", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Account Executive / Sales Lead",
        "guest": "Finance / Deal Desk"
    },
    "inputs": [
        "shared_company_name",
        "shared_deal_name",
        "sales_deal_context",
        "sales_discount_requested",
        "sales_competitive_pressure",
        "sales_relationship_and_strategic_value",
        "sales_what_happens_if_not_approved",
        "finance_standard_pricing_policy",
        "finance_margin_floor",
        "finance_precedent_concerns",
        "finance_what_they_need_to_approve",
        "finance_flexibility_available"
    ],
    "outputs": [
        "margin_impact_analysis",
        "precedent_risk_assessment",
        "approval_recommendation",
        "conditional_approval_terms",
        "alternative_deal_structures",
        "decision_rationale"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Sales and finance each submit their real deal context and approval constraints before a discount decision. AI models the margin impact, assesses precedent risk, and produces an approval recommendation with the conditions both sides can live with."
}
