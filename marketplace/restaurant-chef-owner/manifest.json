{
    "name": "restaurant-chef-owner",
    "version": "1.0.0",
    "domain": "hospitality",
    "tags": ["restaurant", "hospitality", "chef", "owner", "menu", "food cost", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Chef",
        "guest": "Owner"
    },
    "inputs": [
        "shared_restaurant_name",
        "shared_concept",
        "chef_culinary_vision",
        "chef_menu_requirements",
        "chef_concerns_about_financial_constraints",
        "chef_what_they_need_to_do_their_job",
        "chef_what_is_non_negotiable",
        "owner_financial_targets",
        "owner_customer_expectations",
        "owner_concerns_about_the_menu",
        "owner_what_they_need_from_the_chef",
        "owner_constraints"
    ],
    "outputs": [
        "menu_viability_assessment",
        "food_cost_analysis",
        "menu_design_framework",
        "non_negotiable_alignment",
        "operating_model_agreement",
        "conflict_resolution_process"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The chef and the owner each submit their real vision for the restaurant, financial constraints, and concerns. AI finds where culinary ambition and business reality can coexist, and produces a menu and operating model both sides can commit to."
