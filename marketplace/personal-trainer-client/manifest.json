{
  "name": "Personal Trainer Client Engagement",
  "slug": "personal-trainer-client",
  "description": "A personal trainer and a client each submit their real fitness goals, physical history, and expectations before the engagement begins — AI aligns on a training program that achieves the client's goals without the misaligned expectations that end most trainer relationships by month three.",
  "domain": "health",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Client",
    "guest": "Trainer"
  },
  "inputs": [
    { "name": "shared_trainer_and_client", "type": "string", "required": true, "shared": true },
    { "name": "shared_training_context", "type": "string", "required": true, "shared": true },
    { "name": "trainer_initial_assessment", "type": "object", "required": true, "role": "guest" },
    { "name": "trainer_program_approach", "type": "object", "required": true, "role": "guest" },
    { "name": "trainer_fees_and_policies", "type": "object", "required": true, "role": "guest" },
    { "name": "trainer_concerns_about_this_client", "type": "array", "required": true, "role": "guest" },
    { "name": "trainer_what_they_will_not_do", "type": "array", "required": true, "role": "guest" },
    { "name": "client_real_goals", "type": "object", "required": true, "role": "host" },
    { "name": "client_physical_history", "type": "object", "required": true, "role": "host" },
    { "name": "client_lifestyle_and_compliance", "type": "object", "required": true, "role": "host" },
    { "name": "client_concerns_about_training", "type": "array", "required": true, "role": "host" },
    { "name": "client_what_they_will_not_do", "type": "array", "required": true, "role": "host" }
  ],
  "outputs": [
    { "name": "training_program_design", "type": "object" },
    { "name": "goal_timeline_and_milestones", "type": "object" },
    { "name": "safety_and_injury_considerations", "type": "object" },
    { "name": "engagement_terms", "type": "object" },
    { "name": "nutrition_and_lifestyle_alignment", "type": "object" },
    { "name": "progress_measurement_plan", "type": "object" }
  ],
  "version": "1.0.0"
}
