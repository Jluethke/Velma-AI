{
  "name": "Property Management Contract",
  "slug": "property-management-contract",
  "description": "The property owner and the property manager each submit their real expectations, management philosophy, and financial requirements — Claude aligns on a management agreement that gives the owner appropriate oversight and the manager the authority to operate the property without a phone call for every decision.",
  "domain": "real-estate",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Property Owner",
    "guest": "Property Manager"
  },
  "inputs": [
    { "name": "shared_property_description", "type": "string", "required": true, "shared": true },
    { "name": "shared_owner_and_manager", "type": "string", "required": true, "shared": true },
    { "name": "owner_financial_expectations", "type": "object", "required": true, "role": "host" },
    { "name": "owner_oversight_requirements", "type": "object", "required": true, "role": "host" },
    { "name": "owner_past_management_problems", "type": "array", "required": true, "role": "host" },
    { "name": "owner_concerns_about_this_manager", "type": "array", "required": true, "role": "host" },
    { "name": "owner_what_they_will_not_tolerate", "type": "array", "required": true, "role": "host" },
    { "name": "manager_management_approach", "type": "object", "required": true, "role": "guest" },
    { "name": "manager_fee_structure", "type": "object", "required": true, "role": "guest" },
    { "name": "manager_authority_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "manager_concerns_about_the_owner", "type": "array", "required": true, "role": "guest" },
    { "name": "manager_reporting_and_communication", "type": "object", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "management_scope_and_authority", "type": "object" },
    { "name": "fee_structure_and_economics", "type": "object" },
    { "name": "performance_standards", "type": "object" },
    { "name": "communication_and_reporting_plan", "type": "object" },
    { "name": "management_agreement_framework", "type": "object" },
    { "name": "owner_obligations", "type": "object" }
  ],
  "version": "1.0.0"
}
