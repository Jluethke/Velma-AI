{
    "name": "strategy-offsite-prep",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["strategy", "offsite", "leadership", "planning", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "CEO / Facilitator",
        "guest": "Leadership Team Member"
    },
    "inputs": [
        "shared_company_name",
        "shared_offsite_topic",
        "facilitator_objectives",
        "facilitator_concerns_about_team_dynamics",
        "facilitator_topics_to_avoid",
        "facilitator_what_must_be_decided",
        "member_real_priorities",
        "member_concerns_they_wont_raise",
        "member_what_they_want_from_the_offsite",
        "member_what_they_think_is_being_avoided",
        "member_what_would_make_it_worthwhile"
    ],
    "outputs": [
        "priority_alignment",
        "avoided_topics_map",
        "offsite_agenda",
        "pre_read_requirements",
        "decision_log_template",
        "psychological_safety_assessment"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "CEO and each leadership team member each submit what they really want from the offsite and what they think is being avoided. AI builds an agenda that addresses the real issues — not the comfortable ones — and surfaces the psychological safety gaps before the room fills up."
}
