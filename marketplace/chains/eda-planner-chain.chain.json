{
  "name": "eda-planner-chain",
  "description": "Converts a CSV dataset description into a comprehensive exploratory data analysis plan with distribution checks, correlation tests, missing value strategies, outlier detection, visualizations, feature engineering opportunities, and hypothesis generation.",
  "steps": [
    {
      "id": "step_1_intake",
      "skill_name": "Chain Designer",
      "description": "Parse the workflow goal and inventory available skills",
      "inputs": {
        "goal": "Take a CSV dataset description and generate a complete exploratory data analysis plan: distributions to check, correlations to test, outlier detection methods, and visualization recommendations.",
        "available_skills": [
          {
            "name": "Dataset Profiler",
            "inputs": [
              "dataset_description",
              "domain_context"
            ],
            "outputs": [
              "dataset_profile"
            ],
            "description": "Analyzes dataset structure, column types, cardinality, and data quality flags"
          },
          {
            "name": "Missing Value Analyzer",
            "inputs": [
              "dataset_profile",
              "known_constraints"
            ],
            "outputs": [
              "missing_value_plan"
            ],
            "description": "Identifies missingness patterns (MCAR/MAR/MNAR) and recommends handling strategies"
          },
          {
            "name": "Distribution Planner",
            "inputs": [
              "dataset_profile",
              "missing_value_plan"
            ],
            "outputs": [
              "distribution_plan"
            ],
            "description": "Recommends distribution analysis methods for each column with specific insights"
          },
          {
            "name": "Correlation Analyzer",
            "inputs": [
              "dataset_profile",
              "distribution_plan"
            ],
            "outputs": [
              "correlation_plan"
            ],
            "description": "Designs correlation tests and relationship analyses with appropriate statistical methods"
          },
          {
            "name": "Outlier Detection Designer",
            "inputs": [
              "dataset_profile",
              "distribution_plan"
            ],
            "outputs": [
              "outlier_detection_plan"
            ],
            "description": "Specifies outlier detection methods, thresholds, and actions per column"
          },
          {
            "name": "Visualization Recommender",
            "inputs": [
              "distribution_plan",
              "correlation_plan",
              "outlier_detection_plan"
            ],
            "outputs": [
              "visualization_recommendations"
            ],
            "description": "Prioritizes visualizations by insight value and effort estimate"
          },
          {
            "name": "Feature Engineering Scout",
            "inputs": [
              "dataset_profile",
              "distribution_plan",
              "correlation_plan",
              "analysis_scope"
            ],
            "outputs": [
              "feature_engineering_opportunities"
            ],
            "description": "Identifies derived features, transformations, and interactions with rationale"
          },
          {
            "name": "Hypothesis Generator",
            "inputs": [
              "correlation_plan",
              "feature_engineering_opportunities",
              "domain_context"
            ],
            "outputs": [
              "hypothesis_generation"
            ],
            "description": "Formulates 3-5 testable hypotheses with confirmation tests"
          },
          {
            "name": "EDA Execution Planner",
            "inputs": [
              "dataset_profile",
              "missing_value_plan",
              "distribution_plan",
              "correlation_plan",
              "outlier_detection_plan",
              "visualization_recommendations",
              "feature_engineering_opportunities",
              "hypothesis_generation"
            ],
            "outputs": [
              "eda_execution_plan"
            ],
            "description": "Sequences all analyses with effort estimates, sample size considerations, and checkpoints"
          }
        ]
      },
      "outputs": {
        "requirements_list": "9 discrete requirements identified",
        "skill_capability_map": "9 skills mapped to requirements",
        "data_type_inventory": "dataset_profile, missing_value_plan, distribution_plan, correlation_plan, outlier_detection_plan, visualization_recommendations, feature_engineering_opportunities, hypothesis_generation, eda_execution_plan"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2_profile",
      "skill_name": "Dataset Profiler",
      "description": "Extract column names, types, cardinality, and data quality flags from dataset description",
      "inputs": {
        "dataset_description": "CSV dataset description with column names, types, row count, and domain context",
        "domain_context": "Business or scientific domain for tailoring analysis"
      },
      "outputs": {
        "dataset_profile": "Structured inventory of columns with types, cardinality, preliminary observations, and data quality flags"
      },
      "parallel_group": 2
    },
    {
      "id": "step_3_missing_values",
      "skill_name": "Missing Value Analyzer",
      "description": "Classify missingness patterns and recommend handling strategies",
      "inputs": {
        "dataset_profile": "From step_2_profile",
        "known_constraints": "Data quality issues, missing value patterns, measurement limitations"
      },
      "outputs": {
        "missing_value_plan": "Array of missing value analyses with patterns (MCAR/MAR/MNAR), percentages, and handling strategies"
      },
      "parallel_group": 3
    },
    {
      "id": "step_4_distributions",
      "skill_name": "Distribution Planner",
      "description": "Recommend distribution analysis methods with specific insights for each column",
      "inputs": {
        "dataset_profile": "From step_2_profile",
        "missing_value_plan": "From step_3_missing_values"
      },
      "outputs": {
        "distribution_plan": "Array of distribution analyses with methods (histogram, KDE, Q-Q plot, etc.) and specific insights"
      },
      "parallel_group": 4
    },
    {
      "id": "step_5_correlations",
      "skill_name": "Correlation Analyzer",
      "description": "Design correlation tests and relationship analyses with appropriate statistical methods",
      "inputs": {
        "dataset_profile": "From step_2_profile",
        "distribution_plan": "From step_4_distributions"
      },
      "outputs": {
        "correlation_plan": "Array of correlation tests with variable pairs, statistical tests, and interpretation guidance"
      },
      "parallel_group": 4
    },
    {
      "id": "step_6_outliers",
      "skill_name": "Outlier Detection Designer",
      "description": "Specify outlier detection methods, thresholds, and actions per column",
      "inputs": {
        "dataset_profile": "From step_2_profile",
        "distribution_plan": "From step_4_distributions"
      },
      "outputs": {
        "outlier_detection_plan": "Array of outlier detection strategies with methods (IQR, Z-score, isolation forest), thresholds, and actions"
      },
      "parallel_group": 4
    },
    {
      "id": "step_7_visualizations",
      "skill_name": "Visualization Recommender",
      "description": "Prioritize visualizations by insight value and effort estimate",
      "inputs": {
        "distribution_plan": "From step_4_distributions",
        "correlation_plan": "From step_5_correlations",
        "outlier_detection_plan": "From step_6_outliers"
      },
      "outputs": {
        "visualization_recommendations": "Prioritized list of visualizations with chart type, variables, expected insight, and effort estimate"
      },
      "parallel_group": 5
    },
    {
      "id": "step_8_feature_engineering",
      "skill_name": "Feature Engineering Scout",
      "description": "Identify derived features, transformations, and interactions with rationale",
      "inputs": {
        "dataset_profile": "From step_2_profile",
        "distribution_plan": "From step_4_distributions",
        "correlation_plan": "From step_5_correlations",
        "analysis_scope": "quick, standard, or deep"
      },
      "outputs": {
        "feature_engineering_opportunities": "Array of derived features, transformations, and interactions with rationale and complexity estimates"
      },
      "parallel_group": 5
    },
    {
      "id": "step_9_hypotheses",
      "skill_name": "Hypothesis Generator",
      "description": "Formulate 3-5 testable hypotheses with confirmation tests",
      "inputs": {
        "correlation_plan": "From step_5_correlations",
        "feature_engineering_opportunities": "From step_8_feature_engineering",
        "domain_context": "Business or scientific domain for hypothesis prioritization"
      },
      "outputs": {
        "hypothesis_generation": "Array of 3-5 testable hypotheses with variables, expected direction/magnitude, and confirmation tests"
      },
      "parallel_group": 6
    },
    {
      "id": "step_10_execution_plan",
      "skill_name": "EDA Execution Planner",
      "description": "Sequence all analyses with effort estimates, sample size considerations, and checkpoints",
      "inputs": {
        "dataset_profile": "From step_2_profile",
        "missing_value_plan": "From step_3_missing_values",
        "distribution_plan": "From step_4_distributions",
        "correlation_plan": "From step_5_correlations",
        "outlier_detection_plan": "From step_6_outliers",
        "visualization_recommendations": "From step_7_visualizations",
        "feature_engineering_opportunities": "From step_8_feature_engineering",
        "hypothesis_generation": "From step_9_hypotheses"
      },
      "outputs": {
        "eda_execution_plan": "Narrative summary of complete EDA workflow with sequenced steps, effort estimates, sample size considerations, and checkpoints"
      },
      "parallel_group": 7
    }
  ],
