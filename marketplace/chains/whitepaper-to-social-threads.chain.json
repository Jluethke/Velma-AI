{
  "name": "whitepaper-to-social-threads",
  "description": "Convert a technical whitepaper into a series of engaging social media threads, each covering one key insight with hooks, supporting evidence, and calls to action.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 1: Analyze Whitepaper and Extract Key Insights",
      "inputs": {
        "whitepaper_content": "from_context.whitepaper_content",
        "target_audience": "from_context.target_audience",
        "num_threads": "from_context.num_threads",
        "campaign_goal": "from_context.campaign_goal"
      },
      "outputs": {
        "extracted_insights": "array of insights with title, core claim, supporting evidence, relevance_score, actionability_score"
      },
      "parallel_group": 1,
      "description": "Analyze whitepaper end-to-end, extract candidate insights, rank by relevance and actionability, select top N insights"
    },
    {
      "id": "step_2",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 2: Design Thread Structure for Each Insight",
      "inputs": {
        "extracted_insights": "from_step_1.extracted_insights",
        "platform": "from_context.platform",
        "tone": "from_context.tone",
        "campaign_goal": "from_context.campaign_goal"
      },
      "outputs": {
        "thread_outlines": "array of thread outlines with arc structure, engagement hooks, tone notes, visual recommendations"
      },
      "parallel_group": 2,
      "description": "Design thread structure, arc, engagement hooks, and tone adaptations for each insight"
    },
    {
      "id": "step_3",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 3: Write Hook Tweets",
      "inputs": {
        "thread_outlines": "from_step_2.thread_outlines",
        "extracted_insights": "from_step_1.extracted_insights",
        "platform": "from_context.platform"
      },
      "outputs": {
        "hook_tweets": "array of hook tweets, one per thread, with thread indicator and engagement hook"
      },
      "parallel_group": 3,
      "description": "Write hook tweets that create curiosity and engagement, test for clarity"
    },
    {
      "id": "step_4",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 4: Write Body Tweets",
      "inputs": {
        "thread_outlines": "from_step_2.thread_outlines",
        "extracted_insights": "from_step_1.extracted_insights",
        "hook_tweets": "from_step_3.hook_tweets",
        "platform": "from_context.platform"
      },
      "outputs": {
        "body_tweets": "array of thread objects with body_tweets arrays (3-7 tweets per thread)"
      },
      "parallel_group": 4,
      "description": "Write body tweets developing each insight with context, evidence, and implication"
    },
    {
      "id": "step_5",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 5: Write Call-to-Action Tweets",
      "inputs": {
        "body_tweets": "from_step_4.body_tweets",
        "campaign_goal": "from_context.campaign_goal",
        "include_cta": "from_context.include_cta"
      },
      "outputs": {
        "cta_tweets": "array of CTA tweets, one per thread, or null if include_cta is false"
      },
      "parallel_group": 5,
      "description": "Write CTA tweets aligned with campaign goal (awareness, lead generation, community building, thought leadership)"
    },
    {
      "id": "step_6",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 6: Add Hashtags and Formatting",
      "inputs": {
        "cta_tweets": "from_step_5.cta_tweets",
        "body_tweets": "from_step_4.body_tweets",
        "hook_tweets": "from_step_3.hook_tweets",
        "platform": "from_context.platform",
        "extracted_insights": "from_step_1.extracted_insights"
      },
      "outputs": {
        "formatted_threads": "array of complete threads with hashtags, emoji accents, and thread numbering"
      },
      "parallel_group": 6,
      "description": "Add hashtags (2-4 per thread, 50K-500K posts), emoji accents, and thread numbering (1/N format)"
    },
    {
      "id": "step_7",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 7: Review for Accuracy, Tone, and Engagement",
      "inputs": {
        "formatted_threads": "from_step_6.formatted_threads",
        "whitepaper_content": "from_context.whitepaper_content",
        "tone": "from_context.tone",
        "extracted_insights": "from_step_1.extracted_insights"
      },
      "outputs": {
        "quality_report": "object with accuracy_check, tone_consistency, engagement_potential, revision_notes, approval_status"
      },
      "parallel_group": 7,
      "description": "Verify accuracy against whitepaper, assess tone consistency, evaluate engagement potential using rubric (hook/body/cta), identify revisions"
    },
    {
      "id": "step_8",
      "skill_name": "whitepaper-to-social-threads",
      "phase": "PHASE 8: Compile Publishing Package",
      "inputs": {
        "formatted_threads": "from_step_6.formatted_threads",
        "quality_report": "from_step_7.quality_report",
        "num_threads": "from_context.num_threads",
        "platform": "from_context.platform",
        "include_visual_recommendations": "from_context.include_visual_recommendations",
        "thread_outlines": "from_step_2.thread_outlines"
      },
      "outputs": {
        "threads": "array of complete thread objects with all fields",
        "publishing_schedule": "object with cadence, platform notes, and checklist",
        "visual_asset_recommendations": "array of visual assets if include_visual_recommendations is true"
      },
      "parallel_group": 8,
      "description": "Organize publishing package with thread list, complete text, hashtags, visual assets, cadence, and pre-publishing checklist"
    }
  ],
  "edges": [
    {
      "from_step": "step_1",
