{
  "name": "90-day-goal-planner-chain",
  "description": "Convert an ambiguous goal into a concrete, executable 90-day action plan with milestones, task dependencies, resource allocation, and weekly checkpoints.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "goal-clarifier",
      "inputs": {
        "goal_statement": "from_user_input",
        "goal_context": "from_user_input_optional",
        "known_risks": "from_user_input_optional"
      },
      "outputs": {
        "clarified_goal": "clarified_goal_object"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2",
      "skill_name": "kra-decomposer",
      "inputs": {
        "clarified_goal": "step_1.clarified_goal",
        "goal_context": "from_user_input_optional"
      },
      "outputs": {
        "key_result_areas": "kra_array"
      },
      "parallel_group": 2
    },
    {
      "id": "step_3",
      "skill_name": "milestone-designer",
      "inputs": {
        "key_result_areas": "step_2.key_result_areas",
        "clarified_goal": "step_1.clarified_goal"
      },
      "outputs": {
        "milestones": "milestone_array"
      },
      "parallel_group": 3
    },
    {
      "id": "step_4",
      "skill_name": "task-breakdown-engine",
      "inputs": {
        "milestones": "step_3.milestones",
        "key_result_areas": "step_2.key_result_areas"
      },
      "outputs": {
        "weekly_tasks": "task_array"
      },
      "parallel_group": 4
    },
    {
      "id": "step_5",
      "skill_name": "dependency-mapper",
      "inputs": {
        "weekly_tasks": "step_4.weekly_tasks"
      },
      "outputs": {
        "dependency_graph": "dependency_graph_object"
      },
      "parallel_group": 5
    },
    {
      "id": "step_6",
      "skill_name": "resource-allocator",
      "inputs": {
        "weekly_tasks": "step_4.weekly_tasks",
        "dependency_graph": "step_5.dependency_graph",
        "available_resources": "from_user_input_optional"
      },
      "outputs": {
        "resource_plan": "resource_plan_object"
      },
      "parallel_group": 6
    },
    {
      "id": "step_7",
      "skill_name": "checkpoint-designer",
      "inputs": {
        "key_result_areas": "step_2.key_result_areas",
        "weekly_tasks": "step_4.weekly_tasks",
        "milestones": "step_3.milestones"
      },
      "outputs": {
        "checkpoint_template": "checkpoint_template_object"
      },
      "parallel_group": 7
    },
    {
      "id": "step_8",
      "skill_name": "risk-register-builder",
      "inputs": {
        "known_risks": "from_user_input_optional",
        "weekly_tasks": "step_4.weekly_tasks",
        "dependency_graph": "step_5.dependency_graph"
      },
      "outputs": {
        "risk_register": "risk_register_array"
      },
      "parallel_group": 7
    },
    {
      "id": "step_9",
      "skill_name": "plan-assembler",
      "inputs": {
        "clarified_goal": "step_1.clarified_goal",
        "key_result_areas": "step_2.key_result_areas",
        "milestones": "step_3.milestones",
        "weekly_tasks": "step_4.weekly_tasks",
        "dependency_graph": "step_5.dependency_graph",
        "resource_plan": "step_6.resource_plan",
        "checkpoint_template": "step_7.checkpoint_template",
        "risk_register": "step_8.risk_register"
      },
      "outputs": {
        "action_plan_document": "markdown_string"
      },
      "parallel_group": 8
    }
  ],
  "edges": [
    {
      "from_step": "step_1",
      "to_step": "step_2",
      "data_type": "clarified_goal",
      "field_mapping": "clarified_goal -> clarified_goal"
