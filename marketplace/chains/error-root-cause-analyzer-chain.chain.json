      "skill_name": "error-root-cause-analyzer",
      "phase": "Phase 1: Collect and Parse Logs",
      "inputs": {
        "error_logs": "from_user_input",
        "log_format": "from_user_input_or_default_auto",
        "time_window": "from_user_input_or_default_24h"
      },
      "outputs": {
        "parsed_logs": "structured_log_entries",
        "parse_metadata": "parsing_statistics"
      },
      "parallel_group": "group_1"
    },
    {
      "id": "step_2_stack_trace_extraction",
      "skill_name": "error-root-cause-analyzer",
      "phase": "Phase 2: Extract and Normalize Stack Traces",
      "inputs": {
        "parsed_logs": "from_step_1_log_collection"
      },
      "outputs": {
        "normalized_traces": "structured_stack_traces",
        "trace_metadata": "trace_statistics"
      },
      "parallel_group": "group_1"
    },
    {
