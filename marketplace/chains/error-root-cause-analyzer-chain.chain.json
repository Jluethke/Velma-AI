        "clustering_metadata": "from_step_3_error_clustering",
        "parse_metadata": "from_step_1_log_collection"
      },
      "outputs": {
        "analysis_report": "markdown_report",
        "analysis_metadata": "comprehensive_metadata"
      },
      "parallel_group": "group_5"
    }
