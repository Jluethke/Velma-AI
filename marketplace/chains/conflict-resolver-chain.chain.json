{
  "name": "conflict-resolver-chain",
  "description": "Analyzes a conflict using the Thomas-Kilmann framework and recommends resolution strategies matched to relationship type and stakes.",
  "steps": [
    {
      "id": "step_1_preflight",
      "skill_name": "conflict-resolver",
      "phase": "Phase 0: Pre-Flight Information Check",
      "inputs": {
        "conflict_description": "from_user_input"
      },
      "outputs": {
        "preflight_confirmation": "confirmation_or_clarifying_questions",
        "missing_inputs_plan": "list_of_missing_optional_inputs"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2_parse",
      "skill_name": "conflict-resolver",
      "phase": "Phase 1: Parse and Validate Conflict Description",
      "inputs": {
        "conflict_description": "from_step_1_preflight.preflight_confirmation"
      },
      "outputs": {
        "conflict_summary": "structured_summary_with_parties_and_core_issue"
      },
      "parallel_group": 2
    },
    {
      "id": "step_3_assess_context",
      "skill_name": "conflict-resolver",
      "phase": "Phase 2: Assess Relationship Context, Power Dynamics, and Stakes",
      "inputs": {
        "conflict_summary": "from_step_2_parse.conflict_summary",
        "relationship_type": "from_user_input_or_inferred",
        "relationship_importance": "from_user_input_or_inferred",
        "stakes_level": "from_user_input_or_inferred"
      },
      "outputs": {
        "relationship_classification": "type_and_importance_score",
        "power_dynamics_assessment": "balance_and_sources",
        "stakes_assessment": "level_and_consequences",
        "urgency_classification": "immediate_soon_or_ongoing"
      },
      "parallel_group": 2
    },
    {
      "id": "step_4_assess_position",
      "skill_name": "conflict-resolver",
      "phase": "Phase 3: Assess Your Position on Assertiveness-Cooperativeness Matrix",
      "inputs": {
        "conflict_summary": "from_step_2_parse.conflict_summary",
        "relationship_classification": "from_step_3_assess_context.relationship_classification",
        "stakes_assessment": "from_step_3_assess_context.stakes_assessment",
        "your_assertiveness_preference": "from_user_input_or_inferred"
      },
      "outputs": {
        "assertiveness_score": "1_to_5_with_justification",
        "cooperativeness_score": "1_to_5_with_justification",
        "tension_summary": "if_any",
        "consistency_check": "pass_or_flag"
      },
      "parallel_group": 3
    },
    {
      "id": "step_5_map_mode",
      "skill_name": "conflict-resolver",
      "phase": "Phase 4: Map to Thomas-Kilmann Mode(s)",
      "inputs": {
        "assertiveness_score": "from_step_4_assess_position.assertiveness_score",
        "cooperativeness_score": "from_step_4_assess_position.cooperativeness_score",
        "relationship_classification": "from_step_3_assess_context.relationship_classification",
        "power_dynamics_assessment": "from_step_3_assess_context.power_dynamics_assessment",
        "stakes_assessment": "from_step_3_assess_context.stakes_assessment",
        "your_assertiveness_preference": "from_user_input_or_inferred"
      },
      "outputs": {
        "primary_mode": "competing_collaborating_compromising_avoiding_or_accommodating",
        "secondary_mode": "string_or_null",
        "mode_rationale": "2_to_3_sentences",
        "mismatch_warnings": "with_mode_shift_tactics_if_any"
      },
      "parallel_group": 4
    },
    {
      "id": "step_6_generate_strategies",
      "skill_name": "conflict-resolver",
      "phase": "Phase 5: Generate Mode-Specific Strategies",
      "inputs": {
        "primary_mode": "from_step_5_map_mode.primary_mode",
        "secondary_mode": "from_step_5_map_mode.secondary_mode",
        "conflict_summary": "from_step_2_parse.conflict_summary",
        "relationship_classification": "from_step_3_assess_context.relationship_classification"
      },
      "outputs": {
        "recommended_strategies": "array_of_2_to_4_strategy_objects"
      },
      "parallel_group": 5
    },
    {
      "id": "step_7_implementation_guidance",
      "skill_name": "conflict-resolver",
      "phase": "Phase 6: Develop Implementation Guidance",
      "inputs": {
        "recommended_strategies": "from_step_6_generate_strategies.recommended_strategies",
        "conflict_summary": "from_step_2_parse.conflict_summary",
        "stakes_assessment": "from_step_3_assess_context.stakes_assessment",
        "urgency_classification": "from_step_3_assess_context.urgency_classification"
      },
      "outputs": {
        "timing_recommendation": "specific_not_vague",
        "communication_approach": "with_sample_opening_statement",
        "potential_obstacles": "array_of_strings",
        "contingencies": "array_of_strings",
        "success_indicators": "array_with_short_term_and_long_term",
        "preparation_steps": "array_if_any"
      },
      "parallel_group": 6
    },
    {
      "id": "step_8_validate_deliver",
      "skill_name": "conflict-resolver",
      "phase": "Phase 7: Validate and Deliver Recommendation",
      "inputs": {
        "conflict_summary": "from_step_2_parse.conflict_summary",
        "thomas_kilmann_analysis": "from_steps_4_5",
        "recommended_strategies": "from_step_6_generate_strategies.recommended_strategies",
        "implementation_guidance": "from_step_7_implementation_guidance"
      },
      "outputs": {
        "conflict_summary": "final_structured_summary",
        "thomas_kilmann_analysis": "complete_analysis_object",
        "recommended_strategies": "final_array",
        "implementation_guidance": "final_object",
        "confidence_level": "high_medium_or_low_with_justification",
        "assumptions_and_caveats": "if_any",
        "cultural_context_note": "if_applicable"
      },
      "parallel_group": 7
    }
  ],
  "edges": [
    {
      "from_step": "step_1_preflight",
      "to_step": "step_2_parse",
      "data_type": "conflict_description_validated",
      "field_mapping": "preflight_confirmation -> conflict_description"
    },
    {
      "from_step": "step_2_parse",
      "to_step": "step_3_assess_context",
      "data_type": "conflict_summary",
      "field_mapping": "conflict_summary -> conflict_summary"
    },
    {
      "from_step": "step_2_parse",
      "to_step": "step_4_assess_position",
      "data_type": "conflict_summary",
      "field_mapping": "conflict_summary -> conflict_summary"
    },
    {
      "from_step": "step_3_assess_context",
      "to_step": "step_4_assess_position",
      "data_type": "relationship_and_stakes_context",
      "field_mapping": "relationship_classification, stakes_assessment -> relationship_classification, stakes_assessment"
    },
    {
      "from_step": "step_3_assess_context",
      "to_step": "step_5_map_mode",
      "data_type": "relationship_power_stakes_context",
      "field_mapping": "relationship_classification, power_dynamics_assessment, stakes_assessment -> relationship_classification, power_dynamics_assessment, stakes_assessment"
    },
    {
      "from_step": "step_4_assess_position",
      "to_step": "step_5_map_mode",
      "data_type": "assertiveness_cooperativeness_scores",
      "field_mapping": "assertiveness_score, cooperativeness_score -> assertiveness_score, cooperativeness_score"
    },
    {
      "from_step": "step_5_map_mode",
      "to_step": "step_6_generate_strategies",
      "data_type": "thomas_kilmann_mode",
      "field_mapping": "primary_mode, secondary_mode -> primary_mode, secondary_mode"
    },
    {
      "from_step": "step_2_parse",
      "to_step": "step_6_generate_strategies",
      "data_type": "conflict_summary",
      "field_mapping": "conflict_summary -> conflict_summary"
    },
    {
      "from_step": "step_3_assess_context",
      "to_step": "step_6_generate_strategies",
      "data_type": "relationship_classification",
      "field_mapping": "relationship_classification -> relationship_classification"
    },
    {
      "from_step": "step_6_generate_strategies",
      "to_step": "step_7_implementation_guidance",
      "data_type": "recommended_strategies",
      "field_mapping": "recommended_strategies -> recommended_strategies"
    },
    {
      "from_step": "step_2_parse",
      "to_step": "step_7_implementation_guidance",
      "data_type": "conflict_summary",
      "field_mapping": "conflict_summary -> conflict_summary"
    },
    {
      "from_step": "step_3_assess_context",
      "to_step": "step_7_implementation_guidance",
      "data_type": "stakes_and_urgency",
      "field_mapping": "stakes_assessment, urgency_classification -> stakes_assessment, urgency_classification"
    },
    {
      "from_step": "step_2_parse",
      "to_step": "step_8_validate_deliver",
      "data_type": "conflict_summary",
      "field_mapping": "conflict_summary -> conflict_summary"
    },
    {
      "from_step": "step_4_assess_position",
      "to_step": "step_8_validate_deliver",
      "data_type": "assertiveness_cooperativeness_scores",
      "field_mapping": "assertiveness_score, cooperativeness_score -> assertiveness_score, cooperativeness_score"
    },
    {
      "from_step": "step_5_map_mode",
      "to_step": "step_8_validate_deliver",
      "data_type": "thomas_kilmann_mode",
      "field_mapping": "primary_mode, secondary_mode, mode_rationale -> primary_mode, secondary_mode, mode_rationale"
    },
    {
      "from_step": "step_6_generate_strategies",
      "to_step": "step_8_validate_deliver",
      "data_type": "recommended_strategies",
      "field_mapping": "recommended_strategies -> recommended_strategies"
    },
    {
      "from_step": "step_7_implementation_guidance",
      "to_step": "step_8_validate_deliver",
      "data_type": "implementation_guidance",
      "field_mapping": "timing_recommendation, communication_approach, potential_obstacles, contingencies, success_indicators, preparation_steps -> timing_recommendation, communication_approach, potential_obstacles, contingencies, success_indicators, preparation_steps"
    }
  ],
  "entry_inputs": {
    "conflict_description": "string (required) - Narrative description of the conflict including parties involved, core disagreement, what each party wants, and relevant history",
    "relationship_type": "string (optional) - Category of relationship (e.g., 'professional peer', 'manager-report', 'personal', 'vendor', 'client')",
    "relationship_importance": "number (optional) - Scale 1-5 (1=disposable, 5=critical)",
    "stakes_level": "string (optional) - Severity: 'low', 'medium', or 'high'",
    "your_assertiveness_preference": "number (optional) - Natural tendency to assert own needs (1-5 scale)"
  },
  "terminal_outputs": {
    "conflict_summary": "object with parties, core_issue, relationship_type, stakes, urgency",
    "thomas_kilmann_analysis": "object with assertiveness_score, cooperativeness_score, recommended_mode, secondary_mode, mode_rationale",
    "recommended_strategies": "array of objects with strategy_name, description, when_to_use, expected_outcome, risks",
    "implementation_guidance": "object with timing, communication_approach, potential_obstacles, contingencies, success_indicators, preparation_steps",
    "confidence_level": "string (high, medium, or low) with justification"
  },
  "parallel_groups": [
    [
      "step_1_preflight"
    ],
    [
      "step_2_parse",
      "step_3_assess_context"
    ],
    [
      "step_4_assess_position"
    ],
    [
      "step_5_map_mode"
    ],
    [
      "step_6_generate_strategies"
    ],
    [
      "step_7_implementation_guidance"
    ],
    [
      "step_8_validate_deliver"
    ]
  ],
  "estimated_cost": 0,
  "critical_path": [
    "step_1_preflight",
    "step_2_parse",
    "step_3_assess_context",
    "step_4_assess_position",
    "step_5_map_mode",
    "step_6_generate_strategies",
    "step_7_implementation_guidance",
    "step_8_validate_deliver"
  ]
}