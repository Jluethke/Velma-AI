{
  "name": "sleep-protocol-designer-chain",
  "description": "Analyzes user sleep habits and generates a personalized sleep hygiene protocol with environmental and behavioral recommendations, implementation timeline, and tracking templates.",
  "steps": [
    {
      "id": "step_1_intake",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 1: Sleep Profile Elicitation and Parsing",
      "inputs": {
        "sleep_habits_description": "from_user_input",
        "medical_context": "from_user_input_optional"
      },
      "outputs": {
        "sleep_profile": "preliminary_structured_profile",
        "clarification_flags": "information_gaps_array"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2_assessment",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 2: Sleep Quality Assessment and Problem Identification",
      "inputs": {
        "sleep_profile": "from_step_1_intake",
        "medical_context": "from_user_input_optional"
      },
      "outputs": {
        "sleep_assessment": "dimension_scores_with_evidence",
        "problem_analysis": "categorized_problems_with_severity",
        "intervention_candidates": "evidence_based_interventions",
        "medical_referral_flags": "red_flags_array"
      },
      "parallel_group": 2,
      "depends_on": [
        "step_1_intake"
      ]
    },
    {
      "id": "step_3_constraints",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 3: Constraint and Feasibility Analysis",
      "inputs": {
        "user_constraints": "from_user_input_optional",
        "intervention_candidates": "from_step_2_assessment",
        "sleep_profile": "from_step_1_intake"
      },
      "outputs": {
        "feasibility_assessment": "constraints_extracted",
        "prioritized_interventions": "ranked_by_feasibility",
        "constraint_notes": "limiting_factors_summary",
        "filtered_out_interventions": "removed_interventions_with_reasons"
      },
      "parallel_group": 2,
      "depends_on": [
        "step_2_assessment"
      ]
    },
    {
      "id": "step_4_environmental",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 4: Environmental Recommendations Generation",
      "inputs": {
        "prioritized_interventions": "from_step_3_constraints",
        "problem_analysis": "from_step_2_assessment",
        "user_constraints": "from_user_input_optional"
      },
      "outputs": {
        "environmental_recommendations": "array_of_recommendations",
        "environmental_quick_wins": "subset_immediate_actions",
        "environmental_conflicts_resolved": "conflict_resolutions"
      },
      "parallel_group": 3,
      "depends_on": [
        "step_3_constraints"
      ]
    },
    {
      "id": "step_5_behavioral",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 5: Behavioral Recommendations Generation",
      "inputs": {
        "prioritized_interventions": "from_step_3_constraints",
        "problem_analysis": "from_step_2_assessment",
        "user_constraints": "from_user_input_optional"
      },
      "outputs": {
        "behavioral_recommendations": "array_of_recommendations",
        "behavioral_quick_wins": "subset_immediate_actions",
        "difficult_changes": "high_difficulty_with_plans",
        "replacement_behaviors": "habit_substitution_map"
      },
      "parallel_group": 3,
      "depends_on": [
        "step_3_constraints"
      ]
    },
    {
      "id": "step_6_protocol",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 6: Implementation Protocol and Timeline Design",
      "inputs": {
        "environmental_recommendations": "from_step_4_environmental",
        "behavioral_recommendations": "from_step_5_behavioral",
        "user_constraints": "from_user_input_optional",
        "feasibility_assessment": "from_step_3_constraints"
      },
      "outputs": {
        "implementation_protocol": "phased_rollout_plan",
        "success_metrics": "measurable_targets",
        "tracking_template": "daily_weekly_log_format",
        "checkpoint_schedule": "review_dates_and_prompts",
        "contingency_plan": "alternatives_if_not_working"
      },
      "parallel_group": 4,
      "depends_on": [
        "step_4_environmental",
        "step_5_behavioral"
      ]
    },
    {
      "id": "step_7_document",
      "skill_name": "sleep-protocol-designer",
      "phase": "Phase 7: Protocol Document Compilation",
      "inputs": {
        "implementation_protocol": "from_step_6_protocol",
        "sleep_assessment": "from_step_2_assessment",
        "problem_analysis": "from_step_2_assessment",
        "environmental_recommendations": "from_step_4_environmental",
        "behavioral_recommendations": "from_step_5_behavioral",
        "success_metrics": "from_step_6_protocol",
        "tracking_template": "from_step_6_protocol",
        "medical_referral_flags": "from_step_2_assessment",
        "user_constraints": "from_user_input_optional",
        "sleep_profile": "from_step_1_intake"
      },
      "outputs": {
        "protocol_document": "formatted_complete_guide"
      },
      "parallel_group": 5,
      "depends_on": [
        "step_6_protocol"
      ]
    }
  ],
  "edges": [
    {
      "from_step": "step_1_intake",
      "to_step": "step_2_assessment",
      "data_type": "sleep_profile_object",
      "field_mapping": "sleep_profile -> sleep_profile"
    },
    {
      "from_step": "step_2_assessment",
      "to_step": "step_3_constraints",
      "data_type": "intervention_candidates_array",
      "field_mapping": "intervention_candidates -> intervention_candidates"
    },
    {
      "from_step": "step_2_assessment",
      "to_step": "step_3_constraints",
      "data_type": "problem_analysis_object",
      "field_mapping": "problem_analysis -> problem_analysis"
    },
    {
      "from_step": "step_3_constraints",
      "to_step": "step_4_environmental",
      "data_type": "prioritized_interventions_array",
      "field_mapping": "prioritized_interventions -> prioritized_interventions"
    },
    {
      "from_step": "step_3_constraints",
      "to_step": "step_5_behavioral",
      "data_type": "prioritized_interventions_array",
      "field_mapping": "prioritized_interventions -> prioritized_interventions"
    },
    {
      "from_step": "step_4_environmental",
      "to_step": "step_6_protocol",
      "data_type": "environmental_recommendations_array",
      "field_mapping": "environmental_recommendations -> environmental_recommendations"
    },
    {
      "from_step": "step_5_behavioral",
      "to_step": "step_6_protocol",
      "data_type": "behavioral_recommendations_array",
      "field_mapping": "behavioral_recommendations -> behavioral_recommendations"
    },
    {
      "from_step": "step_6_protocol",
      "to_step": "step_7_document",
      "data_type": "implementation_protocol_object",
      "field_mapping": "implementation_protocol -> implementation_protocol"
    },
    {
      "from_step": "step_6_protocol",
      "to_step": "step_7_document",
      "data_type": "success_metrics_array",
      "field_mapping": "success_metrics -> success_metrics"
    },
    {
      "from_step": "step_6_protocol",
      "to_step": "step_7_document",
      "data_type": "tracking_template_string",
      "field_mapping": "tracking_template -> tracking_template"
    },
    {
      "from_step": "step_2_assessment",
      "to_step": "step_7_document",
      "data_type": "sleep_assessment_object",
      "field_mapping": "sleep_assessment -> sleep_assessment"
    },
    {
      "from_step": "step_2_assessment",
      "to_step": "step_7_document",
      "data_type": "medical_referral_flags_array",
      "field_mapping": "medical_referral_flags -> medical_referral_flags"
    }
  ],
  "entry_inputs": {
    "sleep_habits_description": "string (required, minimum 100 characters, must include at least 3 of: sleep/wake times, quality rating, problems, environment, habits, stress, health conditions)",
    "user_constraints": "object (optional: budget_level, time_to_implement, physical_limitations, living_situation, flexibility_score)",
    "priority_goals": "array (optional: user's primary sleep goals)",
    "medical_context": "string (optional: relevant medical history or medications)"
  },
  "terminal_outputs": {
    "sleep_profile": "structured assessment with 6 dimensions scored 1-10",
    "problem_analysis": "categorized root causes with severity and modifiability ranks",
    "environmental_recommendations": "array of 2-7 specific environmental changes with implementation details",
    "behavioral_recommendations": "array of 2-7 specific behavioral changes with sequencing and difficulty levels",
    "implementation_protocol": "phased rollout plan spanning 2-4+ weeks with success metrics and tracking",
    "protocol_document": "comprehensive 2500-3500 word formatted sleep hygiene guide ready for user"
  },
  "parallel_groups": [
    [
      "step_1_intake"
    ],
    [
      "step_2_assessment",
      "step_3_constraints"
    ],
    [
      "step_4_environmental",
      "step_5_behavioral"
    ],
    [
      "step_6_protocol"
    ],
    [
      "step_7_document"
    ]
  ],
  "estimated_cost": "0 TRUST (single skill execution; no external dependencies)",
  "critical_path": [
    "step_1_intake",
    "step_2_assessment",
    "step_3_constraints",
    "step_4_environmental",
    "step_5_behavioral",
    "step_6_protocol",
    "step_7_document"
  ],
  "critical_path_length": 7,
  "parallelizable_steps": 2,
  "execution_notes": "This chain is a single-skill pipeline that executes all 7 phases of the Sleep Protocol Designer skill sequentially. Phases 4 and 5 (environmental and behavioral recommendations) can execute in parallel as they have independent inputs from Phase 3. The chain is deterministic: given the same sleep habits description and constraints, it produces consistent outputs."
}