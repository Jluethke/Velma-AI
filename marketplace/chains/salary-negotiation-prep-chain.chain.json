      "to_step": "step_5_compile_negotiation_brief",
      "data_type": "number",
      "field_mapping": "market_median -> market_median"
    },
    {
      "from_step": "step_2_analyze_batna",
      "to_step": "step_5_compile_negotiation_brief",
      "data_type": "object",
      "field_mapping": "batna_analysis -> batna_analysis"
    },
    {
      "from_step": "step_3_develop_anchoring_strategy",
      "to_step": "step_5_compile_negotiation_brief",
      "data_type": "object",
      "field_mapping": "anchoring_strategy -> anchoring_strategy"
    },
    {
      "from_step": "step_4_create_response_scripts",
