{
  "name": "salary-negotiation-prep-chain",
  "description": "End-to-end chain to generate a negotiation preparation brief with market data, BATNA analysis, anchoring strategy, and response scripts.",
  "steps": [
    {
      "id": "step_1_gather_market_data",
      "skill_name": "Salary Negotiation Preparation Brief",
      "phase": "Phase 1: Gather Market Salary Data",
      "inputs": {
        "job_title": "from user input",
        "location": "from user input",
        "experience_level": "from user input",
        "industry": "from user input",
        "company_size": "from user input (default: mid-market)"
      },
      "outputs": {
        "market_data_points": "array of {source, salary_min, salary_max, percentile, sample_size, date_collected}",
        "market_median": "weighted average salary"
      },
      "parallel_group": 1,
      "dependencies": []
    },
    {
      "id": "step_2_analyze_batna",
      "skill_name": "Salary Negotiation Preparation Brief",
      "phase": "Phase 2: Analyze BATNA",
      "inputs": {
        "current_salary": "from user input (optional)",
        "desired_salary": "from user input",
        "personal_walk_away_threshold": "from user input (optional)",
        "other_offers": "from user input (optional)",
        "market_median": "from step_1_gather_market_data"
      },
      "outputs": {
        "batna_analysis": "object with batna_statement, fallback_salary, walk_away_threshold, batna_strength"
      },
      "parallel_group": 1,
      "dependencies": [
        "step_1_gather_market_data"
      ]
    },
    {
      "id": "step_3_develop_anchoring_strategy",
      "skill_name": "Salary Negotiation Preparation Brief",
      "phase": "Phase 3: Develop Anchoring Strategy",
      "inputs": {
        "market_median": "from step_1_gather_market_data",
        "batna_analysis": "from step_2_analyze_batna",
        "desired_salary": "from user input",
        "negotiation_context": "from user input",
        "non_salary_priorities": "from user input (optional)"
      },
      "outputs": {
        "anchoring_strategy": "object with opening_anchor, anchor_justification, acceptable_range_min, acceptable_range_max, anchor_type, negotiation_levers"
      },
      "parallel_group": 2,
      "dependencies": [
        "step_1_gather_market_data",
        "step_2_analyze_batna"
      ]
    },
    {
      "id": "step_4_create_response_scripts",
      "skill_name": "Salary Negotiation Preparation Brief",
      "phase": "Phase 4: Create Response Scripts",
      "inputs": {
        "anchoring_strategy": "from step_3_develop_anchoring_strategy",
        "batna_analysis": "from step_2_analyze_batna",
        "negotiation_context": "from user input",
        "non_salary_priorities": "from user input (optional)"
      },
      "outputs": {
        "response_scripts": "object with keys: budget-constraint, market-rate-challenge, performance-concern, equity-argument, timing-objection, non-salary-objection, fallback-scenario"
      },
      "parallel_group": 2,
      "dependencies": [
        "step_3_develop_anchoring_strategy",
        "step_2_analyze_batna"
      ]
    },
    {
      "id": "step_5_compile_negotiation_brief",
      "skill_name": "Salary Negotiation Preparation Brief",
      "phase": "Phase 5: Compile Negotiation Brief",
      "inputs": {
        "market_data_points": "from step_1_gather_market_data",
        "market_median": "from step_1_gather_market_data",
        "batna_analysis": "from step_2_analyze_batna",
        "anchoring_strategy": "from step_3_develop_anchoring_strategy",
        "response_scripts": "from step_4_create_response_scripts",
        "job_title": "from user input",
        "location": "from user input",
        "negotiation_context": "from user input"
      },
      "outputs": {
        "negotiation_brief": "markdown formatted 1-2 page brief with all sections"
      },
      "parallel_group": 3,
      "dependencies": [
        "step_1_gather_market_data",
        "step_2_analyze_batna",
        "step_3_develop_anchoring_strategy",
        "step_4_create_response_scripts"
      ]
    }
  ],
  "edges": [
    {
      "from_step": "step_1_gather_market_data",
      "to_step": "step_2_analyze_batna",
      "data_type": "number",
