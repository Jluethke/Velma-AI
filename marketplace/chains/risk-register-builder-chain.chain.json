{
  "name": "Risk Register Builder Chain",
  "description": "Transform a project scope document into a comprehensive risk register with probability, impact, mitigation strategies, and early warning indicators.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "Scope Analyzer",
      "description": "Extract and analyze project scope from document",
      "inputs": {
        "scope_document": "from_user_input",
        "project_type": "from_user_input"
      },
      "outputs": {
        "scope_summary": "structured scope with objectives, deliverables, constraints, stakeholders, success criteria, timeline, budget",
        "clarification_questions": "list of ambiguities requiring follow-up"
      },
      "parallel_group": "group_1"
    },
    {
      "id": "step_2",
      "skill_name": "Risk Brainstormer",
      "description": "Identify risk categories and brainstorm potential risks",
      "inputs": {
        "scope_summary": "from_step_1.scope_summary",
        "project_type": "from_user_input",
        "historical_data": "from_user_input_optional",
        "stakeholder_input": "from_user_input_optional"
      },
      "outputs": {
        "risk_list": "unfiltered risks with category, description, trigger, outcome",
        "risk_count_by_category": "count of risks per category"
      },
      "parallel_group": "group_2"
    },
    {
      "id": "step_3",
      "skill_name": "Risk Assessor",
      "description": "Assess probability and impact for each risk",
      "inputs": {
        "risk_list": "from_step_2.risk_list",
        "risk_assessment_scale": "from_user_input_optional",
        "historical_data": "from_user_input_optional"
      },
      "outputs": {
        "assessed_risks": "risks with probability, impact dimensions, basis, consistency notes",
        "watch_list": "low probability AND low impact risks"
      },
      "parallel_group": "group_3"
    },
    {
      "id": "step_4",
      "skill_name": "Risk Prioritizer",
      "description": "Calculate priority scores and rank risks",
      "inputs": {
        "assessed_risks": "from_step_3.assessed_risks",
        "risk_appetite": "from_user_input_optional",
        "risk_assessment_scale": "from_user_input_optional"
      },
      "outputs": {
        "ranked_risks": "risks with priority score and rank (High/Medium/Low)",
        "priority_summary": "count by priority level, threshold value, heat map"
      },
      "parallel_group": "group_4"
    },
    {
      "id": "step_5",
      "skill_name": "Mitigation Strategist",
      "description": "Develop mitigation strategies for high-priority risks",
      "inputs": {
        "ranked_risks": "from_step_4.ranked_risks",
        "scope_summary": "from_step_1.scope_summary",
        "risk_appetite": "from_user_input_optional"
      },
      "outputs": {
        "mitigated_risks": "high-priority risks with strategy, action, owner, timeline, cost, success criteria",
        "contingency_plans": "accepted risks with fallback and reserve plans"
      },
      "parallel_group": "group_5"
    },
    {
      "id": "step_6",
      "skill_name": "EWI Designer",
      "description": "Define early warning indicators for risks",
      "inputs": {
        "mitigated_risks": "from_step_5.mitigated_risks",
        "ranked_risks": "from_step_4.ranked_risks"
      },
      "outputs": {
        "risks_with_ewis": "risks with indicator, threshold, monitoring frequency, method, response trigger",
        "monitoring_plan": "consolidated monitoring schedule and escalation paths"
      },
      "parallel_group": "group_6"
    },
    {
      "id": "step_7",
      "skill_name": "Register Compiler",
      "description": "Compile and validate risk register",
      "inputs": {
        "risks_with_ewis": "from_step_6.risks_with_ewis",
        "watch_list": "from_step_3.watch_list",
        "scope_summary": "from_step_1.scope_summary",
        "priority_summary": "from_step_4.priority_summary"
      },
      "outputs": {
        "risk_register": "structured register with all risk fields and summary statistics",
        "register_markdown": "human-readable markdown table for stakeholder communication",
        "gaps_and_refinements": "identified gaps and recommendations"
      },
      "parallel_group": "group_7"
    }
  ],
  "edges": [
    {
      "from_step": "step_1",
      "to_step": "step_2",
      "data_type": "scope_summary",
      "field_mapping": "scope_summary -> scope_summary"
    },
    {
      "from_step": "step_2",
      "to_step": "step_3",
      "data_type": "risk_list",
      "field_mapping": "risk_list -> risk_list"
    },
    {
      "from_step": "step_3",
      "to_step": "step_4",
      "data_type": "assessed_risks",
      "field_mapping": "assessed_risks -> assessed_risks"
    },
    {
      "from_step": "step_4",
      "to_step": "step_5",
      "data_type": "ranked_risks",
      "field_mapping": "ranked_risks -> ranked_risks"
    },
    {
      "from_step": "step_1",
      "to_step": "step_5",
      "data_type": "scope_summary",
      "field_mapping": "scope_summary -> scope_summary"
    },
    {
      "from_step": "step_5",
      "to_step": "step_6",
      "data_type": "mitigated_risks",
      "field_mapping": "mitigated_risks -> mitigated_risks"
    },
    {
      "from_step": "step_4",
      "to_step": "step_6",
      "data_type": "ranked_risks",
      "field_mapping": "ranked_risks -> ranked_risks"
    },
    {
      "from_step": "step_6",
      "to_step": "step_7",
      "data_type": "risks_with_ewis",
      "field_mapping": "risks_with_ewis -> risks_with_ewis"
    },
    {
      "from_step": "step_3",
      "to_step": "step_7",
      "data_type": "watch_list",
      "field_mapping": "watch_list -> watch_list"
    },
    {
      "from_step": "step_1",
      "to_step": "step_7",
      "data_type": "scope_summary",
      "field_mapping": "scope_summary -> scope_summary"
    },
    {
      "from_step": "step_4",
      "to_step": "step_7",
      "data_type": "priority_summary",
      "field_mapping": "priority_summary -> priority_summary"
    }
  ],
  "entry_inputs": {
    "scope_document": "string (required)",
    "project_type": "string (required)",
    "risk_assessment_scale": "string (optional, default: Low/Medium/High)",
    "historical_data": "object (optional)",
    "stakeholder_input": "string (optional)",
    "risk_appetite": "string (optional, default: moderate)"
  },
  "terminal_outputs": {
    "risk_register": "object with structured risks, summary, and metadata",
    "register_markdown": "string (markdown table format)",
    "gaps_and_refinements": "array of strings"
  },
  "parallel_groups": [
    [
      "step_1"
    ],
    [
      "step_2"
    ],
    [
      "step_3"
    ],
    [
      "step_4"
    ],
    [
      "step_5"
    ],
    [
      "step_6"
    ],
    [
      "step_7"
    ]
  ],
  "estimated_cost": 7,
  "critical_path": [
    "step_1",
    "step_2",
    "step_3",
    "step_4",
    "step_5",
    "step_6",
    "step_7"
  ]
}