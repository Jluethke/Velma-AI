{
  "name": "Project-Based Lesson Design Chain",
  "description": "A comprehensive pipeline that designs hands-on, scaffolded learning projects with validated alignment to learning objectives, checkpoint assessments, extension challenges, and instructor support materials.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "Phase 1: Define Learning Objective and Validate Feasibility",
      "inputs": {
        "skill_domain": "from user input",
        "learner_level": "from user input",
        "time_constraint": "from user input",
        "instructor_context": "from user input (optional)"
      },
      "outputs": {
        "learning_objective": "formal statement with action verb",
        "feasibility_notes": "scope adjustments and rationale",
        "prerequisites": "list with validation methods",
        "common_misconceptions_draft": "preliminary list of errors"
      },
      "parallel_group": "entry_phase"
    },
    {
      "id": "step_2",
      "skill_name": "Phase 2: Design Project Concept and Real-World Context",
      "inputs": {
        "learning_objective": "from step_1",
        "available_resources": "from user input (optional)",
        "learner_motivation": "from user input (optional)"
      },
      "outputs": {
        "project_brief": "scenario, deliverable, relevance, constraints, accessibility"
      },
      "parallel_group": "entry_phase"
    },
    {
      "id": "step_3",
      "skill_name": "Phase 3: Decompose Skill into Scaffolded Learning Steps",
      "inputs": {
        "project_brief": "from step_2",
        "learning_objective": "from step_1",
        "time_constraint": "from user input",
        "common_misconceptions_draft": "from step_1"
      },
      "outputs": {
        "scaffolded_steps": "5-8 ordered steps with scaffolding and misconception addressing"
      },
      "parallel_group": "design_phase"
    },
    {
      "id": "step_4",
      "skill_name": "Phase 4: Create Checkpoint Assessments",
      "inputs": {
        "scaffolded_steps": "from step_3",
        "learning_objective": "from step_1",
        "common_misconceptions_draft": "from step_1"
      },
      "outputs": {
        "checkpoints": "2-4 formative assessments with pass criteria and remediation"
      },
      "parallel_group": "design_phase"
    },
    {
      "id": "step_5",
      "skill_name": "Phase 5: Design Extension Challenges for Advanced Learners",
      "inputs": {
        "scaffolded_steps": "from step_3",
        "checkpoints": "from step_4",
        "learner_level": "from user input"
      },
      "outputs": {
        "extensions": "2-3 optional advanced tasks with scaffolding"
      },
      "parallel_group": "design_phase"
    },
    {
      "id": "step_6",
      "skill_name": "Phase 6: Develop Supporting Materials and Resources",
      "inputs": {
        "scaffolded_steps": "from step_3",
        "checkpoints": "from step_4",
        "extensions": "from step_5",
        "available_resources": "from user input (optional)"
      },
      "outputs": {
        "supporting_materials": "templates, guides, examples with accessibility features"
      },
      "parallel_group": "materials_phase"
    },
    {
      "id": "step_7",
      "skill_name": "Phase 7: Define Success Criteria and Completion Rubric",
      "inputs": {
        "learning_objective": "from step_1",
        "scaffolded_steps": "from step_3",
        "checkpoints": "from step_4",
        "extensions": "from step_5"
      },
      "outputs": {
        "completion_rubric": "competency levels, dimensions, extension tiers, self-assessment"
      },
      "parallel_group": "materials_phase"
    },
    {
      "id": "step_8",
      "skill_name": "Phase 8: Validate Project Design Against Learning Objective",
      "inputs": {
        "learning_objective": "from step_1",
        "project_brief": "from step_2",
        "scaffolded_steps": "from step_3",
        "checkpoints": "from step_4",
        "extensions": "from step_5",
        "supporting_materials": "from step_6",
        "completion_rubric": "from step_7",
        "prerequisites": "from step_1",
        "available_resources": "from user input (optional)"
      },
      "outputs": {
        "validation_report": "alignment score, gap analysis, resource audit, recommendations"
      },
      "parallel_group": "validation_phase"
    },
    {
      "id": "step_9",
      "skill_name": "Phase 9: Develop Instructor Guide and Differentiation Strategy",
      "inputs": {
        "scaffolded_steps": "from step_3",
        "checkpoints": "from step_4",
        "extensions": "from step_5",
        "common_misconceptions_draft": "from step_1",
        "learner_level": "from user input",
        "validation_report": "from step_8"
      },
      "outputs": {
        "differentiation_strategy": "fast/struggling learner pathways with identification criteria",
        "instructor_guide": "troubleshooting, facilitation tips, reflection prompts, misconception strategies"
      },
      "parallel_group": "final_phase"
    }
  ],
  "edges": [
