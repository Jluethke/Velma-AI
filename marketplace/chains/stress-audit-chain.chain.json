{
  "name": "stress-audit-chain",
  "description": "Guide a user through a structured stress audit to identify stressors, categorize by controllability, assess impact, and generate a prioritized stress management action plan.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "stress-audit",
      "inputs": {
        "user_context": "user_context",
        "stressor_collection_method": "stressor_collection_method",
        "include_physical_health": "include_physical_health",
        "action_plan_detail_level": "action_plan_detail_level",
        "baseline_stress_rating": "baseline_stress_rating"
      },
      "outputs": {
        "stressor_list": "stressor_list",
        "action_plan": "action_plan",
        "quick_wins": "quick_wins",
        "audit_summary": "audit_summary",
        "one_page_plan": "one_page_plan",
        "baseline_to_post_stress_rating": "baseline_to_post_stress_rating",
        "next_review_date": "next_review_date"
      },
      "parallel_group": 1
    }
  ],
  "edges": [],
  "entry_inputs": {
    "user_context": {
      "type": "string",
      "description": "Brief background on the user (role, life stage, current situation) to tailor language and examples",
      "optional": true,
      "default": "General adult"
    },
    "stressor_collection_method": {
      "type": "string",
      "description": "How to elicit stressors: 'open-ended', 'guided-prompts', or 'checklist'",
      "optional": true,
      "default": "open-ended"
    },
    "include_physical_health": {
      "type": "boolean",
      "description": "Whether to explicitly ask about physical health stressors",
      "optional": true,
      "default": true
    },
    "action_plan_detail_level": {
      "type": "string",
      "description": "Depth of generated actions: 'brief' or 'detailed'",
      "optional": true,
      "default": "detailed"
    },
    "baseline_stress_rating": {
      "type": "integer",
      "description": "User's self-reported stress level (1-10) before the audit",
      "optional": true,
      "default": null
    }
  },
  "terminal_outputs": [
    "stressor_list",
    "action_plan",
    "quick_wins",
    "audit_summary",
    "one_page_plan",
    "baseline_to_post_stress_rating",
    "next_review_date"
  ],
  "parallel_groups": [
    [
      "step_1"
    ]
  ],
  "estimated_cost": 0,
  "critical_path": [
    "step_1"
  ]
}