{
  "name": "Code Review Chain",
  "description": "Design an optimal chain to execute the Code Review Assistant skill by decomposing its 6 phases into executable steps with data flow and parallelization.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "Code Review Assistant - Phase 1: Parse and Validate Diff",
      "inputs": {
        "git_diff": "from_entry",
        "context_lines": "from_entry",
        "language_context": "from_entry"
      },
      "outputs": {
        "parsed_diff": "parsed_diff",
        "language_detected": "language_detected",
        "files_changed": "files_changed",
        "change_stats": "change_stats"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2",
      "skill_name": "Code Review Assistant - Phase 2: Analyze Code Changes",
      "inputs": {
        "parsed_diff": "from_step_1.parsed_diff",
        "language_detected": "from_step_1.language_detected",
        "project_conventions": "from_entry",
        "review_scope": "from_entry"
      },
      "outputs": {
        "raw_findings": "raw_findings",
        "positive_patterns": "positive_patterns",
        "related_findings_map": "related_findings_map"
      },
      "parallel_group": 2
    },
    {
      "id": "step_3",
      "skill_name": "Code Review Assistant - Phase 3: Assign Severity and Categorize",
      "inputs": {
        "raw_findings": "from_step_2.raw_findings",
        "review_scope": "from_entry",
        "previous_review_feedback": "from_entry"
      },
      "outputs": {
        "critical_issues": "critical_issues",
        "major_issues": "major_issues",
        "minor_suggestions": "minor_suggestions",
        "praise": "praise",
        "recommendation": "recommendation",
        "prior_feedback_status": "prior_feedback_status"
      },
      "parallel_group": 3
    },
    {
      "id": "step_4",
      "skill_name": "Code Review Assistant - Phase 4: Generate Specific Improvement Suggestions",
      "inputs": {
        "critical_issues": "from_step_3.critical_issues",
        "major_issues": "from_step_3.major_issues",
        "minor_suggestions": "from_step_3.minor_suggestions",
        "praise": "from_step_3.praise",
        "parsed_diff": "from_step_1.parsed_diff",
        "language_detected": "from_step_1.language_detected"
      },
      "outputs": {
        "critical_issues_with_suggestions": "critical_issues",
        "major_issues_with_suggestions": "major_issues",
        "minor_suggestions_with_suggestions": "minor_suggestions",
        "praise_with_benefits": "praise"
      },
      "parallel_group": 4
    },
    {
      "id": "step_5",
      "skill_name": "Code Review Assistant - Phase 5: Compile Structured Review",
      "inputs": {
        "critical_issues": "from_step_4.critical_issues",
        "major_issues": "from_step_4.major_issues",
        "minor_suggestions": "from_step_4.minor_suggestions",
        "praise": "from_step_4.praise",
        "recommendation": "from_step_3.recommendation",
        "prior_feedback_status": "from_step_3.prior_feedback_status",
        "files_changed": "from_step_1.files_changed",
        "change_stats": "from_step_1.change_stats"
      },
      "outputs": {
        "code_review": "code_review"
      },
      "parallel_group": 5
    },
    {
      "id": "step_6",
      "skill_name": "Code Review Assistant - Phase 6: Validate and Finalize",
      "inputs": {
        "code_review": "from_step_5.code_review",
        "language_detected": "from_step_1.language_detected",
        "review_scope": "from_entry"
      },
      "outputs": {
        "code_review_final": "code_review",
        "review_metadata": "review_metadata"
      },
      "parallel_group": 6
    }
  ],
  "edges": [
    {
      "from_step": "entry",
      "to_step": "step_1",
      "data_type": "git_diff_input",
      "field_mapping": {
        "git_diff": "git_diff",
        "context_lines": "context_lines",
        "language_context": "language_context"
      }
    },
    {
      "from_step": "step_1",
      "to_step": "step_2",
      "data_type": "parsed_diff_output",
      "field_mapping": {
        "parsed_diff": "parsed_diff",
        "language_detected": "language_detected"
      }
    },
    {
      "from_step": "entry",
      "to_step": "step_2",
      "data_type": "review_parameters",
      "field_mapping": {
        "project_conventions": "project_conventions",
        "review_scope": "review_scope"
      }
    },
    {
      "from_step": "step_2",
      "to_step": "step_3",
      "data_type": "raw_findings_output",
      "field_mapping": {
        "raw_findings": "raw_findings"
      }
    },
    {
      "from_step": "entry",
      "to_step": "step_3",
      "data_type": "review_parameters",
      "field_mapping": {
        "review_scope": "review_scope",
        "previous_review_feedback": "previous_review_feedback"
      }
    },
    {
      "from_step": "step_3",
      "to_step": "step_4",
      "data_type": "categorized_findings",
      "field_mapping": {
        "critical_issues": "critical_issues",
        "major_issues": "major_issues",
        "minor_suggestions": "minor_suggestions",
        "praise": "praise"
      }
    },
    {
      "from_step": "step_1",
      "to_step": "step_4",
      "data_type": "parsed_diff_context",
      "field_mapping": {
        "parsed_diff": "parsed_diff",
        "language_detected": "language_detected"
      }
    },
    {
      "from_step": "step_4",
      "to_step": "step_5",
      "data_type": "findings_with_suggestions",
      "field_mapping": {
        "critical_issues": "critical_issues",
        "major_issues": "major_issues",
        "minor_suggestions": "minor_suggestions",
        "praise": "praise"
      }
    },
    {
      "from_step": "step_3",
      "to_step": "step_5",
      "data_type": "review_metadata",
      "field_mapping": {
        "recommendation": "recommendation",
        "prior_feedback_status": "prior_feedback_status"
      }
    },
    {
      "from_step": "step_1",
      "to_step": "step_5",
      "data_type": "change_metadata",
      "field_mapping": {
        "files_changed": "files_changed",
        "change_stats": "change_stats"
      }
    },
    {
      "from_step": "step_5",
      "to_step": "step_6",
      "data_type": "compiled_review",
      "field_mapping": {
        "code_review": "code_review"
      }
    },
    {
      "from_step": "entry",
      "to_step": "step_6",
      "data_type": "review_parameters",
      "field_mapping": {
        "review_scope": "review_scope"
      }
    },
    {
      "from_step": "step_1",
      "to_step": "step_6",
      "data_type": "language_context",
      "field_mapping": {
        "language_detected": "language_detected"
      }
    }
  ],
  "entry_inputs": {
    "git_diff": "string (required) - unified format diff",
    "language_context": "string (optional, default: auto-detect)",
    "project_conventions": "string (optional)",
    "context_lines": "integer (optional, default: 3)",
    "review_scope": "string (optional, default: comprehensive)",
    "reviewer_expertise": "string (optional, default: general)",
    "previous_review_feedback": "array (optional)"
  },
  "terminal_outputs": {
    "code_review": "structured code review document with all findings, suggestions, and praise",
    "review_metadata": "metadata about the review including timestamp, language, scope, and finding counts"
  },
  "parallel_groups": [
    [
      "step_1"
    ],
    [
      "step_2"
    ],
    [
      "step_3"
    ],
    [
      "step_4"
    ],
    [
      "step_5"
    ],
    [
      "step_6"
    ]
  ],
  "estimated_cost": 6,
  "critical_path": [
    "step_1",
    "step_2",
    "step_3",
    "step_4",
    "step_5",
    "step_6"
  ]
}