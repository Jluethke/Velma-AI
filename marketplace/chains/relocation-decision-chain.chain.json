{
  "name": "relocation-decision-chain",
  "description": "Design and execute a relocation decision matrix by gathering city data, normalizing scores, applying weights, and generating ranked recommendations with sensitivity analysis.",
  "steps": [
    {
      "id": "step_1",
      "skill_name": "relocation-comparator",
      "phase": "Phase 1: Define, Validate, and Categorize Criteria",
      "inputs": {
        "evaluation_criteria": "from_user_input",
        "hard_constraints": "from_user_input"
      },
      "outputs": {
        "criteria_list": "validated_criteria",
        "weight_distribution_summary": "weight_summary",
        "hard_constraints_summary": "constraints_summary"
      },
      "parallel_group": 1,
      "description": "Validate and categorize evaluation criteria into hard constraints, weighted preferences, and informational items."
    },
    {
      "id": "step_2",
      "skill_name": "relocation-comparator",
      "phase": "Phase 2: Identify, Validate, and Pre-Filter Candidate Cities",
      "inputs": {
        "candidate_cities": "from_user_input",
        "hard_constraints_summary": "from_step_1"
      },
      "outputs": {
        "city_list": "validated_cities",
        "eliminated_cities": "filtered_cities",
        "geographic_summary": "geo_summary"
      },
      "parallel_group": 1,
      "description": "Validate candidate cities and apply hard constraint filtering to eliminate ineligible cities."
    },
    {
      "id": "step_3",
      "skill_name": "relocation-comparator",
      "phase": "Phase 3: Gather Cost of Living Data",
      "inputs": {
        "city_list": "from_step_2",
        "data_sources": "from_user_input",
        "budget_range": "from_user_input"
      },
      "outputs": {
        "cost_of_living_data": "cost_data",
        "budget_compliance": "budget_check",
        "cost_trend_analysis": "cost_trends"
      },
      "parallel_group": 2,
      "description": "Gather and normalize cost of living data for all candidate cities, including trend analysis."
    },
    {
      "id": "step_4",
      "skill_name": "relocation-comparator",
      "phase": "Phase 4: Gather Job Market Data",
      "inputs": {
        "city_list": "from_step_2",
        "user_profession": "from_user_input",
        "data_sources": "from_user_input"
      },
      "outputs": {
        "job_market_data": "job_data",
        "career_growth_analysis": "career_growth"
      },
      "parallel_group": 2,
      "description": "Gather job market data including availability, salary, and career growth potential."
    },
    {
      "id": "step_5",
      "skill_name": "relocation-comparator",
      "phase": "Phase 5: Gather Quality of Life Data",
      "inputs": {
        "city_list": "from_step_2",
        "data_sources": "from_user_input"
      },
      "outputs": {
        "quality_of_life_data": "qol_data",
        "qol_sub_metric_weights": "qol_weights"
      },
      "parallel_group": 2,
      "description": "Gather quality of life metrics including safety, schools, healthcare, culture, and recreation."
    },
    {
      "id": "step_6",
      "skill_name": "relocation-comparator",
      "phase": "Phase 6: Gather Climate Data",
      "inputs": {
        "city_list": "from_step_2",
        "climate_preference": "from_user_input"
      },
      "outputs": {
        "climate_data": "climate_info",
        "climate_scoring_rules": "climate_rules"
      },
      "parallel_group": 2,
      "description": "Gather climate data and score alignment with user preferences using explicit rules."
    },
    {
      "id": "step_7",
      "skill_name": "relocation-comparator",
      "phase": "Phase 7: Normalize Scores Across Criteria",
      "inputs": {
        "cost_of_living_data": "from_step_3",
        "job_market_data": "from_step_4",
        "quality_of_life_data": "from_step_5",
        "climate_data": "from_step_6",
        "criteria_list": "from_step_1"
      },
      "outputs": {
        "normalized_scores": "norm_scores",
        "normalization_formulas": "norm_formulas",
        "normalization_validation": "norm_validation"
      },
      "parallel_group": 3,
      "description": "Apply min-max normalization to all criterion scores to create comparable 0-100 scales."
    },
    {
      "id": "step_8",
      "skill_name": "relocation-comparator",
      "phase": "Phase 8: Calculate Weighted Composite Scores",
      "inputs": {
        "normalized_scores": "from_step_7",
        "criteria_list": "from_step_1"
      },
      "outputs": {
        "composite_scores": "comp_scores",
        "score_gaps": "gaps",
        "tie_breaking_criteria": "tie_breakers"
      },
      "parallel_group": 4,
      "description": "Calculate weighted composite scores and rank cities by overall score."
    },
    {
      "id": "step_9",
      "skill_name": "relocation-comparator",
      "phase": "Phase 9: Generate Comparison Matrix, Visualizations, and Validation Checklist",
      "inputs": {
        "composite_scores": "from_step_8",
        "normalized_scores": "from_step_7",
        "criteria_list": "from_step_1",
        "city_list": "from_step_2"
      },
      "outputs": {
        "comparison_matrix": "matrix",
        "city_summaries": "summaries",
        "ranked_list": "rankings",
        "validation_checklist": "checklist"
      },
      "parallel_group": 5,
      "description": "Build detailed comparison matrix, city summaries with strengths/weaknesses, and in-person validation checklist."
    },
    {
      "id": "step_10",
      "skill_name": "relocation-comparator",
      "phase": "Phase 10: Sensitivity Analysis, Trade-Offs, and Final Recommendation",
      "inputs": {
        "composite_scores": "from_step_8",
        "normalized_scores": "from_step_7",
        "criteria_list": "from_step_1",
        "city_summaries": "from_step_9"
      },
      "outputs": {
        "sensitivity_scenarios": "sensitivity",
        "trade_offs": "tradeoffs",
        "close_competitors": "competitors",
        "extreme_differences": "extremes",
        "recommendation": "final_rec"
      },
      "parallel_group": 6,
      "description": "Perform sensitivity analysis, identify trade-offs and close competitors, and generate final recommendation with trial period guidance."
    }
  ],
