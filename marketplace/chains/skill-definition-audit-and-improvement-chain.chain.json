{
  "name": "Skill Definition Audit and Improvement Chain",
  "description": "Audits a skill definition against quality standards, identifies gaps and issues, and produces an improved skill definition with enhanced clarity, completeness, and error handling.",
  "steps": [
    {
      "id": "step_1_intake_audit",
      "skill_name": "audit-skill-definition",
      "inputs": {
        "skill_definition": "improved_skill from input context",
        "audit_criteria": "section_inventory, section_scores, quality_gates, error_handling, exit_criteria"
      },
      "outputs": {
        "audit_report": "section_inventory, section_scores, total_score, critical_issues"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2_gap_analysis",
      "skill_name": "identify-skill-gaps",
      "inputs": {
        "audit_report": "from step_1_intake_audit",
        "skill_definition": "improved_skill from input context"
      },
      "outputs": {
        "gap_analysis": "missing_sections, incomplete_sections, vague_criteria, error_handling_gaps"
      },
      "parallel_group": 1
    },
    {
      "id": "step_3_improvement_planning",
      "skill_name": "plan-skill-improvements",
      "inputs": {
        "audit_report": "from step_1_intake_audit",
        "gap_analysis": "from step_2_gap_analysis",
        "change_log": "from input context"
      },
      "outputs": {
        "improvement_plan": "prioritized_fixes, enhancement_recommendations, structural_changes"
      },
      "parallel_group": 2
    },
    {
      "id": "step_4_apply_fixes",
      "skill_name": "apply-skill-fixes",
      "inputs": {
        "improvement_plan": "from step_3_improvement_planning",
        "skill_definition": "improved_skill from input context",
        "change_log": "from input context"
      },
      "outputs": {
        "improved_skill_definition": "updated skill with all fixes applied"
      },
      "parallel_group": 3
    },
    {
      "id": "step_5_validate_improved",
      "skill_name": "validate-skill-definition",
      "inputs": {
        "skill_definition": "from step_4_apply_fixes",
        "validation_criteria": "no_cycles, all_phases_complete, quality_gates_testable, error_handling_comprehensive"
      },
      "outputs": {
        "validation_report": "passes_all_checks, remaining_issues, confidence_score"
      },
      "parallel_group": 4
    },
    {
      "id": "step_6_generate_documentation",
      "skill_name": "generate-skill-documentation",
      "inputs": {
        "improved_skill_definition": "from step_4_apply_fixes",
        "validation_report": "from step_5_validate_improved",
        "change_log": "from input context"
      },
      "outputs": {
        "skill_documentation": "markdown_format, usage_guide, examples"
      },
      "parallel_group": 5
    },
    {
      "id": "step_7_export_final",
      "skill_name": "export-skill-definition",
      "inputs": {
        "improved_skill_definition": "from step_4_apply_fixes",
        "skill_documentation": "from step_6_generate_documentation",
        "validation_report": "from step_5_validate_improved"
      },
      "outputs": {
        "final_skill_json": "complete skill definition ready for deployment",
        "deployment_checklist": "verification steps before production use"
      },
      "parallel_group": 6
    }
  ],
  "edges": [
    {
      "from_step": "step_1_intake_audit",
      "to_step": "step_3_improvement_planning",
      "data_type": "audit_report",
      "field_mapping": "audit_report \u2192 audit_report"
    },
    {
      "from_step": "step_2_gap_analysis",
      "to_step": "step_3_improvement_planning",
      "data_type": "gap_analysis",
      "field_mapping": "gap_analysis \u2192 gap_analysis"
    },
    {
      "from_step": "step_3_improvement_planning",
      "to_step": "step_4_apply_fixes",
      "data_type": "improvement_plan",
      "field_mapping": "improvement_plan \u2192 improvement_plan"
    },
    {
      "from_step": "step_4_apply_fixes",
      "to_step": "step_5_validate_improved",
      "data_type": "improved_skill_definition",
      "field_mapping": "improved_skill_definition \u2192 skill_definition"
    },
    {
      "from_step": "step_5_validate_improved",
      "to_step": "step_6_generate_documentation",
      "data_type": "validation_report",
      "field_mapping": "validation_report \u2192 validation_report"
    },
    {
      "from_step": "step_4_apply_fixes",
      "to_step": "step_6_generate_documentation",
      "data_type": "improved_skill_definition",
      "field_mapping": "improved_skill_definition \u2192 improved_skill_definition"
    },
    {
      "from_step": "step_6_generate_documentation",
      "to_step": "step_7_export_final",
      "data_type": "skill_documentation",
      "field_mapping": "skill_documentation \u2192 skill_documentation"
    },
    {
      "from_step": "step_5_validate_improved",
      "to_step": "step_7_export_final",
      "data_type": "validation_report",
      "field_mapping": "validation_report \u2192 validation_report"
    },
    {
      "from_step": "step_4_apply_fixes",
      "to_step": "step_7_export_final",
      "data_type": "improved_skill_definition",
      "field_mapping": "improved_skill_definition \u2192 improved_skill_definition"
    }
  ],
  "entry_inputs": [
    "skill_definition (Training Program Builder)",
    "audit_report (from audit phase)",
    "change_log (improvement tracking)"
  ],
  "terminal_outputs": [
    "final_skill_json (production-ready skill definition)",
    "deployment_checklist (verification steps)"
  ],
  "parallel_groups": [
    [
      "step_1_intake_audit",
      "step_2_gap_analysis"
    ],
    [
      "step_3_improvement_planning"
    ],
    [
      "step_4_apply_fixes"
    ],
    [
      "step_5_validate_improved"
    ],
    [
      "step_6_generate_documentation"
    ],
    [
      "step_7_export_final"
    ]
  ],
  "estimated_cost": 42,
  "critical_path": [
    "step_1_intake_audit",
    "step_3_improvement_planning",
    "step_4_apply_fixes",
    "step_5_validate_improved",
    "step_6_generate_documentation",
    "step_7_export_final"
  ]
}