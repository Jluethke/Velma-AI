{
  "name": "skill-improvement-pipeline",
  "description": "Takes an audit report of a skill definition and produces an improved version with higher quality scores across all dimensions.",
  "steps": [
    {
      "id": "step_1_analyze_audit",
      "skill_name": "audit-analyzer",
      "inputs": {
        "audit_report": "audit_report"
      },
      "outputs": {
        "issues_prioritized": "issues_list",
        "quality_gaps": "gap_analysis",
        "improvement_opportunities": "opportunities"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2_identify_fixes",
      "skill_name": "fix-identifier",
      "inputs": {
        "issues_list": "step_1_analyze_audit.issues_prioritized",
        "gap_analysis": "step_1_analyze_audit.quality_gaps",
        "skill_definition": "improved_skill"
      },
      "outputs": {
        "fix_strategies": "strategies",
        "implementation_plan": "plan"
      },
      "parallel_group": 2
    },
    {
      "id": "step_3_refactor_phases",
      "skill_name": "phase-refactorer",
      "inputs": {
        "original_phases": "improved_skill",
        "quality_issues": "step_1_analyze_audit.issues_prioritized",
        "improvement_opportunities": "step_1_analyze_audit.improvement_opportunities"
      },
      "outputs": {
        "refactored_phases": "phases",
        "complexity_reduction": "metrics"
      },
      "parallel_group": 2
    },
    {
      "id": "step_4_enhance_inputs",
      "skill_name": "input-enhancer",
      "inputs": {
        "current_inputs": "improved_skill",
        "missing_inputs_identified": "step_1_analyze_audit.quality_gaps"
      },
      "outputs": {
        "enhanced_inputs": "inputs_list"
      },
      "parallel_group": 2
    },
    {
      "id": "step_5_enhance_outputs",
      "skill_name": "output-enhancer",
      "inputs": {
        "current_outputs": "improved_skill",
        "missing_outputs_identified": "step_1_analyze_audit.quality_gaps"
      },
      "outputs": {
        "enhanced_outputs": "outputs_list"
      },
      "parallel_group": 2
    },
    {
      "id": "step_6_strengthen_gates",
      "skill_name": "quality-gate-strengthener",
      "inputs": {
        "current_gates": "improved_skill",
        "vague_gates_identified": "step_1_analyze_audit.issues_prioritized"
      },
      "outputs": {
        "measurable_gates": "gates_list"
      },
      "parallel_group": 2
    },
    {
      "id": "step_7_expand_error_handling",
      "skill_name": "error-handler-expander",
      "inputs": {
        "current_error_handling": "improved_skill",
        "missing_scenarios": "step_1_analyze_audit.quality_gaps"
      },
      "outputs": {
        "comprehensive_error_handling": "error_table"
      },
      "parallel_group": 2
    },
    {
      "id": "step_8_integrate_improvements",
      "skill_name": "improvement-integrator",
      "inputs": {
        "refactored_phases": "step_3_refactor_phases.refactored_phases",
        "enhanced_inputs": "step_4_enhance_inputs.enhanced_inputs",
        "enhanced_outputs": "step_5_enhance_outputs.enhanced_outputs",
        "measurable_gates": "step_6_strengthen_gates.measurable_gates",
        "error_handling": "step_7_expand_error_handling.comprehensive_error_handling",
        "original_skill": "improved_skill"
      },
      "outputs": {
        "integrated_skill_definition": "skill_def"
      },
      "parallel_group": 3
    },
    {
      "id": "step_9_validate_improvements",
      "skill_name": "improvement-validator",
      "inputs": {
        "improved_skill": "step_8_integrate_improvements.integrated_skill_definition",
        "original_audit": "audit_report"
      },
      "outputs": {
        "validation_report": "report",
        "quality_score_comparison": "scores"
      },
      "parallel_group": 4
    },
    {
      "id": "step_10_generate_changelog",
      "skill_name": "changelog-generator",
      "inputs": {
        "original_skill": "improved_skill",
        "improved_skill": "step_8_integrate_improvements.integrated_skill_definition",
        "fixes_applied": "step_2_identify_fixes.fix_strategies"
      },
      "outputs": {
        "detailed_changelog": "changelog",
        "before_after_comparison": "comparison"
      },
      "parallel_group": 4
    }
  ],
  "edges": [
    {
      "from_step": "step_1_analyze_audit",
      "to_step": "step_2_identify_fixes",
      "data_type": "quality_analysis",
      "field_mapping": {
        "issues_prioritized": "issues_list",
        "quality_gaps": "gap_analysis",
        "improvement_opportunities": "opportunities"
      }
    },
    {
      "from_step": "step_1_analyze_audit",
      "to_step": "step_3_refactor_phases",
      "data_type": "quality_analysis",
      "field_mapping": {
        "issues_prioritized": "quality_issues",
        "improvement_opportunities": "improvement_opportunities"
      }
    },
    {
      "from_step": "step_1_analyze_audit",
      "to_step": "step_4_enhance_inputs",
      "data_type": "quality_analysis",
      "field_mapping": {
        "quality_gaps": "missing_inputs_identified"
      }
    },
    {
      "from_step": "step_1_analyze_audit",
      "to_step": "step_5_enhance_outputs",
      "data_type": "quality_analysis",
      "field_mapping": {
        "quality_gaps": "missing_outputs_identified"
      }
    },
    {
      "from_step": "step_1_analyze_audit",
      "to_step": "step_6_strengthen_gates",
      "data_type": "quality_analysis",
      "field_mapping": {
        "issues_prioritized": "vague_gates_identified"
      }
    },
    {
      "from_step": "step_1_analyze_audit",
      "to_step": "step_7_expand_error_handling",
      "data_type": "quality_analysis",
      "field_mapping": {
        "quality_gaps": "missing_scenarios"
      }
    },
    {
      "from_step": "step_3_refactor_phases",
      "to_step": "step_8_integrate_improvements",
      "data_type": "refactored_content",
      "field_mapping": {
        "refactored_phases": "refactored_phases"
      }
    },
    {
      "from_step": "step_4_enhance_inputs",
      "to_step": "step_8_integrate_improvements",
      "data_type": "enhanced_content",
      "field_mapping": {
        "enhanced_inputs": "enhanced_inputs"
      }
    },
    {
      "from_step": "step_5_enhance_outputs",
      "to_step": "step_8_integrate_improvements",
      "data_type": "enhanced_content",
      "field_mapping": {
        "enhanced_outputs": "enhanced_outputs"
      }
    },
    {
      "from_step": "step_6_strengthen_gates",
      "to_step": "step_8_integrate_improvements",
      "data_type": "enhanced_content",
      "field_mapping": {
        "measurable_gates": "measurable_gates"
      }
    },
    {
      "from_step": "step_7_expand_error_handling",
      "to_step": "step_8_integrate_improvements",
      "data_type": "enhanced_content",
      "field_mapping": {
        "comprehensive_error_handling": "error_handling"
      }
    },
    {
      "from_step": "step_8_integrate_improvements",
      "to_step": "step_9_validate_improvements",
      "data_type": "skill_definition",
      "field_mapping": {
        "integrated_skill_definition": "improved_skill"
      }
    },
    {
      "from_step": "step_8_integrate_improvements",
      "to_step": "step_10_generate_changelog",
      "data_type": "skill_definition",
      "field_mapping": {
        "integrated_skill_definition": "improved_skill"
      }
    }
  ],
  "entry_inputs": [
    "audit_report",
    "improved_skill",
    "workflow_description",
    "skill_name_hint"
  ],
  "terminal_outputs": [
    "integrated_skill_definition",
    "validation_report",
    "quality_score_comparison",
    "detailed_changelog",
    "before_after_comparison"
  ],
  "parallel_groups": [
    [
      "step_1_analyze_audit"
    ],
    [
      "step_2_identify_fixes",
      "step_3_refactor_phases",
      "step_4_enhance_inputs",
      "step_5_enhance_outputs",
      "step_6_strengthen_gates",
      "step_7_expand_error_handling"
    ],
    [
      "step_8_integrate_improvements"
    ],
    [
      "step_9_validate_improvements",
      "step_10_generate_changelog"
    ]
  ],
  "estimated_cost": 10,
  "critical_path": [
    "step_1_analyze_audit",
    "step_3_refactor_phases",
    "step_8_integrate_improvements",
    "step_9_validate_improvements"
  ]
}