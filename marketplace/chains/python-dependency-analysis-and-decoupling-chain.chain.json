{
  "name": "Python Dependency Analysis and Decoupling Chain",
  "description": "Analyze a Python codebase to extract module dependencies, detect circular imports, identify coupling hotspots, and generate decoupling recommendations with visual dependency graphs.",
  "steps": [
    {
      "id": "step_1_discovery",
      "skill_name": "Dependency Mapper",
      "inputs": {
        "codebase_root": "{{codebase_root}}",
        "exclude_patterns": "{{exclude_patterns}}",
        "include_stdlib": "{{include_stdlib}}",
        "include_third_party": "{{include_third_party}}",
        "output_format": "{{output_format}}",
        "coupling_threshold": "{{coupling_threshold}}"
      },
      "outputs": {
        "modules_discovered": "modules_discovered",
        "import_graph": "import_graph",
        "circular_dependencies": "circular_dependencies",
        "coupling_metrics": "coupling_metrics",
        "high_coupling_modules": "high_coupling_modules",
        "decoupling_recommendations": "decoupling_recommendations",
        "graph_visualization": "graph_visualization",
        "report_summary": "report_summary"
      },
      "parallel_group": 1,
      "description": "Execute the Dependency Mapper skill to analyze the codebase and produce all analysis outputs."
    }
  ],
  "edges": [],
  "entry_inputs": {
    "codebase_root": {
      "type": "string",
      "required": true,
      "description": "Absolute or relative path to the root directory of the Python codebase to analyze."
    },
    "exclude_patterns": {
      "type": "array",
      "required": false,
      "description": "List of glob patterns (POSIX fnmatch syntax) for directories/files to skip.",
      "default": [
        "venv/",
        ".venv/",
        "__pycache__/",
        ".git/",
        "node_modules/"
      ]
    },
    "include_stdlib": {
      "type": "boolean",
      "required": false,
      "description": "Whether to include Python standard library imports in the graph.",
      "default": false
    },
    "include_third_party": {
      "type": "boolean",
      "required": false,
      "description": "Whether to include third-party package imports in the graph.",
      "default": false
    },
    "output_format": {
      "type": "string",
      "required": false,
      "description": "Format for graph output: 'dot', 'json', or 'both'.",
      "default": "json"
    },
    "coupling_threshold": {
      "type": "number",
      "required": false,
      "description": "Minimum number of dependencies to flag a module as high-coupling.",
      "default": 5
    }
  },
  "terminal_outputs": [
    "modules_discovered",
    "import_graph",
    "circular_dependencies",
    "coupling_metrics",
    "high_coupling_modules",
    "decoupling_recommendations",
    "graph_visualization",
    "report_summary"
  ],
  "parallel_groups": [
    [
      "step_1_discovery"
    ]
  ],
  "estimated_cost": 1,
  "critical_path": [
    "step_1_discovery"
  ]
}