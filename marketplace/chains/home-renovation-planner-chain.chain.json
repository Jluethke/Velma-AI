{
  "name": "home-renovation-planner-chain",
  "description": "Convert a renovation idea into a fully scoped, budgeted, and scheduled project plan with contractor selection, documented decision rationale, and post-project closeout procedures.",
  "steps": [
    {
      "id": "step_1_site_inspection",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 0: Pre-Project Site Inspection",
      "inputs": {
        "property_details": "from_entry",
        "renovation_idea": "from_entry"
      },
      "outputs": [
        "site_inspection_report",
        "scope_revisions_needed",
        "revised_budget_impact"
      ],
      "parallel_group": "group_1"
    },
    {
      "id": "step_2_scope_definition",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 1: Scope Definition",
      "inputs": {
        "renovation_idea": "from_entry",
        "property_details": "from_entry",
        "desired_outcomes": "from_entry",
        "budget_ceiling": "from_entry",
        "timeline_constraint": "from_entry",
        "site_inspection_report": "from_step_1_site_inspection"
      },
      "outputs": [
        "scope_statement",
        "scope_complexity",
        "constraints_list",
        "scope_reduction_tree"
      ],
      "parallel_group": "group_2"
    },
    {
      "id": "step_3_contractor_research",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 2: Contractor Research and Evaluation Criteria",
      "inputs": {
        "scope_statement": "from_step_2_scope_definition",
        "budget_ceiling": "from_entry",
        "timeline_constraint": "from_entry"
      },
      "outputs": [
        "contractor_candidates",
        "evaluation_rubric"
      ],
      "parallel_group": "group_2"
    },
    {
      "id": "step_4_bid_collection",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 3: Bid Collection and Comparison",
      "inputs": {
        "contractor_candidates": "from_step_3_contractor_research",
        "evaluation_rubric": "from_step_3_contractor_research",
        "scope_statement": "from_step_2_scope_definition"
      },
      "outputs": [
        "bid_comparison_matrix",
        "bids_complete",
        "bid_clarifications"
      ],
      "parallel_group": "group_3"
    },
    {
      "id": "step_5_contractor_evaluation",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 4: Contractor Evaluation and Selection",
      "inputs": {
        "bid_comparison_matrix": "from_step_4_bid_collection",
        "evaluation_rubric": "from_step_3_contractor_research",
        "contractor_candidates": "from_step_3_contractor_research"
      },
      "outputs": [
        "evaluation_results",
        "reference_feedback",
        "selected_contractor",
        "stakeholder_approval_status"
      ],
      "parallel_group": "group_4"
    },
    {
      "id": "step_6_budget_breakdown",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 5: Budget Breakdown",
      "inputs": {
        "selected_contractor": "from_step_5_contractor_evaluation",
        "budget_ceiling": "from_entry",
        "contingency_philosophy": "from_entry",
        "site_inspection_report": "from_step_1_site_inspection",
        "scope_reduction_tree": "from_step_2_scope_definition"
      },
      "outputs": [
        "budget_breakdown",
        "budget_status",
        "budget_assumptions",
        "scope_reduction_applied",
        "contingency_allocation_detail"
      ],
      "parallel_group": "group_5"
    },
    {
      "id": "step_7_timeline_scheduling",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 6: Timeline and Scheduling",
      "inputs": {
        "selected_contractor": "from_step_5_contractor_evaluation",
        "timeline_constraint": "from_entry",
        "scope_complexity": "from_step_2_scope_definition",
        "contingency_philosophy": "from_entry"
      },
      "outputs": [
        "project_timeline",
        "critical_path",
        "timeline_status",
        "seasonal_factors",
        "buffer_rationale"
      ],
      "parallel_group": "group_5"
    },
    {
      "id": "step_8_decision_documentation",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 7: Decision Documentation",
      "inputs": {
        "selected_contractor": "from_step_5_contractor_evaluation",
        "budget_breakdown": "from_step_6_budget_breakdown",
        "project_timeline": "from_step_7_timeline_scheduling",
        "evaluation_results": "from_step_5_contractor_evaluation",
        "stakeholders": "from_entry"
      },
      "outputs": [
        "decision_memo",
        "stakeholder_approvals",
        "approval_status"
      ],
      "parallel_group": "group_6"
    },
    {
      "id": "step_9_contract_finalization",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 8: Contract Finalization and Kickoff",
      "inputs": {
        "decision_memo": "from_step_8_decision_documentation",
        "selected_contractor": "from_step_5_contractor_evaluation",
        "budget_breakdown": "from_step_6_budget_breakdown",
        "project_timeline": "from_step_7_timeline_scheduling",
        "approval_status": "from_step_8_decision_documentation"
      },
      "outputs": [
        "project_contract",
        "change_order_template",
        "kickoff_checklist",
        "communication_protocol",
        "contingency_tracking_log_initialized",
        "contract_signed"
      ],
      "parallel_group": "group_7"
    },
    {
      "id": "step_10_project_execution",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 9: Project Execution and Change Management",
      "inputs": {
        "project_contract": "from_step_9_contract_finalization",
        "communication_protocol": "from_step_9_contract_finalization",
        "change_order_template": "from_step_9_contract_finalization",
        "contingency_tracking_log_initialized": "from_step_9_contract_finalization",
        "project_timeline": "from_step_7_timeline_scheduling"
      },
      "outputs": [
        "weekly_progress_reports",
        "change_orders_issued",
        "contingency_tracking_log",
        "inspection_reports",
        "issues_log"
      ],
      "parallel_group": "group_8"
    },
    {
      "id": "step_11_project_closeout",
      "skill_name": "Home Renovation Project Planner",
      "phase": "Phase 10: Project Closeout",
      "inputs": {
        "weekly_progress_reports": "from_step_10_project_execution",
        "inspection_reports": "from_step_10_project_execution",
        "contingency_tracking_log": "from_step_10_project_execution",
        "selected_contractor": "from_step_5_contractor_evaluation"
      },
      "outputs": [
        "final_walkthrough_report",
        "punch_list",
        "punch_list_completion_status",
        "warranty_documentation",
        "lien_waivers",
        "final_payment_processed",
        "lessons_learned",
        "project_archive_location",
        "project_status"
      ],
      "parallel_group": "group_9"
    }
  ],
