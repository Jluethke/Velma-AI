      "description": "Plain-English description of the side hustle concept",
      "required": true
    },
    {
      "name": "target_market",
      "type": "string",
      "description": "Specific customer segment (not 'everyone')",
      "required": true
    },
    {
      "name": "revenue_model",
      "type": "string",
