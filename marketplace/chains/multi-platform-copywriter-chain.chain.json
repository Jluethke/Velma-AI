{
  "name": "multi-platform-copywriter-chain",
  "description": "Convert a product description into 10 optimized copy variations for Twitter, LinkedIn, email, landing page, app store, Facebook, Instagram, YouTube, and SMS with quality scoring.",
  "steps": [
    {
      "id": "step_1_parse_extract",
      "skill_name": "multi-platform-copywriter",
      "phase": "Phase 1: Parse & Extract Messaging",
      "inputs": {
        "product_description": "from_entry",
        "brand_voice_guidelines": "from_entry_optional",
        "keyword_focus": "from_entry_optional"
      },
      "outputs": {
        "messaging_blueprint": "messaging_blueprint"
      },
      "parallel_group": 1
    },
    {
      "id": "step_2_social_variations",
      "skill_name": "multi-platform-copywriter",
      "phase": "Phase 2: Generate Social & Short-Form Variations",
      "inputs": {
        "messaging_blueprint": "from_step_1_parse_extract",
        "include_ctas": "from_entry_optional"
      },
      "outputs": {
        "social_variations": "social_variations"
      },
      "parallel_group": 2,
      "depends_on": [
        "step_1_parse_extract"
      ]
    },
    {
      "id": "step_3_email_landing",
      "skill_name": "multi-platform-copywriter",
      "phase": "Phase 3: Generate Email & Landing Page Variations",
      "inputs": {
        "messaging_blueprint": "from_step_1_parse_extract"
      },
      "outputs": {
        "email_variations": "email_variations",
        "landing_page_variations": "landing_page_variations"
      },
      "parallel_group": 2,
      "depends_on": [
        "step_1_parse_extract"
      ]
    },
    {
      "id": "step_4_app_youtube",
      "skill_name": "multi-platform-copywriter",
      "phase": "Phase 4: Generate App Store & Video Variations",
      "inputs": {
        "messaging_blueprint": "from_step_1_parse_extract",
        "keyword_focus": "from_entry_optional"
      },
      "outputs": {
        "app_store_variations": "app_store_variations",
        "youtube_variations": "youtube_variations"
      },
      "parallel_group": 2,
      "depends_on": [
        "step_1_parse_extract"
      ]
    },
    {
      "id": "step_5_compile_validate",
      "skill_name": "multi-platform-copywriter",
      "phase": "Phase 5: Compile, Validate & Score",
      "inputs": {
        "social_variations": "from_step_2_social_variations",
        "email_variations": "from_step_3_email_landing",
        "landing_page_variations": "from_step_3_email_landing",
        "app_store_variations": "from_step_4_app_youtube",
        "youtube_variations": "from_step_4_app_youtube",
        "messaging_blueprint": "from_step_1_parse_extract",
        "brand_voice_guidelines": "from_entry_optional"
      },
      "outputs": {
        "variations": "variations",
        "metadata": "metadata",
        "quality_report": "quality_report"
      },
      "parallel_group": 3,
      "depends_on": [
        "step_2_social_variations",
        "step_3_email_landing",
        "step_4_app_youtube"
      ]
    }
  ],
  "edges": [
    {
      "from_step": "entry",
      "to_step": "step_1_parse_extract",
      "data_type": "product_description, brand_voice_guidelines, keyword_focus",
      "field_mapping": {
        "product_description": "product_description",
        "brand_voice_guidelines": "brand_voice_guidelines",
        "keyword_focus": "keyword_focus"
      }
    },
    {
      "from_step": "step_1_parse_extract",
      "to_step": "step_2_social_variations",
      "data_type": "messaging_blueprint",
      "field_mapping": {
        "messaging_blueprint": "messaging_blueprint"
      }
    },
    {
      "from_step": "step_1_parse_extract",
      "to_step": "step_3_email_landing",
      "data_type": "messaging_blueprint",
      "field_mapping": {
        "messaging_blueprint": "messaging_blueprint"
      }
    },
    {
      "from_step": "step_1_parse_extract",
      "to_step": "step_4_app_youtube",
      "data_type": "messaging_blueprint, keyword_focus",
      "field_mapping": {
        "messaging_blueprint": "messaging_blueprint",
        "keyword_focus": "keyword_focus"
      }
    },
    {
      "from_step": "step_2_social_variations",
      "to_step": "step_5_compile_validate",
      "data_type": "social_variations",
      "field_mapping": {
        "social_variations": "social_variations"
      }
    },
    {
      "from_step": "step_3_email_landing",
      "to_step": "step_5_compile_validate",
      "data_type": "email_variations, landing_page_variations",
      "field_mapping": {
        "email_variations": "email_variations",
        "landing_page_variations": "landing_page_variations"
      }
    },
    {
      "from_step": "step_4_app_youtube",
      "to_step": "step_5_compile_validate",
      "data_type": "app_store_variations, youtube_variations",
      "field_mapping": {
        "app_store_variations": "app_store_variations",
        "youtube_variations": "youtube_variations"
      }
    },
    {
      "from_step": "step_1_parse_extract",
      "to_step": "step_5_compile_validate",
      "data_type": "messaging_blueprint",
      "field_mapping": {
        "messaging_blueprint": "messaging_blueprint"
      }
    }
  ],
  "entry_inputs": [
    {
      "name": "product_description",
      "type": "string",
      "required": true,
      "description": "The original product or service description (minimum 50 characters)"
    },
    {
      "name": "brand_voice_guidelines",
      "type": "string",
      "required": false,
      "description": "Tone, personality, and messaging rules (tone, vocabulary level, key values)"
    },
    {
      "name": "target_audience_override",
      "type": "string",
      "required": false,
      "description": "Override audience inferred from product description"
    },
    {
      "name": "include_ctas",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "Whether to include explicit calls-to-action in each variation"
    },
    {
      "name": "keyword_focus",
      "type": "array",
      "required": false,
      "description": "SEO or marketing keywords to emphasize (maximum 8 keywords)"
    }
  ],
  "terminal_outputs": [
    {
      "name": "variations",
      "type": "object",
      "description": "All 10 platform-specific copy variations with character/word counts and performance notes"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Product name, target audience, brand voice used, keywords emphasized, generation timestamp"
    },
    {
      "name": "quality_report",
      "type": "object",
      "description": "Tone consistency score, brand alignment score, platform compliance flags, consistency notes"
    }
  ],
  "parallel_groups": [
    [
      "step_1_parse_extract"
    ],
    [
      "step_2_social_variations",
      "step_3_email_landing",
      "step_4_app_youtube"
    ],
    [
      "step_5_compile_validate"
    ]
  ],
  "estimated_cost": 1,
  "critical_path": [
    "step_1_parse_extract",
    "step_2_social_variations",
    "step_5_compile_validate"
  ],
  "critical_path_length": 3
}