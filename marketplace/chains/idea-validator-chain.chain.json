{
  "name": "idea-validator-chain",
  "description": "Validate a business idea through 8 sequential phases: idea definition, customer problem validation, market sizing, competitive analysis, UVP assessment, founder-market fit evaluation, validation synthesis, and go/no-go recommendation.",
  "steps": [
    {
      "id": "step_1_idea_definition",
      "skill_name": "idea-validator",
      "phase": 1,
      "inputs": {
        "business_idea": "from_user_input",
        "market_context": "from_user_input_optional",
        "research_depth": "from_user_input_optional_default_standard"
      },
      "outputs": {
        "idea_statement": "structured_definition_with_problem_solution_customer_assumptions"
      },
      "parallel_group": "group_1_entry"
    },
    {
      "id": "step_2_customer_validation",
      "skill_name": "idea-validator",
      "phase": 2,
      "inputs": {
        "idea_statement": "from_step_1_idea_definition",
        "research_depth": "from_user_input_optional_default_standard"
      },
      "outputs": {
        "customer_validation_report": "interviews_problem_confirmation_acuity_willingness_to_pay"
      },
      "parallel_group": "group_2_sequential_after_1"
    },
    {
      "id": "step_3_market_analysis",
      "skill_name": "idea-validator",
      "phase": 3,
      "inputs": {
        "idea_statement": "from_step_1_idea_definition",
        "customer_validation_report": "from_step_2_customer_validation"
      },
      "outputs": {
        "market_analysis": "TAM_SAM_SOM_maturity_timing_growth_trends"
      },
      "parallel_group": "group_3_sequential_after_2"
    },
    {
      "id": "step_4_competitor_analysis",
      "skill_name": "idea-validator",
      "phase": 4,
      "inputs": {
        "idea_statement": "from_step_1_idea_definition",
        "market_analysis": "from_step_3_market_analysis"
      },
      "outputs": {
        "competitor_analysis": "direct_indirect_competitors_feature_matrix_market_concentration_white_space"
      },
      "parallel_group": "group_4_parallel_with_step_3"
    },
    {
      "id": "step_5_uvp_assessment",
      "skill_name": "idea-validator",
      "phase": 5,
      "inputs": {
        "idea_statement": "from_step_1_idea_definition",
        "competitor_analysis": "from_step_4_competitor_analysis",
        "customer_validation_report": "from_step_2_customer_validation"
      },
      "outputs": {
        "uvp_assessment": "uvp_statement_differentiation_defensibility_business_model_viability_unit_economics"
      },
      "parallel_group": "group_5_sequential_after_4"
    },
    {
      "id": "step_6_founder_market_fit",
      "skill_name": "idea-validator",
      "phase": 6,
      "inputs": {
        "idea_statement": "from_step_1_idea_definition",
        "uvp_assessment": "from_step_5_uvp_assessment"
      },
      "outputs": {
        "founder_market_fit_assessment": "team_capability_passion_gaps_founder_market_fit_score_risks_opportunities"
      },
      "parallel_group": "group_6_sequential_after_5"
    },
    {
      "id": "step_7_validation_synthesis",
      "skill_name": "idea-validator",
      "phase": 7,
      "inputs": {
        "idea_statement": "from_step_1_idea_definition",
        "customer_validation_report": "from_step_2_customer_validation",
        "market_analysis": "from_step_3_market_analysis",
        "competitor_analysis": "from_step_4_competitor_analysis",
        "uvp_assessment": "from_step_5_uvp_assessment",
        "founder_market_fit_assessment": "from_step_6_founder_market_fit"
      },
      "outputs": {
        "validation_report": "rubric_scores_total_score_recommendation_category_rationale_next_steps_conditions_pivot_tree_risks"
      },
      "parallel_group": "group_7_sequential_after_6"
    },
    {
      "id": "step_8_recommendation",
      "skill_name": "idea-validator",
      "phase": 8,
      "inputs": {
        "validation_report": "from_step_7_validation_synthesis",
        "research_depth": "from_user_input_optional_default_standard"
      },
      "outputs": {
        "recommendation": "decision_executive_summary_rationale_next_steps_conditions_change_requirements_dependencies_timeline"
      },
      "parallel_group": "group_8_terminal"
    }
  ],
  "edges": [
    {
      "from_step": "step_1_idea_definition",
      "to_step": "step_2_customer_validation",
      "data_type": "idea_statement",
      "field_mapping": "idea_statement.problem_statement, idea_statement.proposed_solution, idea_statement.target_customer, idea_statement.scope"
    },
    {
      "from_step": "step_2_customer_validation",
      "to_step": "step_3_market_analysis",
      "data_type": "customer_validation_report",
      "field_mapping": "customer_validation_report.problem_confirmation_rate, customer_validation_report.average_acuity_score, customer_validation_report.target_segment_interviewed"
    },
    {
      "from_step": "step_1_idea_definition",
      "to_step": "step_3_market_analysis",
      "data_type": "idea_statement",
      "field_mapping": "idea_statement.target_customer, idea_statement.revenue_model"
    },
    {
      "from_step": "step_1_idea_definition",
      "to_step": "step_4_competitor_analysis",
      "data_type": "idea_statement",
      "field_mapping": "idea_statement.proposed_solution, idea_statement.target_customer"
    },
    {
      "from_step": "step_3_market_analysis",
      "to_step": "step_4_competitor_analysis",
      "data_type": "market_analysis",
      "field_mapping": "market_analysis.market_maturity, market_analysis.SAM"
    },
    {
      "from_step": "step_4_competitor_analysis",
      "to_step": "step_5_uvp_assessment",
      "data_type": "competitor_analysis",
      "field_mapping": "competitor_analysis.direct_competitors, competitor_analysis.feature_comparison_matrix, competitor_analysis.white_space_identified"
    },
    {
      "from_step": "step_2_customer_validation",
      "to_step": "step_5_uvp_assessment",
      "data_type": "customer_validation_report",
      "field_mapping": "customer_validation_report.key_quotes, customer_validation_report.average_willingness_to_pay"
    },
    {
      "from_step": "step_5_uvp_assessment",
      "to_step": "step_6_founder_market_fit",
      "data_type": "uvp_assessment",
      "field_mapping": "uvp_assessment.business_model_viability, uvp_assessment.unit_economics, uvp_assessment.defensibility_score"
    },
    {
      "from_step": "step_6_founder_market_fit",
      "to_step": "step_7_validation_synthesis",
      "data_type": "founder_market_fit_assessment",
      "field_mapping": "founder_market_fit_assessment.founder_market_fit_score, founder_market_fit_assessment.team_capability_score, founder_market_fit_assessment.risk_assessment"
    },
    {
      "from_step": "step_3_market_analysis",
      "to_step": "step_7_validation_synthesis",
      "data_type": "market_analysis",
      "field_mapping": "market_analysis.TAM, market_analysis.SAM, market_analysis.market_maturity"
    },
    {
      "from_step": "step_2_customer_validation",
      "to_step": "step_7_validation_synthesis",
      "data_type": "customer_validation_report",
      "field_mapping": "customer_validation_report.problem_confirmation_rate, customer_validation_report.average_acuity_score"
    },
    {
      "from_step": "step_4_competitor_analysis",
      "to_step": "step_7_validation_synthesis",
      "data_type": "competitor_analysis",
      "field_mapping": "competitor_analysis.white_space_identified, competitor_analysis.market_concentration_assessment"
    },
    {
      "from_step": "step_5_uvp_assessment",
      "to_step": "step_7_validation_synthesis",
      "data_type": "uvp_assessment",
      "field_mapping": "uvp_assessment.defensibility_score, uvp_assessment.unit_economics, uvp_assessment.business_model_viability"
    },
    {
      "from_step": "step_7_validation_synthesis",
      "to_step": "step_8_recommendation",
      "data_type": "validation_report",
      "field_mapping": "validation_report.rubric_scores, validation_report.total_score, validation_report.recommendation_category, validation_report.rationale, validation_report.pivot_decision_tree_if_no_go"
    }
  ],
  "entry_inputs": {
    "business_idea": "string_required",
    "research_depth": "string_optional_default_standard",
    "market_context": "string_optional",
    "competitive_landscape_known": "boolean_optional_default_false"
  },
  "terminal_outputs": [
    "idea_statement",
    "customer_validation_report",
    "market_analysis",
    "competitor_analysis",
    "uvp_assessment",
    "founder_market_fit_assessment",
    "validation_report",
    "recommendation"
  ],
  "parallel_groups": [
    {
      "group_id": "group_1_entry",
      "steps": [
        "step_1_idea_definition"
      ],
      "description": "Entry point: parse and clarify the business idea"
    },
    {
      "group_id": "group_2_sequential_after_1",
      "steps": [
        "step_2_customer_validation"
      ],
      "description": "Validate customer problem acuity and willingness to pay"
    },
    {
      "group_id": "group_3_sequential_after_2",
      "steps": [
        "step_3_market_analysis"
      ],
      "description": "Estimate market size and assess maturity/timing"
    },
    {
      "group_id": "group_4_parallel_with_step_3",
      "steps": [
        "step_4_competitor_analysis"
      ],
      "description": "Analyze competitors in parallel with market analysis (both depend on idea_statement)"
    },
    {
      "group_id": "group_5_sequential_after_4",
      "steps": [
        "step_5_uvp_assessment"
      ],
      "description": "Assess UVP defensibility and business model viability"
    },
    {
      "group_id": "group_6_sequential_after_5",
      "steps": [
        "step_6_founder_market_fit"
      ],
      "description": "Evaluate team capability and founder-market fit"
    },
    {
      "group_id": "group_7_sequential_after_6",
      "steps": [
        "step_7_validation_synthesis"
      ],
      "description": "Synthesize all findings into rubric scores and recommendation"
    },
    {
      "group_id": "group_8_terminal",
      "steps": [
        "step_8_recommendation"
      ],
      "description": "Terminal: produce final go/no-go recommendation with next steps"
    }
  ],
  "estimated_cost": "8_skill_executions_cost_varies_by_research_depth",
  "critical_path": [
    "step_1_idea_definition",
    "step_2_customer_validation",
    "step_3_market_analysis",
    "step_4_competitor_analysis",
    "step_5_uvp_assessment",
    "step_6_founder_market_fit",
    "step_7_validation_synthesis",
    "step_8_recommendation"
  ]
}