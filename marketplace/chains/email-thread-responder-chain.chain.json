        "response_structure": "step_4_map_response.response_structure",
        "tone_profile": "step_3_analyze_tone.tone_analysis",
        "formality_level": "step_3_analyze_tone.formality_level",
        "urgency": "step_3_analyze_tone.urgency",
        "communication_style": "step_3_analyze_tone.communication_style",
        "responder_relationship_clarity": "step_3_analyze_tone.responder_relationship_clarity",
        "length_flag": "step_4_map_response.length_flag",
        "unresolved_points": "step_2_extract_points.unresolved_points"
