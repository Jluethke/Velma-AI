{
  "name": "email-thread-responder-chain",
  "description": "Analyze an email thread, extract unresolved points, and draft a response that matches tone, addresses all points, and moves the conversation toward resolution.",
  "steps": [
    {
      "id": "step_1_parse_thread",
      "skill_name": "Email Thread Parser",
      "inputs": {
        "email_thread": "email_thread",
        "validate_chronological": true
      },
      "outputs": {
        "structured_thread": "structured_thread",
        "participant_map": "participant_map",
        "thread_structure": "thread_structure",
        "thread_metadata": "thread_metadata"
      },
      "parallel_group": "group_1"
    },
    {
      "id": "step_2_extract_points",
      "skill_name": "Email Point Extractor",
      "inputs": {
        "structured_thread": "step_1_parse_thread.structured_thread",
        "participant_map": "step_1_parse_thread.participant_map"
      },
      "outputs": {
        "unresolved_points": "unresolved_points",
        "action_items": "action_items",
        "emotional_trajectory": "emotional_trajectory",
        "must_address_count": "must_address_count"
      },
      "parallel_group": "group_2"
    },
    {
      "id": "step_3_analyze_tone",
      "skill_name": "Email Tone Analyzer",
      "inputs": {
        "structured_thread": "step_1_parse_thread.structured_thread",
        "unresolved_points": "step_2_extract_points.unresolved_points",
        "emotional_trajectory": "step_2_extract_points.emotional_trajectory",
        "responder_role": "responder_role",
        "responder_relationship_to_sender": "responder_relationship_to_sender",
        "tone_override": "tone_override"
      },
      "outputs": {
        "formality_level": "formality_level",
        "urgency": "urgency",
        "communication_style": "communication_style",
        "inferred_resolution_goal": "inferred_resolution_goal",
        "tone_override_applied": "tone_override_applied",
        "responder_relationship_clarity": "responder_relationship_clarity",
        "tone_analysis": "tone_analysis"
      },
      "parallel_group": "group_2"
    },
    {
      "id": "step_4_map_response",
      "skill_name": "Response Mapper",
      "inputs": {
        "unresolved_points": "step_2_extract_points.unresolved_points",
        "must_address_count": "step_2_extract_points.must_address_count",
