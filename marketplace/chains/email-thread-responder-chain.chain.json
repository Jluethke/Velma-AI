        "tone_analysis_final": "tone_analysis",
        "resolution_status_final": "resolution_status",
        "validation_notes_final": "validation_notes",
        "follow_up_suggestion": "follow_up_suggestion",
        "iteration_count": "iteration_count",
        "ready_to_send": "ready_to_send"
      },
      "parallel_group": "group_6"
    }
  ],
