    }
  ],
  "entry_inputs": {
    "improved_skill": "The improved Analogy Bridge Builder skill definition",
    "audit_report": "Quality audit report with section inventory and quality scores",
    "workflow_description": "High-level description of the skill's purpose"
  },
  "terminal_outputs": {
    "final_chain_definition": "Complete .chain.json ready for execution",
    "final_execution_plan": "Human-readable execution plan with timing and parallelism",
    "final_missing_skills": "List of skills needed but not available",
    "final_coverage_report": "Requirements-to-skill mapping and gap analysis"
  },
