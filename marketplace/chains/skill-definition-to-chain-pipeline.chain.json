      "from_step": "step_1_parse_skill_structure",
      "to_step": "step_4_design_execution_dag",
      "data_type": "skill_metadata",
      "field_mapping": "parsed_structure -> input for DAG design"
    },
    {
      "from_step": "step_4_design_execution_dag",
      "to_step": "step_5_identify_parallel_paths",
      "data_type": "execution_dag",
      "field_mapping": "execution_dag -> input for parallelization analysis"
    },
    {
      "from_step": "step_4_design_execution_dag",
      "to_step": "step_6_validate_chain",
      "data_type": "execution_dag",
      "field_mapping": "execution_dag -> input for validation"
    },
    {
      "from_step": "step_5_identify_parallel_paths",
      "to_step": "step_6_validate_chain",
      "data_type": "parallel_groups",
      "field_mapping": "parallel_groups -> input for validation"
    },
    {
      "from_step": "step_1_parse_skill_structure",
      "to_step": "step_6_validate_chain",
      "data_type": "skill_metadata",
      "field_mapping": "parsed_structure -> input for validation"
    },
    {
      "from_step": "step_6_validate_chain",
      "to_step": "step_7_generate_chain_json",
      "data_type": "validation_report",
      "field_mapping": "validation_report -> input for JSON generation"
    },
    {
      "from_step": "step_4_design_execution_dag",
      "to_step": "step_7_generate_chain_json",
      "data_type": "execution_dag",
      "field_mapping": "execution_dag -> input for JSON generation"
    },
    {
      "from_step": "step_5_identify_parallel_paths",
      "to_step": "step_7_generate_chain_json",
      "data_type": "parallel_groups",
      "field_mapping": "parallel_groups -> input for JSON generation"
    },
    {
      "from_step": "step_1_parse_skill_structure",
      "to_step": "step_7_generate_chain_json",
      "data_type": "skill_metadata",
      "field_mapping": "parsed_structure -> input for JSON generation"
    },
    {
      "from_step": "step_4_design_execution_dag",
      "to_step": "step_8_generate_execution_plan",
      "data_type": "execution_dag",
      "field_mapping": "execution_dag -> input for plan generation"
    },
    {
      "from_step": "step_5_identify_parallel_paths",
      "to_step": "step_8_generate_execution_plan",
      "data_type": "parallel_groups",
      "field_mapping": "parallel_groups -> input for plan generation"
    },
    {
