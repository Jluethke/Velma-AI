{
  "name": "Skill-Definition-to-Chain-Pipeline",
  "description": "Transform an improved skill definition into an executable FlowFabric pipeline by analyzing its structure, identifying component skills, and designing optimal data flows.",
  "steps": [
    {
      "id": "step_1_parse_skill_structure",
      "skill_name": "Skill Structure Parser",
      "inputs": {
        "skill_definition": "improved_skill (from context)",
        "audit_report": "audit_report (from context)"
      },
      "outputs": {
        "parsed_structure": "skill metadata, phases, inputs, outputs, constraints"
      },
      "parallel_group": "group_1"
    },
    {
      "id": "step_2_extract_requirements",
      "skill_name": "Requirement Extractor",
      "inputs": {
        "parsed_structure": "output from step_1"
      },
      "outputs": {
        "requirements_list": "discrete requirements with types and dependencies"
      },
      "parallel_group": "group_1"
    },
    {
      "id": "step_3_map_phases_to_capabilities",
      "skill_name": "Capability Mapper",
      "inputs": {
        "parsed_structure": "output from step_1",
        "requirements_list": "output from step_2"
      },
      "outputs": {
        "capability_map": "phase-to-requirement mappings with fit assessment"
      },
      "parallel_group": "group_2"
    },
    {
      "id": "step_4_design_execution_dag",
      "skill_name": "DAG Designer",
      "inputs": {
        "capability_map": "output from step_3",
        "parsed_structure": "output from step_1"
      },
      "outputs": {
        "execution_dag": "nodes (phases), edges (data flows), entry/terminal nodes"
      },
      "parallel_group": "group_3"
    },
    {
      "id": "step_5_identify_parallel_paths",
      "skill_name": "Parallelization Analyzer",
      "inputs": {
        "execution_dag": "output from step_4"
      },
      "outputs": {
        "parallel_groups": "independent phase groups, critical path"
      },
      "parallel_group": "group_4"
    },
    {
      "id": "step_6_validate_chain",
      "skill_name": "Chain Validator",
      "inputs": {
        "execution_dag": "output from step_4",
        "parallel_groups": "output from step_5",
        "parsed_structure": "output from step_1"
      },
      "outputs": {
        "validation_report": "acyclicity check, coverage check, data mapping validation"
      },
      "parallel_group": "group_5"
    },
    {
      "id": "step_7_generate_chain_json",
      "skill_name": "Chain JSON Generator",
      "inputs": {
        "execution_dag": "output from step_4",
        "parallel_groups": "output from step_5",
        "validation_report": "output from step_6",
        "parsed_structure": "output from step_1"
      },
      "outputs": {
        "chain_definition_json": ".chain.json formatted output"
      },
      "parallel_group": "group_6"
    },
    {
      "id": "step_8_generate_execution_plan",
      "skill_name": "Execution Plan Generator",
      "inputs": {
        "execution_dag": "output from step_4",
        "parallel_groups": "output from step_5",
        "chain_definition_json": "output from step_7"
      },
      "outputs": {
        "execution_plan": "human-readable layer-by-layer execution diagram"
      },
      "parallel_group": "group_6"
    },
    {
      "id": "step_9_identify_gaps",
      "skill_name": "Gap Analyzer",
      "inputs": {
        "capability_map": "output from step_3",
        "requirements_list": "output from step_2"
      },
      "outputs": {
        "missing_skills_list": "unmet requirements and skill descriptions needed"
      },
      "parallel_group": "group_2"
    },
    {
      "id": "step_10_synthesize_outputs",
      "skill_name": "Output Synthesizer",
      "inputs": {
        "chain_definition_json": "output from step_7",
        "execution_plan": "output from step_8",
        "missing_skills_list": "output from step_9",
        "validation_report": "output from step_6"
      },
      "outputs": {
        "final_chain_definition": "complete .chain.json",
        "final_execution_plan": "complete execution plan document",
        "final_missing_skills": "complete missing skills list",
        "final_coverage_report": "complete coverage report"
      },
      "parallel_group": "group_7"
    }
  ],
  "edges": [
    {
      "from_step": "step_1_parse_skill_structure",
      "to_step": "step_2_extract_requirements",
      "data_type": "skill_metadata",
      "field_mapping": "parsed_structure -> input for requirement extraction"
    },
    {
      "from_step": "step_1_parse_skill_structure",
      "to_step": "step_3_map_phases_to_capabilities",
      "data_type": "skill_metadata",
      "field_mapping": "parsed_structure -> input for capability mapping"
    },
    {
      "from_step": "step_2_extract_requirements",
      "to_step": "step_3_map_phases_to_capabilities",
      "data_type": "requirements_list",
      "field_mapping": "requirements_list -> input for capability mapping"
    },
    {
