{
    "name": "agricultural-supply-contract",
    "version": "1.0.0",
    "domain": "agriculture",
    "tags": ["agriculture", "supply contract", "grower", "processor", "food", "crop", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Processor / Buyer",
        "guest": "Grower"
    },
    "inputs": [
        "shared_buyer_and_grower",
        "shared_crop_and_volume",
        "buyer_volume_and_quality_requirements",
        "buyer_pricing_target",
        "buyer_supply_security_requirements",
        "buyer_concerns_about_the_grower",
        "buyer_contract_terms_required",
        "grower_production_capacity",
        "grower_cost_of_production",
        "grower_what_they_need_from_the_contract",
        "grower_risks_and_concerns",
        "grower_what_they_will_not_agree_to"
    ],
    "outputs": [
        "price_viability_assessment",
        "volume_and_delivery_agreement",
        "price_and_payment_structure",
        "risk_allocation",
        "food_safety_and_compliance_requirements",
        "contract_framework"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The food processor and the grower each submit their real volume needs, production capacity, and price requirements. Claude designs the supply agreement that gives the buyer reliable supply and the grower bankable terms."
