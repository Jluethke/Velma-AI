    "fabric_roles": {
        "host": "Financial Advisor",
        "guest": "Client"
    },
    "inputs": [
        "shared_advisor_and_client",
        "shared_assets_under_discussion",
        "advisor_assessment_of_client_situation",
        "advisor_recommended_strategy",
        "advisor_fee_structure",
        "advisor_concerns_about_the_client",
        "advisor_what_the_client_needs_to_do",
