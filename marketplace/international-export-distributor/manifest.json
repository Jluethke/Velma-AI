{
  "name": "International Export Distribution Agreement",
  "slug": "international-export-distributor",
  "description": "An exporter and a foreign distributor each submit their real market expectations, regulatory requirements, and commercial terms before entering the market — Claude aligns on a distribution arrangement that opens the market without the pricing, support, and legal disputes that stall most international expansion.",
  "domain": "logistics",
  "execution_pattern": "phase_pipeline",
  "fabric": true,
  "fabric_roles": {
    "host": "Exporter",
    "guest": "Foreign Distributor"
  },
  "inputs": [
    { "name": "shared_exporter_and_distributor", "type": "string", "required": true, "shared": true },
    { "name": "shared_market_and_product", "type": "string", "required": true, "shared": true },
    { "name": "exporter_market_objectives", "type": "object", "required": true, "role": "host" },
    { "name": "exporter_pricing_and_economics", "type": "object", "required": true, "role": "host" },
    { "name": "exporter_product_and_regulatory_support", "type": "object", "required": true, "role": "host" },
    { "name": "exporter_requirements_from_distributor", "type": "object", "required": true, "role": "host" },
    { "name": "exporter_concerns_about_this_distributor", "type": "array", "required": true, "role": "host" },
    { "name": "distributor_market_knowledge", "type": "object", "required": true, "role": "guest" },
    { "name": "distributor_economics_requirements", "type": "object", "required": true, "role": "guest" },
    { "name": "distributor_regulatory_and_compliance_context", "type": "object", "required": true, "role": "guest" },
    { "name": "distributor_concerns_about_this_exporter", "type": "array", "required": true, "role": "guest" },
    { "name": "distributor_what_they_will_not_do", "type": "array", "required": true, "role": "guest" }
  ],
  "outputs": [
    { "name": "market_entry_assessment", "type": "object" },
    { "name": "pricing_and_economics_structure", "type": "object" },
    { "name": "regulatory_and_compliance_roadmap", "type": "object" },
    { "name": "distributor_commitments_and_exclusivity", "type": "object" },
    { "name": "marketing_and_support_plan", "type": "object" },
    { "name": "distribution_agreement_framework", "type": "object" }
  ],
  "version": "1.0.0"
}
