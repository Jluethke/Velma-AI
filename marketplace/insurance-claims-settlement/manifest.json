{
    "name": "insurance-claims-settlement",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["insurance", "claims", "settlement", "adjuster", "claimant", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Claims Adjuster / Insurer",
        "guest": "Claimant / Public Adjuster"
    },
    "inputs": [
        "shared_claim_number",
        "shared_loss_description",
        "adjuster_coverage_analysis",
        "adjuster_reserve_position",
        "adjuster_settlement_authority",
        "adjuster_documentation_requirements",
        "adjuster_concerns_about_claim",
        "claimant_damages_claimed",
        "claimant_supporting_evidence",
        "claimant_urgency",
        "claimant_minimum_acceptable",
        "claimant_concerns_about_process"
    ],
    "outputs": [
        "coverage_position_summary",
        "damages_gap_analysis",
        "documentation_checklist",
        "negotiation_range",
        "settlement_path_options",
        "resolution_timeline"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Adjuster and claimant each submit their real coverage position and damages evidence before negotiations. Claude identifies the gap, surfaces documentation needs, and builds a resolution path that closes the claim fairly and efficiently."
}
