{
    "name": "pricing-strategy-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["pricing", "strategy", "sales", "finance", "product", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Product / Revenue Lead",
        "guest": "Finance / CFO"
    },
    "inputs": [
        "shared_product_name",
        "shared_current_pricing",
        "product_market_positioning",
        "product_competitive_pressure",
        "product_proposed_pricing_direction",
        "product_customer_sensitivity_read",
        "product_concerns_about_constraints",
        "finance_margin_requirements",
        "finance_revenue_targets",
        "finance_concerns_about_proposal",
        "finance_flexibility",
        "finance_what_would_make_it_work"
    ],
    "outputs": [
        "margin_viability_assessment",
        "competitive_position_check",
        "pricing_model_options",
        "revenue_impact_model",
        "negotiated_pricing_strategy",
        "implementation_risks"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "Product and finance each submit their real constraints on pricing — competitive pressure, margin requirements, customer sensitivity. AI models the tradeoffs and produces a pricing strategy both sides can defend to the board."
}
