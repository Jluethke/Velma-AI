{
    "name": "hotel-group-sales",
    "version": "1.0.0",
    "domain": "hospitality",
    "tags": ["hospitality", "hotel", "group sales", "events", "contract", "room block", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "Hotel Sales Manager",
        "guest": "Group Client"
    },
    "inputs": [
        "shared_hotel_and_event",
        "shared_event_dates_and_size",
        "hotel_minimum_revenue_requirements",
        "hotel_concession_budget",
        "hotel_attrition_and_cancellation_requirements",
        "hotel_concerns_about_this_group",
        "hotel_what_they_need_from_the_client",
        "client_event_requirements",
        "client_budget",
        "client_concerns_about_the_contract",
        "client_flexibility_in_the_program",
        "client_what_would_make_them_sign"
    ],
    "outputs": [
        "revenue_alignment_assessment",
        "room_block_and_rate_structure",
        "concession_package",
        "attrition_and_cancellation_terms",
        "contract_framework",
        "signing_path"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The hotel sales manager and the group client each submit their real event needs, budget constraints, and deal expectations. AI designs the contract terms that fill the block, protect the hotel's revenue, and give the client a workable deal for an event that will actually run as planned."
