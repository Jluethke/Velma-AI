{
    "name": "board-ceo-alignment",
    "version": "1.0.0",
    "domain": "business",
    "tags": ["board", "CEO", "governance", "leadership", "alignment", "fabric"],
    "fabric": true,
    "fabric_roles": {
        "host": "CEO",
        "guest": "Board Member"
    },
    "inputs": [
        "shared_company_name",
        "shared_period",
        "shared_agenda_topic",
        "ceo_assessment",
        "ceo_needs_from_board",
        "ceo_concerns",
        "ceo_undisclosed",
        "board_assessment",
        "board_concerns",
        "board_expectations",
        "board_confidence_level"
    ],
    "outputs": [
        "alignment_map",
        "confidence_gap",
        "unspoken_concerns",
        "support_needs",
        "board_meeting_agenda",
        "relationship_health"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "CEO and board member each submit their honest assessment before a board meeting or 1:1. Claude surfaces the confidence gaps, unspoken concerns, and what the CEO actually needs from the board — replacing the performance with a real conversation."
}
