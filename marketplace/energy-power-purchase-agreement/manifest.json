    "fabric": true,
    "fabric_roles": {
        "host": "Generator / Developer",
        "guest": "Offtaker"
    },
    "inputs": [
        "shared_project_name",
        "shared_energy_type_and_capacity",
        "generator_lcoe_and_price_floor",
        "generator_project_timeline_and_risks",
        "generator_capacity_factor_and_delivery_profile",
        "generator_bankability_requirements",
        "generator_concerns_about_the_offtaker",
        "offtaker_energy_needs",
        "offtaker_price_ceiling_and_budget",
        "offtaker_sustainability_requirements",
        "offtaker_term_and_risk_preferences",
        "offtaker_concerns_about_delivery"
    ],
    "outputs": [
        "price_and_economics_alignment",
        "delivery_profile_match",
        "ppa_structure_recommendation",
        "risk_allocation",
        "sustainability_and_rec_framework",
        "ppa_term_sheet"
    ],
    "execution_pattern": "phase_pipeline",
    "price": "0",
    "license": "OPEN",
    "description": "The energy generator and the offtaker each submit their real price requirements, volume commitments, and risk positions. Claude aligns on the PPA structure that gives the generator bankable revenue and the offtaker predictable energy costs."
